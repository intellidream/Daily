@code {
    [Parameter] public List<CountryEconomicData> Data { get; set; } = new();

    private Dictionary<string, CountryEconomicData> _dataMap = new();

    private string StrokeColor => "rgba(128,128,128,0.25)";
    private string TextColor => "rgba(200,200,200,0.9)";
    private string DefaultFill => "rgba(128,128,128,0.12)";

    protected override void OnParametersSet()
    {
        _dataMap = Data?.ToDictionary(d => d.CountryCode, d => d) ?? new();
    }

    private string GetFill(string cc)
    {
        if (!_dataMap.TryGetValue(cc, out var d)) return DefaultFill;
        var (r, g, b) = HeatRgb(d.RealRate);
        return $"rgb({r},{g},{b})";
    }

    private string GetTooltip(string cc)
    {
        if (!_dataMap.TryGetValue(cc, out var d)) return cc;
        return $"{d.CountryName}: {d.RealRate:F1}% real rate ({d.InterestRate:F1}% rate − {d.InflationRate:F1}% inflation)";
    }

    private string FormatLabel(string cc)
    {
        if (!_dataMap.TryGetValue(cc, out var d)) return cc;
        return $"{cc} {d.RealRate:F1}%";
    }

    private (int r, int g, int b) HeatRgb(decimal rate)
    {
        var c = Math.Max(-10, Math.Min(10, (double)rate));
        var n = (c + 10) / 20.0;
        int r, g, b;
        if (n < 0.5) { r = 244; g = (int)(67 + 188 * (n / 0.5)); b = (int)(54 * (1 - n / 0.5)); }
        else { r = (int)(255 * (1 - (n - 0.5) / 0.5)); g = (int)(175 + 80 * ((n - 0.5) / 0.5)); b = (int)(80 * ((n - 0.5) / 0.5)); }
        return (r, g, b);
    }

    // Label positions (approximate country centroids in SVG viewbox coordinates)
    private static readonly Dictionary<string, (int x, int y)> LabelPositions = new()
    {
        ["US"] = (220, 140), ["CA"] = (210, 80), ["MX"] = (200, 180), ["BR"] = (335, 300),
        ["AR"] = (295, 355), ["GB"] = (472, 92), ["FR"] = (488, 118), ["DE"] = (508, 103),
        ["SE"] = (527, 75), ["PL"] = (530, 100), ["RO"] = (547, 118), ["TR"] = (575, 137),
        ["CH"] = (502, 116), ["EG"] = (558, 170), ["SA"] = (600, 178), ["AE"] = (625, 178),
        ["NG"] = (500, 218), ["ZA"] = (547, 318), ["CN"] = (765, 145), ["IN"] = (698, 190),
        ["JP"] = (855, 133), ["KR"] = (822, 140), ["ID"] = (780, 260), ["TH"] = (752, 205),
        ["AU"] = (840, 310)
    };

    /// <summary>
    /// Renders all SVG text elements as a raw MarkupString.
    /// Razor treats &lt;text&gt; as a special directive, so we build it in C# code.
    /// </summary>
    private string RenderAllLabels()
    {
        var sb = new System.Text.StringBuilder();

        // Legend labels
        sb.Append($"<text x=\"325\" y=\"466\" font-size=\"9\" fill=\"{TextColor}\" text-anchor=\"end\" opacity=\"0.6\">−</text>");
        sb.Append($"<text x=\"635\" y=\"466\" font-size=\"9\" fill=\"{TextColor}\" text-anchor=\"start\" opacity=\"0.6\">+</text>");
        sb.Append($"<text x=\"480\" y=\"455\" font-size=\"9\" fill=\"{TextColor}\" text-anchor=\"middle\" opacity=\"0.5\">Real Interest Rate</text>");

        // Country labels — only show for countries with data, only on larger countries
        var labelsToShow = new[] { "US", "CA", "BR", "AR", "CN", "IN", "AU", "SA", "ZA", "MX", "ID", "EG" };
        foreach (var cc in labelsToShow)
        {
            if (_dataMap.ContainsKey(cc) && LabelPositions.ContainsKey(cc))
            {
                var (x, y) = LabelPositions[cc];
                var label = FormatLabel(cc);
                sb.Append($"<text x=\"{x}\" y=\"{y}\" font-size=\"9\" fill=\"{TextColor}\" text-anchor=\"middle\" font-weight=\"bold\" style=\"pointer-events:none;text-shadow:0 0 3px rgba(0,0,0,0.8);\">{label}</text>");
            }
        }

        return sb.ToString();
    }
}
