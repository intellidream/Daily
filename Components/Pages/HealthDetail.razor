@page "/vitals"
@using Daily.Models.Health
@using Daily.Services.Health
@using Daily.Services
@using Daily.Components.Widgets
@inject IHealthService HealthService
@inject IRefreshService RefreshService
@inject ISyncService SyncService
@inject IWindowManagerService WindowManager

<MudGrid Spacing="4" Class="h-100 pb-4">

    <!-- LEFT COLUMN: Activity Hero -->
    <MudItem xs="12" lg="6">
        <MudPaper Class="detail-tile rounded-xl pa-4 pa-md-6 d-flex flex-column justify-center relative overflow-hidden" Elevation="3" Style="height: 100%; min-height: 300px;">
             
             <!-- Header -->
             <div class="d-flex align-center justify-space-between mb-4 mb-md-8 z-10">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Warning" Size="Size.Large"/>
                    <MudText Typo="Typo.h4" Class="font-weight-bold">Activity</MudText>
                </div>
                <!-- Source Dot for Aggregate -->
                <div class="d-flex flex-column align-end gap-0">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.h6" Style="opacity: 0.7;">Today</MudText>
                        <MudTooltip Text="@_sourceTooltip">
                            <div style="@GetSourceDotStyle(_dominantSource)"></div>
                        </MudTooltip>
                    </div>
                    @if (!string.IsNullOrEmpty(_syncedAgoText))
                    {
                        <MudText Typo="Typo.caption" Style="opacity: 0.45; font-size: 10px;">@_syncedAgoText</MudText>
                    }
                </div>
            </div>

            <!-- Big Metrics (Responsive Stack) -->
            <div class="d-flex flex-column flex-md-row align-center justify-space-around z-10 my-4 gap-4">
                <!-- Steps -->
                <div class="d-flex flex-column align-center relative">
                     @{ var stepsM = GetMetric(VitalType.Steps); }
                     <div style="@GetSourceDotStyle(stepsM?.SourceDevice); position: absolute; top: -5px; right: -5px;"></div>
                     <MudText Typo="Typo.caption" Style="opacity: 0.6; text-transform: uppercase; letter-spacing: 1px;">STEPS</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@FormatNumber(stepsM?.Value ?? 0)</MudText>
                    @if (!string.IsNullOrEmpty(GetSyncCaption(stepsM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(stepsM)</MudText> }
                </div>

                <!-- Calories Ring -->
                <div class="d-flex flex-column align-center mx-4 relative">
                     @{ var calM = GetMetric(VitalType.ActiveEnergy); }
                     <div style="@GetSourceDotStyle(calM?.SourceDevice); position: absolute; top: 0; right: 0; z-index: 20;"></div>
                     <MudProgressCircular Value="@GetPercent(calM?.Value ?? 0, 2500)" Size="Size.Large" Color="Color.Warning" StrokeWidth="8" Style="height: 120px; width: 120px;">
                         <div class="d-flex flex-column align-center">
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@FormatNumber(calM?.Value ?? 0)</MudText>
                            <MudText Typo="Typo.caption">Kcal</MudText>
                         </div>
                     </MudProgressCircular>
                     @if (!string.IsNullOrEmpty(GetSyncCaption(calM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(calM)</MudText> }
                </div>

                <!-- Sleep -->
                <div class="d-flex flex-column align-center relative">
                    @{ var sleepM = GetMetric(VitalType.SleepDuration); }
                    <div style="@GetSourceDotStyle(sleepM?.SourceDevice); position: absolute; top: -5px; right: -5px;"></div>
                    <MudText Typo="Typo.caption" Style="opacity: 0.6; text-transform: uppercase; letter-spacing: 1px;">SLEEP</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@FormatSleep(sleepM?.Value ?? 0)</MudText>
                    @if (!string.IsNullOrEmpty(GetSyncCaption(sleepM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(sleepM)</MudText> }
                </div>
            </div>

            <!-- Activity Sub-Metrics -->
            <div class="d-flex justify-space-around mt-auto pa-4 rounded-xl z-10" style="background: rgba(255,255,255,0.05);">
                 @{ var distM = GetMetric(VitalType.Distance); var floorM = GetMetric(VitalType.FloorsClimbed); var speedM = GetMetric(VitalType.WalkingSpeed); }
                 <div class="d-flex flex-column align-center relative">
                     <div style="@GetSourceDotStyle(distM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                     <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Success" Size="Size.Small" Class="mb-1"/>
                     <MudText Typo="Typo.body1" Class="font-weight-bold">@(distM?.Value > 0 ? Math.Round(distM.Value/1000.0, 2) + "km" : "--")</MudText>
                 </div>
                 <div class="d-flex flex-column align-center relative">
                     <div style="@GetSourceDotStyle(floorM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                     <MudIcon Icon="@Icons.Material.Filled.Stairs" Color="Color.Info" Size="Size.Small" Class="mb-1"/>
                     <MudText Typo="Typo.body1" Class="font-weight-bold">@(floorM?.Value > 0 ? floorM.Value.ToString() : "--")</MudText>
                 </div>
                  <div class="d-flex flex-column align-center relative">
                     <div style="@GetSourceDotStyle(speedM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                     <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Warning" Size="Size.Small" Class="mb-1"/>
                     <MudText Typo="Typo.body1" Class="font-weight-bold">@(speedM?.Value > 0 ? speedM.Value + " m/s" : "--")</MudText>
                 </div>
            </div>

            <!-- Decorative Gradient -->
            <div style="position: absolute; top: 0; right: 0; width: 100%; height: 100%; 
                        background: radial-gradient(circle at top right, rgba(255,152,0,0.15) 0%, transparent 60%); pointer-events: none;"></div>
        </MudPaper>
    </MudItem>

    <!-- RIGHT COLUMN: Vitals Grid -->
    <MudItem xs="12" lg="6">
        <MudGrid Spacing="4">
            <!-- Heart Rate -->
            <MudItem xs="6">
                @{ var hrM = GetMetric(VitalType.HeartRate); }
                <MudPaper Class="detail-tile rounded-xl pa-4 d-flex flex-column align-center justify-center relative" Elevation="3" Style="height: 140px;">
                    <div style="@GetSourceDotStyle(hrM?.SourceDevice); position: absolute; top: 12px; right: 12px;"></div>
                    <MudIcon Icon="@Icons.Material.Filled.Favorite" Color="Color.Error" Class="mb-2" />
                    <MudText Typo="Typo.caption" Style="opacity: 0.6; text-transform: uppercase;">HEART RATE</MudText>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@(hrM?.Value > 0 ? hrM.Value + " bpm" : "--")</MudText>
                    @if (!string.IsNullOrEmpty(GetSyncCaption(hrM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(hrM)</MudText> }
                </MudPaper>
            </MudItem>

            <!-- Weight -->
            <MudItem xs="6">
                @{ var weightM = GetMetric(VitalType.Weight); }
                <MudPaper Class="detail-tile rounded-xl pa-4 d-flex flex-column align-center justify-center relative" Elevation="3" Style="height: 140px;">
                    <div style="@GetSourceDotStyle(weightM?.SourceDevice); position: absolute; top: 12px; right: 12px;"></div>
                    <MudIcon Icon="@Icons.Material.Filled.MonitorWeight" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.caption" Style="opacity: 0.6; text-transform: uppercase;">WEIGHT</MudText>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@(weightM?.Value > 0 ? weightM.Value + " kg" : "--")</MudText>
                    @if (!string.IsNullOrEmpty(GetSyncCaption(weightM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(weightM)</MudText> }
                </MudPaper>
            </MudItem>

            <!-- HRV -->
            <MudItem xs="6">
                @{ var hrvM = GetMetric(VitalType.HeartRateVariabilitySDNN) ?? GetMetric(VitalType.HeartRateVariabilityRMSSD); }
                <MudPaper Class="detail-tile rounded-xl pa-4 d-flex flex-column align-center justify-center relative" Elevation="3" Style="height: 140px;">
                     <div style="@GetSourceDotStyle(hrvM?.SourceDevice); position: absolute; top: 12px; right: 12px;"></div>
                    <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Color="Color.Secondary" Class="mb-2" />
                    <MudText Typo="Typo.caption" Style="opacity: 0.6; text-transform: uppercase;">HRV</MudText>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@(hrvM?.Value > 0 ? hrvM.Value + " ms" : "--")</MudText>
                    @if (!string.IsNullOrEmpty(GetSyncCaption(hrvM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(hrvM)</MudText> }
                </MudPaper>
            </MudItem>

            <!-- Blood Pressure -->
             <MudItem xs="6">
                @{ var bpSysM = GetMetric(VitalType.BloodPressureSystolic); var bpDiaM = GetMetric(VitalType.BloodPressureDiastolic); }
                <MudPaper Class="detail-tile rounded-xl pa-4 d-flex flex-column align-center justify-center relative" Elevation="3" Style="height: 140px;">
                    <div style="@GetSourceDotStyle(bpSysM?.SourceDevice); position: absolute; top: 12px; right: 12px;"></div>
                    <MudIcon Icon="@Icons.Material.Filled.Compress" Color="Color.Error" Class="mb-2" />
                    <MudText Typo="Typo.caption" Style="opacity: 0.6; text-transform: uppercase;">BP</MudText>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@(bpSysM?.Value > 0 && bpDiaM?.Value > 0 ? $"{bpSysM.Value}/{bpDiaM.Value}" : "--")</MudText>
                    @if (!string.IsNullOrEmpty(GetSyncCaption(bpSysM))) { <MudText Typo="Typo.caption" Style="opacity: 0.35; font-size: 9px;">@GetSyncCaption(bpSysM)</MudText> }
                </MudPaper>
            </MudItem>

            <!-- Expanded Vitals Row: RHR, RespRate, SpO2, Glucose -->
            <MudItem xs="12">
                <MudPaper Class="detail-tile rounded-xl pa-4 d-flex align-center justify-space-around relative" Elevation="3" Style="min-height: 80px;">
                    @{ var rhrM = GetMetric(VitalType.RestingHeartRate); var respM = GetMetric(VitalType.RespiratoryRate); var oxyM = GetMetric(VitalType.OxygenSaturation); var glucM = GetMetric(VitalType.BloodGlucose); }
                    <div class="d-flex flex-column align-center relative">
                        <div style="@GetSourceDotStyle(rhrM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">RHR</MudText>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">@(rhrM?.Value > 0 ? rhrM.Value + " bpm" : "--")</MudText>
                    </div>
                    <MudDivider Vertical="true" FlexItem="true" />
                    <div class="d-flex flex-column align-center relative">
                        <div style="@GetSourceDotStyle(respM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">RESP</MudText>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">@(respM?.Value > 0 ? respM.Value + " br/m" : "--")</MudText>
                    </div>
                    <MudDivider Vertical="true" FlexItem="true" />
                    <div class="d-flex flex-column align-center relative">
                        <div style="@GetSourceDotStyle(oxyM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">SpO2</MudText>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">@(oxyM?.Value > 0 ? oxyM.Value + "%" : "--")</MudText>
                    </div>
                    <MudDivider Vertical="true" FlexItem="true" />
                    <div class="d-flex flex-column align-center relative">
                        <div style="@GetSourceDotStyle(glucM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">GLUCOSE</MudText>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">@(glucM?.Value > 0 ? glucM.Value + " mg/dL" : "--")</MudText>
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Body Composition Row -->
            <MudItem xs="12">
                 @{ var bfM = GetMetric(VitalType.BodyFatPercentage); var lmM = GetMetric(VitalType.LeanBodyMass); var heightM = GetMetric(VitalType.Height); }
                 <MudPaper Class="detail-tile rounded-xl pa-4 d-flex align-center justify-space-around relative" Elevation="3" Style="height: 100px;">
                     <div class="d-flex flex-column align-center relative">
                         <div style="@GetSourceDotStyle(bfM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                         <MudText Typo="Typo.caption" Style="opacity: 0.6;">BODY FAT</MudText>
                         <MudText Typo="Typo.h6" Class="font-weight-bold">@(bfM?.Value > 0 ? bfM.Value + "%" : "--")</MudText>
                     </div>
                     <MudDivider Vertical="true" FlexItem="true" />
                      <div class="d-flex flex-column align-center">
                         <MudText Typo="Typo.caption" Style="opacity: 0.6;">BMI</MudText>
                         @{ var w = GetMetric(VitalType.Weight)?.Value ?? 0; var h = heightM?.Value ?? 0; var bmi = w > 0 && h > 0 ? w / (h * h) : 0; }
                         <MudText Typo="Typo.h6" Class="font-weight-bold">@(bmi > 0 ? bmi.ToString("N1") : "--")</MudText>
                     </div>
                     <MudDivider Vertical="true" FlexItem="true" />
                      <div class="d-flex flex-column align-center relative">
                         <div style="@GetSourceDotStyle(lmM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                         <MudText Typo="Typo.caption" Style="opacity: 0.6;">LEAN MASS</MudText>
                         <MudText Typo="Typo.h6" Class="font-weight-bold">@(lmM?.Value > 0 ? lmM.Value + "kg" : "--")</MudText>
                     </div>
                 </MudPaper>
            </MudItem>

            <!-- Sleep Stages (shown if any stage data exists) -->
            @{ var deepM = GetMetric(VitalType.SleepDeep); var lightM = GetMetric(VitalType.SleepLight); var remM = GetMetric(VitalType.SleepREM); var awakeM = GetMetric(VitalType.SleepAwake); }
            @if (deepM?.Value > 0 || lightM?.Value > 0 || remM?.Value > 0 || awakeM?.Value > 0)
            {
                <MudItem xs="12">
                    <MudPaper Class="detail-tile rounded-xl pa-4 d-flex flex-column gap-1 relative" Elevation="3">
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Bedtime" Color="Color.Info" Size="Size.Small"/>
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Sleep Stages</MudText>
                        </div>
                        <div class="d-flex align-center justify-space-around">
                            <div class="d-flex flex-column align-center relative">
                                <div style="@GetSourceDotStyle(deepM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                                <MudText Typo="Typo.caption" Style="color: #3F51B5;">DEEP</MudText>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@(deepM?.Value > 0 ? FormatSleep(deepM.Value) : "--")</MudText>
                            </div>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <div class="d-flex flex-column align-center relative">
                                <div style="@GetSourceDotStyle(lightM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                                <MudText Typo="Typo.caption" Style="color: #7C4DFF;">LIGHT</MudText>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@(lightM?.Value > 0 ? FormatSleep(lightM.Value) : "--")</MudText>
                            </div>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <div class="d-flex flex-column align-center relative">
                                <div style="@GetSourceDotStyle(remM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                                <MudText Typo="Typo.caption" Style="color: #00BCD4;">REM</MudText>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@(remM?.Value > 0 ? FormatSleep(remM.Value) : "--")</MudText>
                            </div>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <div class="d-flex flex-column align-center relative">
                                <div style="@GetSourceDotStyle(awakeM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                                <MudText Typo="Typo.caption" Style="color: #FF9800;">AWAKE</MudText>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@(awakeM?.Value > 0 ? FormatSleep(awakeM.Value) : "--")</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>
            }

            <!-- Sleep & Mind & Temp & Hydration Row -->
             <MudItem xs="12">
                 @{ var mindM = GetMetric(VitalType.MindfulSession); var tempM = GetMetric(VitalType.BodyTemperature); var h2oM = GetMetric(VitalType.Hydration); }
                 <MudPaper Class="detail-tile rounded-xl pa-4 d-flex align-center justify-space-around relative" Elevation="3" Style="height: 100px;">
                     <div class="d-flex flex-column align-center relative">
                         <div style="@GetSourceDotStyle(mindM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                         <div style="display:flex; align-items:center; gap:4px">
                            <MudIcon Icon="@Icons.Material.Filled.SelfImprovement" Color="Color.Info" Size="Size.Small"/>
                            <MudText Typo="Typo.caption" Style="opacity: 0.6;">MIND</MudText>
                         </div>
                         <MudText Typo="Typo.h6" Class="font-weight-bold">@(mindM?.Value > 0 ? mindM.Value + "m" : "--")</MudText>
                     </div>
                     <MudDivider Vertical="true" FlexItem="true" />
                      <div class="d-flex flex-column align-center relative">
                         <div style="@GetSourceDotStyle(tempM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                         <div style="display:flex; align-items:center; gap:4px">
                             <MudIcon Icon="@Icons.Material.Filled.DeviceThermostat" Color="Color.Warning" Size="Size.Small"/>
                             <MudText Typo="Typo.caption" Style="opacity: 0.6;">TEMP</MudText>
                         </div>
                         <MudText Typo="Typo.h6" Class="font-weight-bold">@(tempM?.Value > 0 ? tempM.Value + "°C" : "--")</MudText>
                     </div>
                     <MudDivider Vertical="true" FlexItem="true" />
                      <div class="d-flex flex-column align-center relative">
                         <div style="@GetSourceDotStyle(h2oM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                         <div style="display:flex; align-items:center; gap:4px">
                            <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Color="Color.Primary" Size="Size.Small"/>
                            <MudText Typo="Typo.caption" Style="opacity: 0.6;">H2O</MudText>
                         </div>
                         <MudText Typo="Typo.h6" Class="font-weight-bold">@(h2oM?.Value > 0 ? h2oM.Value + "L" : "--")</MudText>
                     </div>
                 </MudPaper>
            </MudItem>

            <!-- Nutrition Summary -->
            <MudItem xs="12">
                 @{ var carbsM = GetMetric(VitalType.Carbs); var protM = GetMetric(VitalType.Protein); var fatM = GetMetric(VitalType.Fat); }
                 <MudPaper Class="detail-tile rounded-xl pa-4 d-flex flex-column gap-2 relative" Elevation="3">
                     <!-- Macros -->
                     <div class="d-flex align-center justify-space-around mb-2">
                         <div class="d-flex flex-column align-center relative">
                             <div style="@GetSourceDotStyle(carbsM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                             <MudText Typo="Typo.caption" Style="color: #4caf50;">CARBS</MudText>
                             <MudText Typo="Typo.h6" Class="font-weight-bold">@(carbsM?.Value > 0 ? carbsM.Value + "g" : "--")</MudText>
                         </div>
                          <div class="d-flex flex-column align-center relative">
                             <div style="@GetSourceDotStyle(protM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                             <MudText Typo="Typo.caption" Style="color: #ff9800;">PROT</MudText>
                             <MudText Typo="Typo.h6" Class="font-weight-bold">@(protM?.Value > 0 ? protM.Value + "g" : "--")</MudText>
                         </div>
                          <div class="d-flex flex-column align-center relative">
                             <div style="@GetSourceDotStyle(fatM?.SourceDevice); position: absolute; top: -4px; right: -4px;"></div>
                             <MudText Typo="Typo.caption" Style="color: #f44336;">FAT</MudText>
                             <MudText Typo="Typo.h6" Class="font-weight-bold">@(fatM?.Value > 0 ? fatM.Value + "g" : "--")</MudText>
                         </div>
                     </div>
                     <MudDivider Light="true"/>
                     <!-- Micros -->
                     @{ var sugarM = GetMetric(VitalType.Sugar); var ironM = GetMetric(VitalType.Iron); var vitCM = GetMetric(VitalType.VitaminC); var caffM = GetMetric(VitalType.Caffeine); }
                     @{ var magM = GetMetric(VitalType.Magnesium); var zincM = GetMetric(VitalType.Zinc); var calcM = GetMetric(VitalType.Calcium); }
                     <div class="d-flex align-center justify-space-around mt-1 flex-wrap gap-2">
                          <MudText Typo="Typo.caption" Style="opacity:0.6">Sug: @(sugarM?.Value > 0 ? sugarM.Value+"g" : "-")</MudText>
                          <MudText Typo="Typo.caption" Style="opacity:0.6">Iron: @(ironM?.Value > 0 ? ironM.Value+"mg" : "-")</MudText>
                          <MudText Typo="Typo.caption" Style="opacity:0.6">VitC: @(vitCM?.Value > 0 ? vitCM.Value+"mg" : "-")</MudText>
                          <MudText Typo="Typo.caption" Style="opacity:0.6">Caff: @(caffM?.Value > 0 ? caffM.Value+"mg" : "-")</MudText>
                          <MudText Typo="Typo.caption" Style="opacity:0.6">Mg: @(magM?.Value > 0 ? magM.Value+"mg" : "-")</MudText>
                          <MudText Typo="Typo.caption" Style="opacity:0.6">Zn: @(zincM?.Value > 0 ? zincM.Value+"mg" : "-")</MudText>
                          <MudText Typo="Typo.caption" Style="opacity:0.6">Ca: @(calcM?.Value > 0 ? calcM.Value+"mg" : "-")</MudText>
                     </div>
                 </MudPaper>
            </MudItem>

            <!-- Cycle Tracking (Conditional) -->
            @{ var mensM = GetMetric(VitalType.MenstruationFlow); var ovuM = GetMetric(VitalType.OvulationTest); var sexM = GetMetric(VitalType.SexualActivity); }
            @if (mensM?.Value > 0 || ovuM?.Value > 0 || sexM?.Value > 0)
            {
                <MudItem xs="12">
                    <MudPaper Class="detail-tile rounded-xl pa-4 d-flex align-center justify-space-between relative" Elevation="3" Style="background: rgba(233, 30, 99, 0.1);">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Female" Color="Color.Secondary"/>
                            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="font-weight-bold">Cycle</MudText>
                        </div>
                        <div class="d-flex gap-4">
                             @if(mensM?.Value > 0) { <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">Flow</MudChip> }
                             @if(ovuM?.Value == 1) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Ovulation (+)</MudChip> }
                             @if(sexM?.Value > 0) { <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Activity</MudChip> }
                        </div>
                    </MudPaper>
                </MudItem>
            }

        </MudGrid>
    </MudItem>

    <!-- 7-Day Trends -->
    <MudItem xs="12">
        <MudExpansionPanels Elevation="0" Class="rounded-xl overflow-hidden" Style="background: transparent;">
            <MudExpansionPanel Text="7-Day Trends" IsInitiallyExpanded="true" Style="background: rgba(255,255,255,0.05);">
                @if (_stepsHistory.Any() || _sleepHistory.Any() || _hrHistory.Any())
                {
                    <MudGrid Spacing="4">
                        <!-- STEPS TREND -->
                        @if (_stepsHistory.Any())
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-4 rounded-xl detail-tile" Elevation="2">
                                    <div class="d-flex align-center justify-space-between mb-3">
                                        <div class="d-flex align-center gap-2">
                                            <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Small" Style="color: #FF9800;"/>
                                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Steps</MudText>
                                        </div>
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@GetTrendIcon(_stepsHistory)" Size="Size.Small" Style="@GetTrendColor(_stepsHistory)"/>
                                            <MudText Typo="Typo.caption" Style="@GetTrendColor(_stepsHistory)">@GetTrendPercent(_stepsHistory)</MudText>
                                        </div>
                                    </div>
                                    <MudChart ChartType="ChartType.Line" ChartSeries="@(new List<ChartSeries<double>> { new() { Name = "Steps", Data = _stepsHistory.ToArray() } })" 
                                              XAxisLabels="@_historyLabels" Width="100%" Height="140px" 
                                              ChartOptions="@(new ChartOptions { ChartPalette = new[] { "#FF9800" } })" />
                                    <!-- Stats Grid -->
                                    <div class="d-flex align-center justify-space-around mt-3 pa-2 rounded-lg" style="background: rgba(255,152,0,0.06);">
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">AVG</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@FormatNumber(_stepsAvg)</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">BEST</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #4CAF50;">@FormatNumber(_stepsMax)</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">LOW</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #FF5252;">@FormatNumber(_stepsMin)</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">TOTAL</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@FormatNumber(_stepsTotal)</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">TODAY</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #FF9800;">@FormatNumber(_stepsHistory.LastOrDefault())</MudText>
                                        </div>
                                    </div>
                                    <!-- Daily Breakdown -->
                                    <div class="d-flex align-center justify-space-between mt-2 gap-1">
                                        @for (int si = 0; si < _historyLabels.Length && si < _stepsBarPcts.Count; si++)
                                        {
                                            var idx = si;
                                            <div class="d-flex flex-column align-center" style="flex: 1;">
                                                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">@FormatNumber(_stepsHistory[idx])</MudText>
                                                <div style="width: 16px; height: 50px; border-radius: 4px; background: rgba(255,152,0,0.15); position: relative; overflow: hidden;">
                                                    <div style="position: absolute; bottom: 0; width: 100%; height: @(_stepsBarPcts[idx])%; background: #FF9800; border-radius: 4px;"></div>
                                                </div>
                                                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">@_historyLabels[idx]</MudText>
                                            </div>
                                        }
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }

                        <!-- SLEEP TREND -->
                        @if (_sleepHistory.Any())
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-4 rounded-xl detail-tile" Elevation="2">
                                    <div class="d-flex align-center justify-space-between mb-3">
                                        <div class="d-flex align-center gap-2">
                                            <MudIcon Icon="@Icons.Material.Filled.Bedtime" Size="Size.Small" Style="color: #7C4DFF;"/>
                                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Sleep (hours)</MudText>
                                        </div>
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@GetTrendIcon(_sleepHistory)" Size="Size.Small" Style="@GetTrendColor(_sleepHistory)"/>
                                            <MudText Typo="Typo.caption" Style="@GetTrendColor(_sleepHistory)">@GetTrendPercent(_sleepHistory)</MudText>
                                        </div>
                                    </div>
                                    <MudChart ChartType="ChartType.Line" ChartSeries="@(new List<ChartSeries<double>> { new() { Name = "Sleep", Data = _sleepHistory.ToArray() } })" 
                                              XAxisLabels="@_historyLabels" Width="100%" Height="140px" 
                                              ChartOptions="@(new ChartOptions { ChartPalette = new[] { "#7C4DFF" } })" />
                                    <!-- Stats -->
                                    <div class="d-flex align-center justify-space-around mt-3 pa-2 rounded-lg" style="background: rgba(124,77,255,0.06);">
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">AVG</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@(_sleepAvg.ToString("N1"))h</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">BEST</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #4CAF50;">@(_sleepMax.ToString("N1"))h</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">LOW</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #FF5252;">@(_sleepMin.ToString("N1"))h</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">TODAY</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #7C4DFF;">@(_sleepHistory.LastOrDefault().ToString("N1"))h</MudText>
                                        </div>
                                    </div>
                                    <!-- Daily Breakdown -->
                                    <div class="d-flex align-center justify-space-between mt-2 gap-1">
                                        @for (int sli = 0; sli < _historyLabels.Length && sli < _sleepBarPcts.Count; sli++)
                                        {
                                            var idx = sli;
                                            <div class="d-flex flex-column align-center" style="flex: 1;">
                                                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">@(_sleepHistory[idx].ToString("N1"))h</MudText>
                                                <div style="width: 16px; height: 50px; border-radius: 4px; background: rgba(124,77,255,0.15); position: relative; overflow: hidden;">
                                                    <div style="position: absolute; bottom: 0; width: 100%; height: @(_sleepBarPcts[idx])%; background: #7C4DFF; border-radius: 4px;"></div>
                                                </div>
                                                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">@_historyLabels[idx]</MudText>
                                            </div>
                                        }
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }

                        <!-- HEART RATE TREND -->
                        @if (_hrHistory.Any())
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-4 rounded-xl detail-tile" Elevation="2">
                                    <div class="d-flex align-center justify-space-between mb-3">
                                        <div class="d-flex align-center gap-2">
                                            <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" Style="color: #FF5252;"/>
                                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Heart Rate (bpm)</MudText>
                                        </div>
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@GetTrendIcon(_hrHistory)" Size="Size.Small" Style="@GetTrendColor(_hrHistory)"/>
                                            <MudText Typo="Typo.caption" Style="@GetTrendColor(_hrHistory)">@GetTrendPercent(_hrHistory)</MudText>
                                        </div>
                                    </div>
                                    <MudChart ChartType="ChartType.Line" ChartSeries="@(new List<ChartSeries<double>> { new() { Name = "HR", Data = _hrHistory.ToArray() } })" 
                                              XAxisLabels="@_historyLabels" Width="100%" Height="140px" 
                                              ChartOptions="@(new ChartOptions { ChartPalette = new[] { "#FF5252" } })" />
                                    <!-- Stats -->
                                    <div class="d-flex align-center justify-space-around mt-3 pa-2 rounded-lg" style="background: rgba(255,82,82,0.06);">
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">AVG</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@(_hrAvg.ToString("N0")) bpm</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">HIGH</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #FF5252;">@(_hrMax.ToString("N0")) bpm</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">LOW</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #4CAF50;">@(_hrMin.ToString("N0")) bpm</MudText>
                                        </div>
                                        <MudDivider Vertical="true" FlexItem="true" />
                                        <div class="d-flex flex-column align-center">
                                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 9px;">TODAY</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Style="color: #FF5252;">@(_hrHistory.LastOrDefault().ToString("N0")) bpm</MudText>
                                        </div>
                                    </div>
                                    <!-- Daily Breakdown -->
                                    <div class="d-flex align-center justify-space-between mt-2 gap-1">
                                        @for (int hi = 0; hi < _historyLabels.Length && hi < _hrBarPcts.Count; hi++)
                                        {
                                            var idx = hi;
                                            <div class="d-flex flex-column align-center" style="flex: 1;">
                                                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">@(_hrHistory[idx] > 0 ? _hrHistory[idx].ToString("N0") : "--")</MudText>
                                                <div style="width: 16px; height: 50px; border-radius: 4px; background: rgba(255,82,82,0.15); position: relative; overflow: hidden;">
                                                    <div style="position: absolute; bottom: 0; width: 100%; height: @(_hrBarPcts[idx])%; background: #FF5252; border-radius: 4px;"></div>
                                                </div>
                                                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">@_historyLabels[idx]</MudText>
                                            </div>
                                        }
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.5; text-align: center; padding: 16px;">No trend data available yet. Sync from a mobile device to start tracking.</MudText>
                }
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudItem>

    <!-- Diagnostics Footer -->
    <MudItem xs="12">
        <MudExpansionPanels Elevation="0" Class="rounded-xl overflow-hidden" Style="background: transparent;">
            <MudExpansionPanel Text="Diagnostics & Sync" Style="background: rgba(255,255,255,0.05);">
                <div class="d-flex flex-column gap-2">
                     <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ManualSync" Disabled="_isSyncing" FullWidth="true" Class="mb-2">
                        @(_isSyncing ? "Syncing..." : "Force Native Sync")
                    </MudButton>
                    <MudTextField Value="@_debugLog" Label="Sync Logs" Variant="Variant.Outlined" Lines="8" ReadOnly="true" Style="font-family: monospace; font-size: 11px;" />
                </div>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudItem>

</MudGrid>

@implements IDisposable

@code {
    // Store all metrics as VitalMetric objects for source dots + sync times
    private List<VitalMetric> _metrics = new();

    // Dominant Source & SyncedAt
    private string _dominantSource = "Mixed";
    private string _sourceTooltip = "Source: Multiple";
    private string _syncedAgoText = "";

    // 7-Day Trend History
    private List<double> _stepsHistory = new();
    private List<double> _sleepHistory = new();
    private List<double> _hrHistory = new();
    private string[] _historyLabels = Array.Empty<string>();

    // Pre-computed bar chart data (avoid expensive LINQ in render)
    private List<double> _stepsBarPcts = new();
    private List<double> _sleepBarPcts = new();
    private List<double> _hrBarPcts = new();
    private double _stepsMax, _stepsAvg, _stepsMin, _stepsTotal;
    private double _sleepMax, _sleepAvg, _sleepMin;
    private double _hrMax, _hrAvg, _hrMin;

    // Diagnostics
    private string _debugLog = "";
    private bool _isSyncing = false;

    protected override async Task OnInitializedAsync()
    {
        RefreshService.RefreshRequested += LoadDataInternal;
        
        // Initial Log Load
        _debugLog = SyncService.DebugLog;
        SyncService.OnDebugLogUpdated += UpdateLog;

        await LoadDataInternal();
    }
    
    private void UpdateLog()
    {
        _debugLog = SyncService.DebugLog;
        InvokeAsync(StateHasChanged);
    }
    
    private async Task ManualSync()
    {
        if (_isSyncing) return;
        _isSyncing = true;
        StateHasChanged();
        
        try 
        {
            await HealthService.SyncNativeHealthDataAsync();
            await LoadDataInternal();
        }
        catch(Exception ex)
        {
             Console.WriteLine($"Manual Sync Failed: {ex}");
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task LoadDataInternal() => await LoadData(); 

    private async Task LoadData()
    {
         try 
        {
            await InvokeAsync(async () => 
            {
                _metrics = await HealthService.FetchMetricsAsync(DateTime.Now);

                // Dominant Source Calculation (>70% threshold)
                CalculateDominantSource(_metrics);

                // SyncedAt (with updated_at fallback)
                CalculateSyncedAgo(_metrics);

                StateHasChanged();
            });

            // Load trend history in background (fire-and-forget to avoid blocking UI)
            _ = Task.Run(async () => {
                try { await LoadTrendHistory(); }
                catch (Exception tex) { Console.WriteLine($"Trend history error: {tex.Message}"); }
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading health detail: {ex}");
        }
    }

    /// <summary>
    /// Get a specific metric from the loaded list. Returns null if not found or value is 0.
    /// </summary>
    private VitalMetric GetMetric(VitalType type)
    {
        var m = _metrics.FirstOrDefault(x => x.TypeString == type.ToString());
        return m?.Value > 0 ? m : null;
    }

    private void CalculateDominantSource(List<VitalMetric> metrics)
    {
        var sourced = metrics.Where(m => !string.IsNullOrEmpty(m.SourceDevice)).ToList();
        if (!sourced.Any()) { _dominantSource = "Mixed"; _sourceTooltip = "No source data"; return; }

        int iosCount = sourced.Count(m => m.SourceDevice == "iOS");
        int androidCount = sourced.Count(m => m.SourceDevice == "Health Connect" || m.SourceDevice == "Android");
        int total = sourced.Count;

        double iosPercent = total > 0 ? (double)iosCount / total : 0;
        double androidPercent = total > 0 ? (double)androidCount / total : 0;

        if (iosPercent >= 0.70) _dominantSource = "iOS";
        else if (androidPercent >= 0.70) _dominantSource = "Health Connect";
        else _dominantSource = "Mixed";

        _sourceTooltip = $"iOS: {iosCount}, Android: {androidCount}";
        if (total - iosCount - androidCount > 0)
            _sourceTooltip += $", Other: {total - iosCount - androidCount}";
    }

    private void CalculateSyncedAgo(List<VitalMetric> metrics)
    {
        // Try SyncedAt first, fallback to UpdatedAt for older data
        var latestSync = metrics
            .Select(m => m.SyncedAt ?? (DateTime?)m.UpdatedAt)
            .Where(t => t.HasValue)
            .OrderByDescending(t => t)
            .FirstOrDefault();

        if (latestSync != null)
        {
            var ago = DateTime.UtcNow - latestSync.Value;
            if (ago.TotalMinutes < 1) _syncedAgoText = "Synced just now";
            else if (ago.TotalMinutes < 60) _syncedAgoText = $"Synced {(int)ago.TotalMinutes}m ago";
            else if (ago.TotalHours < 24) _syncedAgoText = $"Synced {(int)ago.TotalHours}h ago";
            else _syncedAgoText = $"Synced {(int)ago.TotalDays}d ago";
        }
        else
        {
            _syncedAgoText = "";
        }
    }

    private async Task LoadTrendHistory()
    {
        try 
        {
            var stepsData = await HealthService.GetHistoryAsync(VitalType.Steps, 7);
            var sleepData = await HealthService.GetHistoryAsync(VitalType.SleepDuration, 7);
            var hrData = await HealthService.GetHistoryAsync(VitalType.HeartRate, 7);

            var labels = new List<string>();
            var stepsVals = new List<double>();
            var sleepVals = new List<double>();
            var hrVals = new List<double>();

            for (int i = 6; i >= 0; i--)
            {
                var day = DateTime.Today.AddDays(-i);
                labels.Add(day.ToString("ddd"));
                stepsVals.Add(stepsData.FirstOrDefault(m => m.Date.Date == day)?.Value ?? 0);
                var sleepMin = sleepData.FirstOrDefault(m => m.Date.Date == day)?.Value ?? 0;
                sleepVals.Add(Math.Round(sleepMin / 60.0, 1));
                hrVals.Add(hrData.FirstOrDefault(m => m.Date.Date == day)?.Value ?? 0);
            }

            _historyLabels = labels.ToArray();
            _stepsHistory = stepsVals.Any(v => v > 0) ? stepsVals : new List<double>();
            _sleepHistory = sleepVals.Any(v => v > 0) ? sleepVals : new List<double>();
            _hrHistory = hrVals.Any(v => v > 0) ? hrVals : new List<double>();

            // Pre-compute stats to avoid LINQ in render loop
            if (_stepsHistory.Any())
            {
                _stepsMax = _stepsHistory.Max();
                _stepsMin = _stepsHistory.Where(v => v > 0).DefaultIfEmpty(0).Min();
                _stepsAvg = _stepsHistory.Where(v => v > 0).DefaultIfEmpty(0).Average();
                _stepsTotal = _stepsHistory.Sum();
                _stepsBarPcts = _stepsHistory.Select(v => _stepsMax > 0 ? v / _stepsMax * 100 : 0).ToList();
            }
            if (_sleepHistory.Any())
            {
                _sleepMax = _sleepHistory.Max();
                _sleepMin = _sleepHistory.Where(v => v > 0).DefaultIfEmpty(0).Min();
                _sleepAvg = _sleepHistory.Where(v => v > 0).DefaultIfEmpty(0).Average();
                _sleepBarPcts = _sleepHistory.Select(v => _sleepMax > 0 ? v / _sleepMax * 100 : 0).ToList();
            }
            if (_hrHistory.Any())
            {
                _hrMax = _hrHistory.Max();
                _hrMin = _hrHistory.Where(v => v > 0).DefaultIfEmpty(0).Min();
                _hrAvg = _hrHistory.Where(v => v > 0).DefaultIfEmpty(0).Average();
                var range = _hrMax - _hrMin;
                _hrBarPcts = _hrHistory.Select(v => range > 0 ? (v - _hrMin) / range * 100 : 50).ToList();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading trend history: {ex}");
        }
    }


    private string GetSyncCaption(VitalMetric m)
    {
        if (m == null) return "";
        var ts = m.SyncedAt ?? (DateTime?)m.UpdatedAt;
        if (ts == null) return "";
        var ago = DateTime.UtcNow - ts.Value;
        if (ago.TotalMinutes < 1) return "just now";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        if (ago.TotalHours < 24) return $"{(int)ago.TotalHours}h ago";
        return $"{(int)ago.TotalDays}d ago";
    }

    private int GetPercent(double current, double goal)
    {
        if (goal <= 0) return 0;
        var p = (int)((current / goal) * 100);
        return Math.Min(p, 100);
    }
    
    private string FormatNumber(double val) => val >= 1000 ? (val / 1000.0).ToString("N1") + "k" : (val > 0 ? val.ToString("N0") : "--");

    private string FormatSleep(double minutes)
    {
        if (minutes <= 0) return "--";
        var ts = TimeSpan.FromMinutes(minutes);
        return $"{ts.Hours}h {ts.Minutes}m";
    }
    
    private string GetSourceDotStyle(string source)
    {
        string color = "rgba(158, 158, 158, 0.5)"; // Default Grey
        if (source == "iOS") color = "#2979FF"; // Blue
        else if (source == "Health Connect" || source == "Android") color = "#00E676"; // Green
        else if (source == "Manual") color = "#E91E63"; // Pink
        
        return $"width: 8px; height: 8px; border-radius: 50%; background-color: {color}; display: inline-block;";
    }

    // Trend Analysis Helpers
    private double GetAvg(List<double> data) => data.Where(v => v > 0).DefaultIfEmpty(0).Average();
    private double GetMax(List<double> data) => data.DefaultIfEmpty(0).Max();
    private double GetMinNonZero(List<double> data) => data.Where(v => v > 0).DefaultIfEmpty(0).Min();

    private string GetTrendIcon(List<double> data)
    {
        if (data.Count < 2) return Icons.Material.Filled.Remove;
        // Compare last 3 days avg to first 3 days avg
        var recentAvg = data.Skip(Math.Max(0, data.Count - 3)).Where(v => v > 0).DefaultIfEmpty(0).Average();
        var olderAvg = data.Take(3).Where(v => v > 0).DefaultIfEmpty(0).Average();
        if (olderAvg == 0) return Icons.Material.Filled.Remove;
        var change = (recentAvg - olderAvg) / olderAvg;
        if (change > 0.05) return Icons.Material.Filled.TrendingUp;
        if (change < -0.05) return Icons.Material.Filled.TrendingDown;
        return Icons.Material.Filled.TrendingFlat;
    }

    private string GetTrendColor(List<double> data)
    {
        if (data.Count < 2) return "color: grey;";
        var recentAvg = data.Skip(Math.Max(0, data.Count - 3)).Where(v => v > 0).DefaultIfEmpty(0).Average();
        var olderAvg = data.Take(3).Where(v => v > 0).DefaultIfEmpty(0).Average();
        if (olderAvg == 0) return "color: grey;";
        var change = (recentAvg - olderAvg) / olderAvg;
        if (change > 0.05) return "color: #4CAF50;";
        if (change < -0.05) return "color: #FF5252;";
        return "color: grey;";
    }

    private string GetTrendPercent(List<double> data)
    {
        if (data.Count < 2) return "—";
        var recentAvg = data.Skip(Math.Max(0, data.Count - 3)).Where(v => v > 0).DefaultIfEmpty(0).Average();
        var olderAvg = data.Take(3).Where(v => v > 0).DefaultIfEmpty(0).Average();
        if (olderAvg == 0) return "—";
        var pct = (recentAvg - olderAvg) / olderAvg * 100;
        return $"{(pct > 0 ? "+" : "")}{pct:N0}%";
    }

    public void Dispose()
    {
        RefreshService.RefreshRequested -= LoadDataInternal;
        SyncService.OnDebugLogUpdated -= UpdateLog;
    }
}
