@using Daily.Services
@using Daily.Models
@using MudBlazor
@inject IRssFeedService RssService
@inject IRssArticleService ArticleService
@inject IDetailNavigationService NavService
@inject IBackButtonService _backButtonService
@inject IRefreshService RefreshService
@inject ISnackbar Snackbar

@implements IDisposable

<div class="d-flex flex-column" style="height: 100%; position: relative;">

    <!-- List View (Always rendered, hidden via CSS when reading) -->
    <div class="@(_selectedItem == null ? "d-flex flex-column" : "d-none") mx-n4" style="height: 100%; overflow: hidden;">

        @if (RssService.IsLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2 flex-shrink-0" />
        }

        @if (OverlayMode == RssOverlayMode.Publications)
        {
            <!-- Publications Picker -->
            <div style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;" class="px-4 pb-4">
                @foreach (var category in Enum.GetValues<FeedCategory>())
                {
                    var feedsInCategory = RssService.Feeds.Where(f => f.Category == category).ToList();
                    if (feedsInCategory.Any())
                    {
                        <MudText Typo="Typo.overline" Class="px-2 pt-4 pb-1" Style="opacity: 0.6; font-weight: 700; letter-spacing: 0.1em;">
                            @GetCategoryLabel(category)
                        </MudText>
                        <MudDivider Class="mx-2 mb-1" />
                        @foreach (var feed in feedsInCategory)
                        {
                            var isSelected = RssService.CurrentFeed == feed;
                            <MudPaper Class="@($"pa-3 mb-2 cursor-pointer hover-scale rounded-xl {(isSelected ? "pub-selected" : "tile-glass")}")"
                                      @onclick="@(() => SelectPublication(feed))" Elevation="@(isSelected ? 4 : 1)">
                                <div class="d-flex align-center gap-3">
                                    @if (!string.IsNullOrEmpty(feed.IconUrl))
                                    {
                                        <MudImage Src="@feed.IconUrl" Width="28" Height="28" ObjectFit="ObjectFit.Contain" Class="rounded flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.RssFeed" Class="flex-shrink-0" />
                                    }
                                    <MudText Typo="Typo.body1" Style="@(isSelected ? "font-weight: 700;" : "")">@feed.Name</MudText>
                                    @if (isSelected)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Primary" Class="ml-auto" />
                                    }
                                </div>
                            </MudPaper>
                        }
                    }
                }
            </div>
        }
        else if (OverlayMode == RssOverlayMode.ReadLater)
        {
            <!-- Read Later List -->
            <div style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;" class="px-4 pb-4">
                @if (!ArticleService.ReadLaterItems.Any())
                {
                    <div class="d-flex justify-center align-center" style="height: 200px;">
                        <MudText Color="Color.Secondary">No articles saved for later.</MudText>
                    </div>
                }
                else
                {
                    <MudGrid Spacing="4">
                    @foreach (var dateGroup in ArticleService.ReadLaterItems.GroupBy(a => a.CreatedAt.ToLocalTime().Date).OrderByDescending(g => g.Key))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.overline" Class="px-2 pt-2 pb-1" Style="opacity: 0.6; font-weight: 700; letter-spacing: 0.1em;">
                                @dateGroup.Key.ToString("D")
                            </MudText>
                            <MudDivider Class="mx-2 mb-2" />
                        </MudItem>
                        @foreach (var article in dateGroup)
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-3 cursor-pointer hover-scale tile-glass rounded-xl" @onclick="@(() => OpenSavedItem(article))">
                                    <div class="d-flex gap-4 align-center">
                                        @if (!string.IsNullOrEmpty(article.PublicationIconUrl))
                                        {
                                            <div class="rounded-lg flex-shrink-0 d-flex justify-center align-center" style="width: 60px; height: 50px;">
                                                <MudImage Src="@article.PublicationIconUrl" Width="40" Height="40" ObjectFit="ObjectFit.Contain" />
                                            </div>
                                        }
                                        <div class="d-flex flex-column flex-grow-1" style="min-width: 0;">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600; line-height: 1.2;">@article.Title</MudText>
                                            <MudText Typo="Typo.caption" Class="mt-1" Style="opacity: 0.7;">@article.PublicationName • @article.ArticleDate.ToString("g")</MudText>
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.BookmarkRemove" Size="Size.Small" Color="Color.Warning"
                                                       OnClick="@(async () => await RemoveSaved(article.ArticleUrl, SavedArticleType.ReadLater))"
                                                       OnClick:stopPropagation="true" Title="Remove" />
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }
                    }
                    </MudGrid>
                }
            </div>
        }
        else if (OverlayMode == RssOverlayMode.Favorites)
        {
            <!-- Favorites List -->
            <div style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;" class="px-4 pb-4">
                @if (!ArticleService.FavoriteItems.Any())
                {
                    <div class="d-flex justify-center align-center" style="height: 200px;">
                        <MudText Color="Color.Secondary">No favorite articles yet.</MudText>
                    </div>
                }
                else
                {
                    <MudGrid Spacing="4">
                    @foreach (var pubGroup in ArticleService.FavoriteItems.GroupBy(a => a.PublicationName).OrderBy(g => g.Key))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.overline" Class="px-2 pt-2 pb-1" Style="opacity: 0.6; font-weight: 700; letter-spacing: 0.1em;">
                                @pubGroup.Key
                            </MudText>
                            <MudDivider Class="mx-2 mb-2" />
                        </MudItem>
                        @foreach (var article in pubGroup.OrderByDescending(a => a.ArticleDate))
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-3 cursor-pointer hover-scale tile-glass rounded-xl" @onclick="@(() => OpenSavedItem(article))">
                                    <div class="d-flex gap-4 align-center">
                                        @if (!string.IsNullOrEmpty(article.ImageUrl))
                                        {
                                            <div style="flex-shrink: 0;">
                                                <MudImage Src="@article.ImageUrl" Width="@(_isMobile ? 80 : 200)" Height="@(_isMobile ? 54 : 135)" ObjectFit="ObjectFit.Cover" Class="rounded-xl elevation-2" />
                                            </div>
                                        }
                                        <div class="d-flex flex-column flex-grow-1" style="min-width: 0;">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600; line-height: 1.2;">@article.Title</MudText>
                                            <MudText Typo="Typo.caption" Class="mt-1" Style="opacity: 0.7;">@article.ArticleDate.ToString("g")</MudText>
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.StarBorder" Size="Size.Small" Color="Color.Warning"
                                                       OnClick="@(async () => await RemoveSaved(article.ArticleUrl, SavedArticleType.Favorite))"
                                                       OnClick:stopPropagation="true" Title="Remove from favorites" />
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }
                    }
                    </MudGrid>
                }
            </div>
        }
        else
        {
            <!-- Articles List -->
            <div style="flex-grow: 1; overflow-y: auto;" class="px-4 pb-4">
                <MudGrid Spacing="4">
                    @if (RssService.Items != null)
                    {
                        @foreach (var item in RssService.Items.Skip((_currentPage - 1) * _pageSize).Take(_pageSize))
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-3 cursor-pointer hover-scale tile-glass rounded-xl" @onclick="@(() => OpenItem(item))">
                                    <div class="d-flex gap-4">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <div style="flex-shrink: 0;">
                                                <MudImage Src="@item.ImageUrl" Width="@(_isMobile ? 80 : 200)" Height="@(_isMobile ? 54 : 135)" ObjectFit="ObjectFit.Cover" Class="rounded-xl elevation-2" />
                                            </div>
                                        }
                                        <div class="d-flex flex-column flex-grow-1" style="min-width: 0;">
                                            <MudTooltip Text="@item.Title" Arrow="true" Placement="Placement.Top">
                                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; line-height: 1.2;">@item.Title</MudText>
                                            </MudTooltip>
                                            <MudText Typo="Typo.caption" Class="mt-1" Style="opacity: 0.7;">@item.PublishDate.ToString("g")</MudText>
                                            @if (!string.IsNullOrEmpty(item.Description))
                                            {
                                                 <MudText Typo="Typo.body2" Class="mt-2" Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; opacity: 0.9;">
                                                     @((MarkupString)StripHtml(item.Description))
                                                 </MudText>
                                            }
                                        </div>
                                        <div class="d-flex flex-column flex-shrink-0 justify-center" style="gap: 2px;">
                                            <MudIconButton Icon="@(ArticleService.IsSaved(item.Link, SavedArticleType.ReadLater) ? Icons.Material.Filled.Bookmark : Icons.Material.Filled.BookmarkBorder)" 
                                                           Size="Size.Small" Color="@(ArticleService.IsSaved(item.Link, SavedArticleType.ReadLater) ? Color.Primary : Color.Default)"
                                                           OnClick="@(async () => await ToggleSave(item, SavedArticleType.ReadLater))" OnClick:stopPropagation="true"
                                                           Title="Read Later" />
                                            <MudIconButton Icon="@(ArticleService.IsSaved(item.Link, SavedArticleType.Favorite) ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" 
                                                           Size="Size.Small" Color="@(ArticleService.IsSaved(item.Link, SavedArticleType.Favorite) ? Color.Warning : Color.Default)"
                                                           OnClick="@(async () => await ToggleSave(item, SavedArticleType.Favorite))" OnClick:stopPropagation="true"
                                                           Title="Favorite" />
                                        </div>
                                    </div>
                                </MudPaper>
                            </MudItem>
                        }
                    }
                </MudGrid>
            </div>
            @if (RssService.Items != null && RssService.Items.Count > _pageSize)
            {
                <div class="d-flex justify-center py-2 flex-shrink-0 px-4">
                     <MudPagination BoundaryCount="1" MiddleCount="1" Count="@_pageCount" SelectedChanged="OnPageChanged" Selected="@_currentPage" 
                                    Class="pa-2" Variant="Variant.Outlined" Size="Size.Small" ShowFirstButton="false" ShowLastButton="false" />
                </div>
            }
        }
    </div>

    <!-- Reading Mode (Only rendered when selected) -->
    @if (_selectedItem != null)
    {
        <div class="d-flex flex-column animate-fade-in" style="height: 100%; overflow: hidden;">
            @if (NavService.IsBrowserOpen && !NavService.IsReaderMode)
            {
                 // Native WebView Overlay is handling this
                 <div class="d-flex align-center justify-center" style="height: 100%;">
                     <MudText Typo="Typo.h5" Style="opacity: 0.5;">Viewing Web Content...</MudText>
                 </div>
            }
            else
            {
                <!-- Inject Shared Readability CSS (Universal) -->
                <style>
                    @((MarkupString)Configuration.ReadabilitySettings.GetCss(_isMobile))
                </style>

                <MudSwipeArea OnSwipe="@OnSwipe" Style="flex-grow: 1; overflow: hidden; display: flex; flex-direction: column;">
                    <MudPaper Class="@(_isMobile ? "pa-3 reader-paper rounded-xl mb-4" : "pa-6 reader-paper rounded-xl mb-4")" Elevation="3" Style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;">
                    <div class="reader-content" data-theme="@(_isDarkMode ? "dark" : "light")">
                        <MudText Typo="Typo.h4" GutterBottom="true" Style="font-weight: 800;">@_selectedItem.Title</MudText>
                        
                        @if (_isArticleLoading)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                        }
                        else
                        {
                             <div class="d-flex align-center mb-6">
                                 @if (!string.IsNullOrEmpty(RssService.CurrentFeed?.IconUrl))
                                 {
                                     <MudImage Src="@RssService.CurrentFeed.IconUrl" Width="20" Height="20" Class="me-2 rounded-circle" ObjectFit="ObjectFit.Cover" />
                                 }
                                 <MudText Typo="Typo.caption" Style="opacity: 0.8;" Class="flex-grow-1">
                                     <span class="fw-bold">@RssService.CurrentFeed?.Name</span>
                                     @if (!string.IsNullOrEmpty(_selectedItem.Author))
                                     {
                                         <span> • @_selectedItem.Author</span>
                                     } 
                                     • @_selectedItem.PublishDate.ToString("f")
                                 </MudText>
                                 <MudIconButton Icon="@(ArticleService.IsSaved(_selectedItem.Link, SavedArticleType.ReadLater) ? Icons.Material.Filled.Bookmark : Icons.Material.Filled.BookmarkBorder)" 
                                                Size="Size.Small" Color="@(ArticleService.IsSaved(_selectedItem.Link, SavedArticleType.ReadLater) ? Color.Primary : Color.Default)"
                                                OnClick="@(async () => await ToggleSave(_selectedItem, SavedArticleType.ReadLater))"
                                                Title="Read Later" />
                                 <MudIconButton Icon="@(ArticleService.IsSaved(_selectedItem.Link, SavedArticleType.Favorite) ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" 
                                                Size="Size.Small" Color="@(ArticleService.IsSaved(_selectedItem.Link, SavedArticleType.Favorite) ? Color.Warning : Color.Default)"
                                                OnClick="@(async () => await ToggleSave(_selectedItem, SavedArticleType.Favorite))"
                                                Title="Favorite" />
                            </div>
    
                            <!-- Featured Image (Only if NOT in Reader Mode or if desired) -->
                            @if (!string.IsNullOrEmpty(_selectedItem.ImageUrl))
                            {
                                <MudImage Src="@_selectedItem.ImageUrl" Class="rounded-xl mb-6" Style="max-width: 100%; height: auto; object-fit: contain; display: block; margin: 0 auto;" />
                            }
    
                            <div class="article-content" style="@(NavService.IsReaderMode ? "font-size: 1.2rem; line-height: 1.8;" : "")">
                                @if (!string.IsNullOrEmpty(_selectedItem.Content))
                                {
                                    @((MarkupString)_selectedItem.Content)
                                }
                                else if (!string.IsNullOrEmpty(_selectedItem.Description))
                                {
                                     @((MarkupString)_selectedItem.Description)
                                     <MudAlert Severity="Severity.Info" Class="mt-4">Full content not available in feed.</MudAlert>
                                }
                            </div>
                        }

                        @if (!NavService.IsReaderMode && !_isReaderViewChanged)
                        {
                            <div class="d-flex justify-center mt-8 mb-4 gap-4">
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="@OnReaderViewClicked" StartIcon="@Icons.Material.Filled.ChromeReaderMode" Disabled="@_isReaderViewLoading">
                                    @if (_isReaderViewLoading)
                                    {
                                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                        <span class="ms-2">Loading Reader View...</span>
                                    }
                                    else
                                    {
                                        <span>Reader View</span>
                                    }
                                </MudButton>
                            </div>
                        }
                    </div>
                </MudPaper>
                </MudSwipeArea>
            }
        </div>
    }
</div>

<style>
    .tile-glass { background-color: rgba(255, 255, 255, 0.4); backdrop-filter: blur(5px); }
    [data-theme='dark'] .tile-glass { background-color: rgba(0, 0, 0, 0.4); }

    [data-theme='light'] .reader-paper { background-color: rgba(250, 249, 246, 0.20); backdrop-filter: blur(5px); }
    [data-theme='dark'] .reader-paper { background-color: rgba(0, 0, 0, 0.3); backdrop-filter: blur(5px); }
    
    .hover-scale { transition: transform 0.2s; }
    .hover-scale:hover { transform: scale(1.01); }

    .article-content img { max-width: 100%; height: auto; border-radius: 12px; margin: 16px 0; }
    .article-content p { font-size: 1.1rem; line-height: 1.6; margin-bottom: 16px; opacity: 0.9; }
    .article-content h1, .article-content h2, .article-content h3 { font-weight: 700; margin-top: 24px; margin-bottom: 12px; }
    .article-content a { color: var(--mud-palette-primary); text-decoration: none; }
    .article-content a:hover { text-decoration: underline; }

    .pub-selected { background-color: var(--mud-palette-primary-hover) !important; border: 1px solid var(--mud-palette-primary); }

    /* .reader-container moved to shared Configuration */
</style>

@code {
    [Parameter] public RssOverlayMode OverlayMode { get; set; }
    [Parameter] public EventCallback<RssOverlayMode> OverlayModeChanged { get; set; }

    private RssItem? _selectedItem = null;
    private bool _isArticleLoading = false;
    private bool _isReaderViewLoading = false;
    private bool _isReaderViewChanged = false;
    private bool _isMobile;
    private bool _isDarkMode;

    private int _currentPage = 1;
    private const int _pageSize = 10;
    private int _pageCount => RssService.Items != null ? (int)Math.Ceiling((double)RssService.Items.Count / _pageSize) : 0;

    protected override async Task OnInitializedAsync()
    {
        _isMobile = DeviceInfo.Idiom == DeviceIdiom.Phone;

        if (Application.Current != null)
        {
            _isDarkMode = Application.Current.RequestedTheme == AppTheme.Dark;
            Application.Current.RequestedThemeChanged += OnThemeChanged;
        }

        RssService.OnItemsUpdated += StateHasChanged;
        RssService.OnFeedChanged += OnFeedChanged;
        ArticleService.OnItemsChanged += OnArticleItemsChanged;
        NavService.OnArticleLinkChanged += OnArticleLinkChanged;
        NavService.OnBrowserStateChanged += OnBrowserStateChanged;
        NavService.OnReaderModeChanged += OnReaderModeChanged;
        RefreshService.DetailRefreshRequested += OnDetailRefresh;

        await ArticleService.InitializeAsync();

        // Check if we were navigated to with a specific item
        if (NavService.CurrentData is RssItem item)
        {
            await OpenItem(item);
        }
        else if (!string.IsNullOrEmpty(NavService.CurrentArticleLink))
        {
            // Restore state if we have a link but the component was re-initialized
            var existingItem = RssService.Items.FirstOrDefault(i => i.Link == NavService.CurrentArticleLink);
            if (existingItem != null)
            {
                await OpenItem(existingItem);
            }
        }
    }

    private void OnThemeChanged(object? sender, AppThemeChangedEventArgs e)
    {
        _isDarkMode = e.RequestedTheme == AppTheme.Dark;
        StateHasChanged();
    }

    public void Dispose()
    {
        if (Application.Current != null)
        {
            Application.Current.RequestedThemeChanged -= OnThemeChanged;
        }
        RssService.OnItemsUpdated -= StateHasChanged;
        RssService.OnFeedChanged -= OnFeedChanged;
        ArticleService.OnItemsChanged -= OnArticleItemsChanged;
        NavService.OnArticleLinkChanged -= OnArticleLinkChanged;
        NavService.OnBrowserStateChanged -= OnBrowserStateChanged;
        NavService.OnReaderModeChanged -= OnReaderModeChanged;
        RefreshService.DetailRefreshRequested -= OnDetailRefresh;
        _backButtonService.Unregister(OnBackNative);
    }

    private void OnArticleItemsChanged()
    {
        InvokeAsync(StateHasChanged);
    }
    
    private void OnFeedChanged()
    {
        _currentPage = 1;
        StateHasChanged();
    }
    
    private void OnPageChanged(int page)
    {
        _currentPage = page;
        StateHasChanged();
    }
    
    private void OnBrowserStateChanged(bool isOpen)
    {
        StateHasChanged();
    }

    private void OnReaderModeChanged(bool isEnabled)
    {
        StateHasChanged();
    }

    private async Task OnDetailRefresh()
    {
        await RssService.ReloadCurrentFeedAsync();
    }

    private void OnArticleLinkChanged()
    {
        // If the service says no article is open, but we have one open, close it.
        // This handles the "Back" button in the DetailPane header.
        if (NavService.CurrentArticleLink == null && _selectedItem != null)
        {
            _selectedItem = null;
            _isArticleLoading = false;
            _backButtonService.Unregister(OnBackNative);
            StateHasChanged();
        }
    }

    private async Task OpenItem(RssItem item)
    {
        _selectedItem = item;
        _isArticleLoading = true;
        _backButtonService.Register(OnBackNative);
        _isReaderViewChanged = false;
        NavService.SetCurrentArticle(item.Link, item.Title);
        StateHasChanged(); // Show initial content (Description)

        // Do NOT auto-fetch full content here. 
        // User requested explicit button.
        // If we want auto-fetch, uncomment below:
        /*
        var fullArticle = await RssService.FetchFullArticleAsync(item.Link);
        if (fullArticle != null && !string.IsNullOrEmpty(fullArticle.Content))
        {
            _selectedItem = fullArticle;
        }
        */

        _isArticleLoading = false;
        StateHasChanged();
    }

    private async Task OnReaderViewClicked()
    {
        if (_selectedItem == null || _isReaderViewLoading) return;

        _isReaderViewLoading = true;
        StateHasChanged();

        try
        {
            Console.WriteLine($"[RssFeedDetail] Fetching full article for: {_selectedItem.Link}");
            var fullArticle = await RssService.FetchFullArticleAsync(_selectedItem.Link);
            
            if (fullArticle != null && !string.IsNullOrEmpty(fullArticle.Content))
            {
                 Console.WriteLine($"[RssFeedDetail] Success. Content length: {fullArticle.Content.Length}");
                 _selectedItem = fullArticle;
                 _isReaderViewChanged = true;
                 Snackbar.Add("Full article loaded", Severity.Success);
            }
            else
            {
                 Console.WriteLine($"[RssFeedDetail] Fetch returned null or empty.");
                 Snackbar.Add("Could not load reader view", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[RssFeedDetail] Error: {ex}");
            Snackbar.Add($"Error loading reader view: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isReaderViewLoading = false;
            StateHasChanged();
        }
    }

    private void CloseItem()
    {
        _selectedItem = null;
        _isArticleLoading = false;
        _backButtonService.Unregister(OnBackNative);
        NavService.SetCurrentArticle(null, null);
        StateHasChanged();
    }

    private bool OnBackNative()
    {
        if (_selectedItem != null)
        {
            CloseItem();
            return true;
        }
        return false;
    }

    private void OnSwipe(SwipeDirection direction)
    {
        if (direction == SwipeDirection.LeftToRight && _selectedItem != null)
        {
            CloseItem();
        }
    }

    private string StripHtml(string input)
    {
        if (string.IsNullOrEmpty(input)) return string.Empty;
        // Simple strip for the preview list
        return System.Text.RegularExpressions.Regex.Replace(input, "<.*?>", String.Empty);
    }

    private async Task SelectPublication(FeedSource feed)
    {
        await OverlayModeChanged.InvokeAsync(RssOverlayMode.None);
        _currentPage = 1;
        RssService.SelectFeed(feed);
    }

    private void OpenSavedItem(LocalSavedArticle article)
    {
        var rssItem = new RssItem
        {
            Title = article.Title,
            Link = article.ArticleUrl,
            PublishDate = article.ArticleDate,
            ImageUrl = article.ImageUrl,
            Description = article.Description,
            Author = article.Author
        };
        _ = OpenItem(rssItem);
    }

    private async Task ToggleSave(RssItem item, SavedArticleType type)
    {
        var pubName = RssService.CurrentFeed?.Name ?? "Unknown";
        var pubIcon = RssService.CurrentFeed?.IconUrl;
        await ArticleService.ToggleArticleAsync(item, pubName, pubIcon, type);
    }

    private async Task RemoveSaved(string articleUrl, SavedArticleType type)
    {
        await ArticleService.RemoveArticleAsync(articleUrl, type);
    }

    private static string GetCategoryLabel(FeedCategory category) => category switch
    {
        FeedCategory.Local => "🇷🇴 Local",
        FeedCategory.Markets => "📈 Markets",
        FeedCategory.World => "🌍 World",
        FeedCategory.Tech => "💡 Tech",
        _ => category.ToString()
    };
}
