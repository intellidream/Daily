@using Daily.Models
@using Daily.Configuration
@using Daily.Services
@inject IRefreshService RefreshService
@inject ISettingsService SettingsService
@inject IAuthService AuthService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ISeederService SeederService
@inject Supabase.Client SupabaseClient
@implements IDisposable


<div class="d-flex flex-column" style="min-height: 100%; flex-grow: 1;">
    <MudGrid Spacing="4">
        <!-- Account Section -->
        <MudItem xs="12">
            <MudPaper Class="detail-tile rounded-xl pa-4" Elevation="3">
                <MudText Typo="Typo.h6" Class="mb-4 font-weight-bold">Account</MudText>
                <div class="d-flex align-center justify-space-between">
                    <div class="d-flex align-center gap-4" style="min-width: 0; flex: 1; overflow: hidden;">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                            @if (SettingsService.IsAuthenticated && !string.IsNullOrEmpty(SettingsService.CurrentUserAvatarUrl))
                            {
                                <MudImage Src="@SettingsService.CurrentUserAvatarUrl" />
                            }
                            else if (SettingsService.IsAuthenticated && !string.IsNullOrEmpty(SettingsService.CurrentUserEmail))
                            {
                                @SettingsService.CurrentUserEmail.Substring(0, 1).ToUpper()
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Person" />
                            }
                        </MudAvatar>
                        <div style="min-width: 0; flex: 1; display: flex; flex-direction: column;">
                            @if (SettingsService.IsAuthenticated)
                            {
                                <MudTooltip Text="@SettingsService.CurrentUserEmail">
                                    <MudText Typo="Typo.h6" Class="font-weight-bold" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @SettingsService.CurrentUserEmail
                                    </MudText>
                                </MudTooltip>
                                <div class="d-flex align-center gap-1">
                                     <MudIcon Icon="@Icons.Material.Filled.CloudDone" Size="Size.Small" Color="Color.Success" Style="flex-shrink: 0;" />
                                     <MudText Typo="Typo.body2" Style="opacity: 0.7; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">Synced to Cloud</MudText>
                                     <!-- ID Removed as requested -->
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Guest User</MudText>
                                 <div class="d-flex align-center gap-1">
                                     <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Small" Color="Color.Warning" Style="flex-shrink: 0;" />
                                     <MudText Typo="Typo.body2" Style="opacity: 0.7; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">Settings saved locally</MudText>
                                </div>
                            }
                        </div>
                    </div>

                    <div style="flex-shrink: 0;">
                        @if (SettingsService.IsAuthenticated)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@SignOut">Sign Out</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" 
                                       StartIcon="@Icons.Custom.Brands.Google" 
                                       Color="Color.Primary" 
                                       OnClick="@SignInWithGoogle"
                                       Disabled="_isAuthenticating">
                                 @if (_isAuthenticating)
                                 {
                                     <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                     <MudText Class="ms-2">Connecting...</MudText>
                                 }
                                 else
                                 {
                                     <MudText>Sign In</MudText>
                                 }
                            </MudButton>
                        }
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Weather Units Section -->
        <MudItem xs="12">
            <MudPaper Class="detail-tile rounded-xl pa-0" Elevation="3" Style="overflow: hidden;">
                <div class="pa-6 pb-2">
                     <MudText Typo="Typo.h6" Class="font-weight-bold">Units</MudText>
                </div>
                
                <!-- Temperature -->
                <div class="px-6 py-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Temperature</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Degrees Celsius or Fahrenheit</MudText>
                    </div>
                    <MudToggleGroup T="string" SelectionMode="SelectionMode.SingleSelection" @bind-Value="SettingsService.Settings.UnitSystem" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="border-solid" Style="border-color: rgba(255,255,255,0.1) !important;">
                        <MudToggleItem Value="@("metric")" Text="°C" />
                        <MudToggleItem Value="@("imperial")" Text="°F" />
                    </MudToggleGroup>
                </div>
                <MudDivider Style="opacity: 0.1;" />

                <!-- Wind -->
                <div class="px-6 py-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Wind Speed</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Measurement unit for wind</MudText>
                    </div>
                    <MudToggleGroup T="string" SelectionMode="SelectionMode.SingleSelection" @bind-Value="SettingsService.Settings.WindUnit" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="border-solid" Style="border-color: rgba(255,255,255,0.1) !important;">
                        <MudToggleItem Value="@("km/h")" Text="km/h" />
                        <MudToggleItem Value="@("m/s")" Text="m/s" />
                        <MudToggleItem Value="@("mph")" Text="mph" />
                    </MudToggleGroup>
                </div>
                <MudDivider Style="opacity: 0.1;" />

                <!-- Pressure -->
                <div class="px-6 py-4 d-flex justify-space-between align-center">
                     <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Pressure</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Atmospheric pressure</MudText>
                    </div>
                     <MudToggleGroup T="string" SelectionMode="SelectionMode.SingleSelection" @bind-Value="SettingsService.Settings.PressureUnit" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="border-solid" Style="border-color: rgba(255,255,255,0.1) !important;">
                        <MudToggleItem Value="@("hpa")" Text="hPa" />
                        <MudToggleItem Value="@("mmhg")" Text="mmHg" />
                        <MudToggleItem Value="@("inhg")" Text="inHg" />
                    </MudToggleGroup>
                </div>
                <MudDivider Style="opacity: 0.1;" />

                <!-- Visibility -->
                <div class="px-6 py-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Visibility</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Distance measurement</MudText>
                    </div>
                    <MudToggleGroup T="string" SelectionMode="SelectionMode.SingleSelection" @bind-Value="SettingsService.Settings.VisibilityUnit" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="border-solid" Style="border-color: rgba(255,255,255,0.1) !important;">
                        <MudToggleItem Value="@("km")" Text="km" />
                        <MudToggleItem Value="@("mi")" Text="mi" />
                    </MudToggleGroup>
                </div>
                <MudDivider Style="opacity: 0.1;" />

                <!-- Precipitation -->
                <div class="px-6 py-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Precipitation</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Rain and snow volume</MudText>
                    </div>
                    <MudToggleGroup T="string" SelectionMode="SelectionMode.SingleSelection" @bind-Value="SettingsService.Settings.PrecipitationUnit" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="border-solid" Style="border-color: rgba(255,255,255,0.1) !important;">
                        <MudToggleItem Value="@("mm")" Text="mm" />
                        <MudToggleItem Value="@("in")" Text="in" />
                    </MudToggleGroup>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Smartwatch Pairing Section -->
        @if (SettingsService.IsAuthenticated)
        {
            <MudItem xs="12">
                <MudPaper Class="detail-tile rounded-xl pa-0" Elevation="3" Style="overflow: hidden;">
                    <div class="pa-6 pb-4">
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Size="Size.Large" Style="background: linear-gradient(135deg, #FF6B6B, #FF8E53);">
                                <MudIcon Icon="@Icons.Material.Filled.Watch" Size="Size.Medium" Style="color: white;" />
                            </MudAvatar>
                            <div style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Smartwatch</MudText>
                                <MudText Typo="Typo.caption" Style="opacity: 0.6;">Pair your smartwatch to sync health &amp; habits</MudText>
                            </div>
                        </div>
                    </div>
                    <MudDivider Style="opacity: 0.1;" />

                    @* ── Paired Watches List ── *@
                    @if (_pairedWatches.Any())
                    {
                        @foreach (var watch in _pairedWatches)
                        {
                            <div class="px-6 py-4 d-flex align-center gap-4">
                                <MudIcon Icon="@GetPlatformIcon(watch.Platform)"
                                         Size="Size.Medium"
                                         Style="opacity: 0.7;" />
                                <div style="flex: 1; min-width: 0;">
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                        @(string.IsNullOrEmpty(watch.DeviceName) ? GetPlatformDisplayName(watch.Platform) : watch.DeviceName)
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">
                                        Paired @(watch.PairedAt?.ToString("MMM d, yyyy") ?? "recently")
                                        @if (watch.LastTokenPush.HasValue)
                                        {
                                            <text> · Last refreshed @(watch.LastTokenPush.Value.ToString("MMM d, h:mm tt"))</text>
                                        }
                                    </MudText>
                                </div>
                                <div class="d-flex gap-1" style="flex-shrink: 0;">
                                    <MudTooltip Text="Push fresh auth tokens to this watch">
                                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="_isRepairingId == watch.Id"
                                                       OnClick="@(() => RepairWatch(watch))" />
                                    </MudTooltip>
                                    @if (_unpairingWatchId == watch.Id)
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmUnpair(watch))" Class="mx-1">Confirm</MudButton>
                                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="@(() => _unpairingWatchId = null)">Cancel</MudButton>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="Unpair this watch">
                                            <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => _unpairingWatchId = watch.Id)" />
                                        </MudTooltip>
                                    }
                                </div>
                            </div>
                            <MudDivider Style="opacity: 0.06;" />
                        }
                    }

                    @* ── Pair New Watch ── *@
                    <div class="pa-6">
                        @if (!_showPairingInput)
                        {
                            <div class="d-flex flex-column flex-sm-row align-center gap-4" style="text-align: center;">
                                <MudIcon Icon="@Icons.Material.Outlined.PhonelinkSetup" Style="font-size: 2.5rem; opacity: 0.25;" />
                                <MudText Typo="Typo.body2" Style="opacity: 0.7; flex: 1;">
                                    Open <strong>Daily</strong> on your smartwatch, then enter the 6-digit pairing code shown on screen.
                                </MudText>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Link"
                                           OnClick="ShowPairingInput"
                                           Class="rounded-pill px-6"
                                           Style="flex-shrink: 0;">
                                    Pair Watch
                                </MudButton>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                <div class="d-flex flex-column flex-sm-row align-center gap-4">
                                    <MudTextField @ref="_pairingCodeField"
                                                  @bind-Value="_pairingCode"
                                                  Label="6-Digit Code"
                                                  Placeholder="000000"
                                                  Variant="Variant.Outlined"
                                                  MaxLength="6"
                                                  Immediate="true"
                                                  AutoFocus="true"
                                                  Margin="Margin.Dense"
                                                  Style="max-width: 220px; letter-spacing: 0.4em; font-size: 1.15rem; font-weight: 600;"
                                                  Class="flex-grow-1" />
                                    <MudToggleGroup T="string" Value="@_pairingPlatform" ValueChanged="@OnPlatformChanged" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="border-solid" Style="border-color: rgba(255,255,255,0.1) !important;">
                                        <MudToggleItem Value="@("watchos")" Text="Apple Watch" />
                                        <MudToggleItem Value="@("wearos")" Text="Wear OS" />
                                        <MudToggleItem Value="@("harmonyos")" Text="HarmonyOS" />
                                    </MudToggleGroup>
                                </div>
                                <div class="d-flex gap-2 justify-end">
                                    <MudButton Variant="Variant.Text"
                                               OnClick="@(() => { _showPairingInput = false; _pairingCode = string.Empty; StateHasChanged(); })">
                                        Cancel
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="PairWatch"
                                               Disabled="@(string.IsNullOrWhiteSpace(_pairingCode) || _pairingCode.Length != 6 || _isPairing)"
                                               Class="rounded-pill px-6">
                                        @if (_isPairing)
                                        {
                                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                            <MudText Class="ms-2">Pairing…</MudText>
                                        }
                                        else
                                        {
                                            <MudText>Connect</MudText>
                                        }
                                    </MudButton>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        }

        <!-- Notifications Section -->
        <MudItem xs="12">
            <MudPaper Class="detail-tile rounded-xl pa-0" Elevation="3" Style="overflow: hidden;">
                 <div class="pa-6 pb-2">
                     <MudText Typo="Typo.h6" Class="font-weight-bold">Notifications</MudText>
                </div>
                 <div class="px-6 py-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Daily Forecast</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Receive a daily summary at 8:00 AM</MudText>
                    </div>
                    <MudSwitch @bind-Value="SettingsService.Settings.DailyForecastAlert" Color="Color.Primary" />
                </div>
                <MudDivider Style="opacity: 0.1;" />
                 <div class="px-6 py-4 d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Precipitation Alerts</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Get notified when rain is expected</MudText>
                    </div>
                     <MudSwitch @bind-Value="SettingsService.Settings.PrecipitationAlert" Color="Color.Primary" />
                </div>
            </MudPaper>
        </MudItem>
        
        <!-- Global Save Action -->
        <MudItem xs="12">
            <div class="d-flex justify-end pb-4">
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           OnClick="SaveSettings" 
                           Disabled="_isSaving"
                           Class="px-8 py-2 elevation-4">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">Saving...</MudText>
                    }
                    else
                    {
                        <MudText>Save Preferences</MudText>
                    }
                </MudButton>
            </div>
        </MudItem>
    </MudGrid>


    <!-- About / System - Sticky Bottom -->
    <MudGrid Spacing="4" Class="mt-auto pb-4">
        <MudItem xs="12">
             <MudPaper Class="detail-tile rounded-xl pa-4" Elevation="3">
                 <div class="d-flex justify-space-between align-center">
                     <div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Daily Dashboard</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Version 1.0.0 (Build 2025.1)</MudText>
                     </div>
                     <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">Check for Updates</MudButton>
                 </div>
             </MudPaper>
        </MudItem>
        
        <!-- Debug Log Section (New) -->
        <MudItem xs="12">
             <MudPaper Class="detail-tile rounded-xl pa-4" Elevation="3">
                 <MudText Typo="Typo.h6" Class="mb-2 font-weight-bold">Diagnostics (Auth & Sync)</MudText>
                 <MudTextField T="string" 
                               Value="@(string.Join("\n", DebugLogger.Logs))" 
                               Label="Application Logs" 
                               Variant="Variant.Outlined" 
                               Lines="15" 
                               ReadOnly="true"
                               Style="font-family: monospace; font-size: 11px;" />
                 <div class="d-flex justify-end mt-2 gap-2">
                     <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="@(() => DebugLogger.Log("Test Log Entry " + DateTime.Now.ToLongTimeString()))">Test Log</MudButton>
                     <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => DebugLogger.Clear())">Clear</MudButton>
                 </div>
             </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@inject DebugLogger DebugLogger
@inject ISyncService SyncService
@inject IWindowManagerService WindowManagerService

@code {


    private bool _isSeeding = false;

    private async Task PopulateHistory()
    {
        _isSeeding = true;
        StateHasChanged();

        try 
        {
            Snackbar.Add("Seeding 3 Years of Data... (This may take a moment)", Severity.Info);
            // Use current user ID (Guest or Auth)
            string userId = SettingsService.CurrentUserId;
            await SeederService.SeedHistoryAsync(userId);
            
            Snackbar.Add("Seeding Complete! Check your charts.", Severity.Success);
        }
        catch(Exception ex)
        {
            Snackbar.Add($"Seeding Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSeeding = false;
            StateHasChanged();
        }
    }

    private bool _isSaving;

    private void OnSettingsChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SettingsService.OnSettingsChanged -= OnSettingsChanged;
        RefreshService.RefreshRequested -= OnRefreshRequested;
        if (DebugLogger != null)
        {
            DebugLogger.OnLogAdded -= OnLogUpdated;
        }
    }

    private void OnLogUpdated()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task OnRefreshRequested()
    {
        if (SettingsService.IsAuthenticated)
        {
            await LoadPairedWatches();
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await SettingsService.InitializeAsync();
        SettingsService.OnSettingsChanged += OnSettingsChanged;
        RefreshService.RefreshRequested += OnRefreshRequested;
        
        if (DebugLogger != null)
        {
            DebugLogger.OnLogAdded += OnLogUpdated;
        }

        if (SettingsService.IsAuthenticated)
        {
            await LoadPairedWatches();
        }
    }

    private async Task SaveSettings()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            await SettingsService.SaveSettingsAsync();
            Snackbar.Add("Settings saved", Severity.Success);
        }
        catch (Exception ex)
        {
             Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private bool _isAuthenticating;

    private async Task SignInWithGoogle()
    {
        _isAuthenticating = true;
        StateHasChanged();
        
        try
        {
            var success = await AuthService.SignInWithGoogleAsync();
            if (success)
            {
                Snackbar.Add("Welcome back!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Authentication cancelled or failed.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
             Snackbar.Add($"Auth Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAuthenticating = false;
            StateHasChanged();
        }
    }

    private async Task SignOut()
    {
        await AuthService.SignOutAsync();
        _showPairingInput = false;
        _pairingCode = string.Empty;
        Snackbar.Add("Signed out.", Severity.Info);
    }

    private bool _showPairingInput;
    private string _pairingCode = string.Empty;
    private string _pairingPlatform = "watchos";
    private bool _isPairing;
    private MudTextField<string> _pairingCodeField;
    private bool _focusPairingCode;
    private List<PairedWatch> _pairedWatches = new();
    private string? _isRepairingId;
    private string? _unpairingWatchId;

    private void ShowPairingInput()
    {
        _showPairingInput = true;
        _focusPairingCode = true;
    }

    private void OnPlatformChanged(string newValue)
    {
        _pairingPlatform = newValue;
        _focusPairingCode = true;
        StateHasChanged();
    }

    private static string GetPlatformIcon(string? platform) => platform switch
    {
        "watchos" => Icons.Custom.Brands.Apple,
        "wearos" => Icons.Custom.Brands.Google,
        "harmonyos" => Icons.Material.Filled.Watch,
        _ => Icons.Material.Filled.Devices
    };

    private static string GetPlatformDisplayName(string? platform) => platform switch
    {
        "watchos" => "Apple Watch",
        "wearos" => "Wear OS",
        "harmonyos" => "HarmonyOS Watch",
        _ => "Watch"
    };

    private async Task LoadPairedWatches()
    {
        try
        {
            var userId = SettingsService.CurrentUserId;
            if (string.IsNullOrEmpty(userId)) return;

            var response = await SupabaseClient.From<PairedWatch>()
                .Where(x => x.UserId == userId)
                .Where(x => x.IsActive == true)
                .Order("paired_at", Supabase.Postgrest.Constants.Ordering.Descending)
                .Get();

            _pairedWatches = response.Models;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Settings] Failed to load paired watches: {ex.Message}");
        }
    }

    private async Task ConfirmUnpair(PairedWatch watch)
    {
        try
        {
            watch.IsActive = false;
            await SupabaseClient.From<PairedWatch>().Update(watch);
            _pairedWatches.Remove(watch);
            Snackbar.Add("Watch unpaired.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to unpair: {ex.Message}", Severity.Error);
        }
        finally
        {
            _unpairingWatchId = null;
        }
    }

    private async Task RepairWatch(PairedWatch watch)
    {
        _isRepairingId = watch.Id;
        StateHasChanged();

        try
        {
            var currentSession = SupabaseClient.Auth.CurrentSession;
            if (currentSession == null || string.IsNullOrEmpty(currentSession.AccessToken))
            {
                Snackbar.Add("You must be logged in to refresh watch tokens.", Severity.Error);
                return;
            }

            watch.PendingAccessToken = currentSession.AccessToken;
            watch.PendingRefreshToken = currentSession.RefreshToken;
            watch.LastTokenPush = DateTime.UtcNow;
            await SupabaseClient.From<PairedWatch>().Update(watch);

            Snackbar.Add("Fresh tokens pushed! Open Daily on your watch to pick them up.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Repair failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRepairingId = null;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusPairingCode && _pairingCodeField is not null)
        {
            _focusPairingCode = false;
            await _pairingCodeField.FocusAsync();
        }
    }

    private async Task PairWatch()
    {
        _isPairing = true;
        StateHasChanged();

        try
        {
            var currentSession = SupabaseClient.Auth.CurrentSession;
            if (currentSession == null || string.IsNullOrEmpty(currentSession.AccessToken))
            {
                Snackbar.Add("You must be logged in to pair a Watch.", Severity.Error);
                return;
            }

            var existingResponse = await SupabaseClient.From<WatchPairing>()
                .Where(x => x.Code == _pairingCode)
                .Get();

            var existing = existingResponse.Models.FirstOrDefault();
            if (existing == null)
            {
                Snackbar.Add($"Pairing code '{_pairingCode}' not found. Did the watch disconnect?", Severity.Error);
                return;
            }

            existing.AccessToken = currentSession.AccessToken;
            existing.RefreshToken = currentSession.RefreshToken;

            var updateResponse = await SupabaseClient.From<WatchPairing>().Update(existing);

            if (updateResponse.Models == null || updateResponse.Models.Count == 0)
            {
                Snackbar.Add("Database rejected the token update! (0 rows affected)", Severity.Error);
                return;
            }

            // Polling to detect when the watch actually saves itself to the database
            for (int i = 0; i < 4; i++)
            {
                await Task.Delay(1500); // Wait 1.5s
                await LoadPairedWatches();
                
                // If a watch matching the platform just appeared in the last 2 minutes, assume success and stop polling
                if (_pairedWatches.Any(w => w.Platform == _pairingPlatform && w.PairedAt > DateTime.UtcNow.AddMinutes(-2)))
                {
                    break;
                }
            }

            var watchLabel = GetPlatformDisplayName(_pairingPlatform) + " watch";
            Snackbar.Add($"Watch paired successfully! Check your {watchLabel}.", Severity.Success);
            _showPairingInput = false;
            _pairingCode = string.Empty;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Pairing failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPairing = false;
            StateHasChanged();
        }
    }
}
