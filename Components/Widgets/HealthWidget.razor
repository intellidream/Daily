@using Daily.Models.Health
@using Daily.Services.Health
@using Daily.Services
@using Microsoft.AspNetCore.Components
@inject IHealthService HealthService
@inject IRefreshService RefreshService
@inject IWindowManagerService WindowManager

<div class="d-flex flex-column h-100 w-100 gap-2" style="min-height: 420px;">

    <!-- Header -->
    <div class="d-flex align-center mb-1 flex-shrink-0" style="gap: 2px;">
        <div class="flex-grow-1" style="min-width: 0;">
            <MudCarousel TData="object" ShowArrows="false" ShowBullets="false" AutoCycle="false" Style="height: 40px; width: 100%;" 
                         Class="flex-grow-1 rounded-pill mud-theme-primary">
                 <MudCarouselItem Transition="Transition.Slide">
                     <div class="d-flex align-center justify-center h-100 px-8" style="width: 100%;">
                         <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-2" Size="Size.Small" Style="color: white;" />
                         <MudText Typo="Typo.body1" Class="font-weight-bold" Style="color: white !important;">
                             Vitals
                         </MudText>
                         <div class="d-flex align-center gap-1 ml-auto">
                             <MudText Typo="Typo.caption" Style="color: white; opacity: 0.7;">Today</MudText>
                             <MudTooltip Text="@_sourceTooltip">
                                 <div style="@GetSourceDotStyle(_dominantSource)"></div>
                             </MudTooltip>
                         </div>
                     </div>
                 </MudCarouselItem>
            </MudCarousel>
        </div>
        @if (HeaderAction != null)
        {
             @HeaderAction
        }
    </div>

    <!-- Main Content -->
    <div class="d-flex flex-column gap-3 flex-grow-1 overflow-auto pa-1" style="scrollbar-width: none;">
        
        <!-- TOP ROW: Steps + Kcal + Heart Rate -->
        <div class="d-flex align-center justify-space-around px-2 py-2">
            @{ var stepsM = GetMetric(VitalType.Steps); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(stepsM?.SourceDevice); position: absolute; top: -2px; right: 4px;"></div>
                <MudIcon Icon="@Icons.Material.Filled.DirectionsWalk" Size="Size.Small" Style="opacity: 0.5;" Class="mb-1"/>
                <MudText Typo="Typo.h5" Class="font-weight-bold">@FormatNumber(stepsM?.Value ?? 0)</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 10px;">steps</MudText>
            </div>

            <MudDivider Vertical="true" FlexItem="true" Style="height: 40px;"/>

            @{ var calM = GetMetric(VitalType.ActiveEnergy); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(calM?.SourceDevice); position: absolute; top: -2px; right: 4px;"></div>
                <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" Size="Size.Small" Style="color: #FF9800;" Class="mb-1"/>
                <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color: #FF9800;">@FormatNumber(calM?.Value ?? 0)</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 10px;">kcal</MudText>
            </div>

            <MudDivider Vertical="true" FlexItem="true" Style="height: 40px;"/>

            @{ var hrM = GetMetric(VitalType.HeartRate); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(hrM?.SourceDevice); position: absolute; top: -2px; right: 4px;"></div>
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" Style="color: #F44336;" Class="mb-1"/>
                <MudText Typo="Typo.h5" Class="font-weight-bold">@(hrM?.Value > 0 ? hrM.Value.ToString("N0") : "--")</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 10px;">bpm</MudText>
            </div>
        </div>

        <!-- SLEEP SECTION -->
        <div class="rounded-lg pa-3" style="background: rgba(124, 77, 255, 0.06);">
            @{ var sleepM = GetMetric(VitalType.SleepDuration); }
            <div class="d-flex align-center justify-center gap-2 mb-2 relative">
                <div style="@GetSourceDotStyle(sleepM?.SourceDevice); position: absolute; top: 0; right: 0;"></div>
                <MudIcon Icon="@Icons.Material.Filled.Bedtime" Size="Size.Small" Style="color: #7C4DFF;"/>
                <MudText Typo="Typo.h6" Class="font-weight-bold">@FormatSleep(sleepM?.Value ?? 0)</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.5;">total</MudText>
            </div>
            <!-- Sleep Stages -->
            @{ var deepM = GetMetric(VitalType.SleepDeep); var lightM = GetMetric(VitalType.SleepLight); var remM = GetMetric(VitalType.SleepREM); var awakeM = GetMetric(VitalType.SleepAwake); }
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex flex-column align-center relative" style="flex: 1;">
                    <div style="@GetSourceDotStyle(deepM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                    <div style="width: 100%; height: 3px; border-radius: 2px; background: #3F51B5; margin-bottom: 4px;"></div>
                    <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.7;">DEEP</MudText>
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@(deepM?.Value > 0 ? FormatSleepShort(deepM.Value) : "--")</MudText>
                </div>
                <div class="d-flex flex-column align-center relative" style="flex: 1;">
                    <div style="@GetSourceDotStyle(lightM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                    <div style="width: 100%; height: 3px; border-radius: 2px; background: #7C4DFF; margin-bottom: 4px;"></div>
                    <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.7;">LIGHT</MudText>
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@(lightM?.Value > 0 ? FormatSleepShort(lightM.Value) : "--")</MudText>
                </div>
                <div class="d-flex flex-column align-center relative" style="flex: 1;">
                    <div style="@GetSourceDotStyle(remM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                    <div style="width: 100%; height: 3px; border-radius: 2px; background: #00BCD4; margin-bottom: 4px;"></div>
                    <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.7;">REM</MudText>
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@(remM?.Value > 0 ? FormatSleepShort(remM.Value) : "--")</MudText>
                </div>
                <div class="d-flex flex-column align-center relative" style="flex: 1;">
                    <div style="@GetSourceDotStyle(awakeM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                    <div style="width: 100%; height: 3px; border-radius: 2px; background: #FF9800; margin-bottom: 4px;"></div>
                    <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.7;">AWAKE</MudText>
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@(awakeM?.Value > 0 ? FormatSleepShort(awakeM.Value) : "--")</MudText>
                </div>
            </div>
        </div>

        <!-- VITALS GRID: HRV, RHR, RESP, SpO2 -->
        <div class="d-flex align-center justify-space-around px-2 py-2 rounded-lg" style="background: rgba(255,255,255,0.04);">
            @{ var hrvM = GetMetric(VitalType.HeartRateVariabilitySDNN) ?? GetMetric(VitalType.HeartRateVariabilityRMSSD); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(hrvM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">HRV</MudText>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@(hrvM?.Value > 0 ? hrvM.Value + " ms" : "--")</MudText>
            </div>

            <MudDivider Vertical="true" FlexItem="true" Style="height: 30px;"/>

            @{ var rhrM = GetMetric(VitalType.RestingHeartRate); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(rhrM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">RHR</MudText>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@(rhrM?.Value > 0 ? rhrM.Value + " bpm" : "--")</MudText>
            </div>

            <MudDivider Vertical="true" FlexItem="true" Style="height: 30px;"/>

            @{ var respM = GetMetric(VitalType.RespiratoryRate); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(respM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">RESP</MudText>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@(respM?.Value > 0 ? respM.Value + " br/m" : "--")</MudText>
            </div>

            <MudDivider Vertical="true" FlexItem="true" Style="height: 30px;"/>

            @{ var oxyM = GetMetric(VitalType.OxygenSaturation); }
            <div class="d-flex flex-column align-center relative" style="flex: 1;">
                <div style="@GetSourceDotStyle(oxyM?.SourceDevice); position: absolute; top: -2px; right: 0;"></div>
                <MudText Typo="Typo.caption" Style="font-size: 9px; opacity: 0.5;">SpO2</MudText>
                <MudText Typo="Typo.body2" Class="font-weight-bold">@(oxyM?.Value > 0 ? oxyM.Value + "%" : "--")</MudText>
            </div>
        </div>

    </div>
</div>

@implements IDisposable

@code {
    [Parameter] public RenderFragment HeaderAction { get; set; }

    private List<VitalMetric> _metrics = new();
    private string _dominantSource = "Mixed";
    private string _sourceTooltip = "Source: Multiple";

    protected override async Task OnInitializedAsync()
    {
        RefreshService.RefreshRequested += LoadDataInternal;
        await LoadDataInternal();
    }

    private async Task LoadDataInternal() => await LoadData();

    private async Task LoadData()
    {
        try 
        {
            await InvokeAsync(async () => 
            {
                _metrics = await HealthService.FetchMetricsAsync(DateTime.Now);

                var sourced = _metrics.Where(m => !string.IsNullOrEmpty(m.SourceDevice)).ToList();
                if (sourced.Any())
                {
                    int iosCount = sourced.Count(m => m.SourceDevice == "iOS");
                    int androidCount = sourced.Count(m => m.SourceDevice == "Health Connect" || m.SourceDevice == "Android");
                    int total = sourced.Count;
                    if (total > 0 && (double)iosCount / total >= 0.70) _dominantSource = "iOS";
                    else if (total > 0 && (double)androidCount / total >= 0.70) _dominantSource = "Health Connect";
                    else _dominantSource = "Mixed";
                    _sourceTooltip = $"iOS: {iosCount}, Android: {androidCount}";
                }

                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading health: {ex}");
        }
    }

    private VitalMetric GetMetric(VitalType type)
    {
        var m = _metrics.FirstOrDefault(x => x.TypeString == type.ToString());
        return m?.Value > 0 ? m : null;
    }

    private string FormatNumber(double val)
    {
        if (val >= 1000) return (val / 1000.0).ToString("N1") + "k";
        return val > 0 ? val.ToString("N0") : "--";
    }

    private string FormatSleep(double minutes)
    {
        if (minutes <= 0) return "--";
        var ts = TimeSpan.FromMinutes(minutes);
        return $"{ts.Hours}h {ts.Minutes}m";
    }

    private string FormatSleepShort(double minutes)
    {
        if (minutes <= 0) return "--";
        if (minutes < 60) return $"{(int)minutes}m";
        var ts = TimeSpan.FromMinutes(minutes);
        return $"{ts.Hours}h{ts.Minutes}m";
    }

    private string GetSourceDotStyle(string source)
    {
        string color = "transparent";
        if (source == "iOS") color = "#2979FF";
        else if (source == "Health Connect" || source == "Android") color = "#00E676";
        
        return $"width: 6px; height: 6px; border-radius: 50%; background-color: {color}; display: inline-block;";
    }

    public void Dispose()
    {
        RefreshService.RefreshRequested -= LoadDataInternal;
    }
}
