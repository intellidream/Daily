@using MudBlazor
@using Daily.Models
@using Daily.Services
@inject IRssFeedService RssService
@inject IRssArticleService ArticleService
@inject IRefreshService RefreshService
@inject IWindowManagerService WindowManager
@inject IJSRuntime JSRuntime
@inject ISmartAgentService SmartAgent

<div class="d-flex align-center my-2 flex-grow-1" style="width: 100%; gap: 2px;">
    <div class="flex-grow-1" style="min-width: 0;">
        @if (_overlayMode == RssOverlayMode.Publications)
        {
            <div class="d-flex align-center justify-center rounded-pill mud-theme-primary px-4" style="height: 40px; width: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Newspaper" Size="Size.Small" Style="color: white;" Class="mr-2" />
                <MudText Typo="Typo.caption" Class="font-weight-bold" Style="font-size: 1.1em; color: white;">
                    News
                </MudText>
            </div>
        }
        else if (_overlayMode == RssOverlayMode.ReadLater)
        {
            <div class="d-flex align-center justify-center rounded-pill mud-theme-primary px-4" style="height: 40px; width: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.BookmarkBorder" Size="Size.Small" Style="color: white;" Class="mr-2" />
                <MudText Typo="Typo.caption" Class="font-weight-bold" Style="font-size: 1.1em; color: white;">
                    Later (@ArticleService.ReadLaterItems.Count)
                </MudText>
            </div>
        }
        else if (_overlayMode == RssOverlayMode.Favorites)
        {
            <div class="d-flex align-center justify-center rounded-pill mud-theme-primary px-4" style="height: 40px; width: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color: white;" Class="mr-2" />
                <MudText Typo="Typo.caption" Class="font-weight-bold" Style="font-size: 1.1em; color: white;">
                    Favs (@ArticleService.FavoriteItems.Count)
                </MudText>
            </div>
        }
        else
        {
            <MudCarousel TData="object" ShowArrows="true" ShowBullets="false" AutoCycle="false" Style="height: 40px; width: 100%;" 
                         SelectedIndex="@_selectedFeedIndex" SelectedIndexChanged="@OnCarouselIndexChanged" 
                         Class="flex-grow-1 rounded-pill mud-theme-primary">
                @foreach (var feed in RssService.Feeds)
                {
                    <MudCarouselItem Transition="Transition.Slide">
                        <div class="d-flex align-center justify-center h-100 px-8" style="width: 100%;">
                            @if (!string.IsNullOrEmpty(feed.IconUrl))
                            {
                                <MudImage Src="@feed.IconUrl" Width="20" Height="20" Class="mr-3 flex-shrink-0" ObjectFit="ObjectFit.Contain" />
                            }
                            <div style="min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;" class="mr-3 flex-shrink-1 text-center">
                                <MudText Typo="Typo.caption" Class="font-weight-bold" Style="font-size: 1.1em; color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @feed.Name
                                </MudText>
                            </div>
                            <div @onclick="@(async () => await ForceRefreshFeed(feed))" @onclick:stopPropagation class="d-flex align-center justify-center rounded-circle hover-darken cursor-pointer pa-1 flex-shrink-0 ml-2">
                                 <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Title="Refresh" Style="color: white;" />
                            </div>
                        </div>
                    </MudCarouselItem>
                }
            </MudCarousel>
        }
    </div>

    <div class="flex-shrink-0 d-flex align-center">
        @if (_overlayMode != RssOverlayMode.None)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Medium" OnClick="@(() => SetOverlayMode(RssOverlayMode.None))" Color="Color.Error" Title="Close" />
        }
        else
        {
            <MudIconButton Icon="@(_showRssMenu ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.MoreVert)" 
                           Size="Size.Medium" Color="Color.Primary" OnClick="@(() => _showRssMenu = !_showRssMenu)" Title="Browse" />
        }
        @if (HeaderAction != null)
        {
            @HeaderAction
        }
    </div>
</div>

@if (_showRssMenu)
{
    <div class="d-flex gap-1 px-1 pb-1 flex-wrap justify-center">
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Newspaper" Color="Color.Primary"
                   OnClick="@(() => { _showRssMenu = false; SetOverlayMode(RssOverlayMode.Publications); })" Style="text-transform: none; font-size: 0.75rem;">
            News
        </MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.BookmarkBorder" Color="Color.Error"
                   OnClick="@(() => { _showRssMenu = false; SetOverlayMode(RssOverlayMode.ReadLater); })" Style="text-transform: none; font-size: 0.75rem;">
            Later (@ArticleService.ReadLaterItems.Count)
        </MudButton>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Star" Color="Color.Warning"
                   OnClick="@(() => { _showRssMenu = false; SetOverlayMode(RssOverlayMode.Favorites); })" Style="text-transform: none; font-size: 0.75rem;">
            Favs (@ArticleService.FavoriteItems.Count)
        </MudButton>
    </div>
}

<div style="height: 460px; overflow: hidden; display: flex; flex-direction: column;">

    @if (_overlayMode == RssOverlayMode.Publications)
    {
        <div style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;" class="pb-3">
            @foreach (var category in Enum.GetValues<FeedCategory>())
            {
                var feedsInCategory = RssService.Feeds.Where(f => f.Category == category).ToList();
                if (feedsInCategory.Any())
                {
                    <MudText Typo="Typo.overline" Class="px-2 pt-3 pb-1" Style="opacity: 0.6; font-weight: 700; letter-spacing: 0.1em;">
                        @GetCategoryLabel(category)
                    </MudText>
                    <MudDivider Class="mx-2 mb-1" />
                    @foreach (var feed in feedsInCategory)
                    {
                        var isSelected = RssService.CurrentFeed == feed;
                        <div class="d-flex align-center gap-3 px-3 py-2 cursor-pointer publication-item @(isSelected ? "publication-selected" : "")"
                             @onclick="@(() => SelectPublication(feed))">
                            @if (!string.IsNullOrEmpty(feed.IconUrl))
                            {
                                <MudImage Src="@feed.IconUrl" Width="24" Height="24" ObjectFit="ObjectFit.Contain" Class="rounded flex-shrink-0" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.RssFeed" Size="Size.Small" Class="flex-shrink-0" />
                            }
                            <MudText Typo="Typo.body2" Style="@(isSelected ? "font-weight: 700;" : "")">@feed.Name</MudText>
                            @if (isSelected)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Primary" Class="ml-auto" />
                            }
                        </div>
                    }
                }
            }
        </div>
    }
    else if (_overlayMode == RssOverlayMode.ReadLater)
    {
        <div style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;" class="pb-3">
            @if (!ArticleService.ReadLaterItems.Any())
            {
                <div class="d-flex justify-center align-center" style="height: 100%;">
                    <MudText Color="Color.Secondary">No articles saved for later.</MudText>
                </div>
            }
            else
            {
                @foreach (var dateGroup in ArticleService.ReadLaterItems.GroupBy(a => a.CreatedAt.ToLocalTime().Date).OrderByDescending(g => g.Key))
                {
                    <MudText Typo="Typo.overline" Class="px-2 pt-3 pb-1" Style="opacity: 0.6; font-weight: 700; letter-spacing: 0.1em;">
                        @dateGroup.Key.ToString("D")
                    </MudText>
                    <MudDivider Class="mx-2 mb-1" />
                    @foreach (var article in dateGroup)
                    {
                        <MudListItem OnClick="@(() => OpenSavedItem(article))" Style="height: 80px; overflow: hidden;" Class="px-0 py-2" T="string">
                            <div class="d-flex align-center gap-4" style="height: 100%; width: 100%;">
                                @if (!string.IsNullOrEmpty(article.PublicationIconUrl))
                                {
                                    <div class="rounded-lg flex-shrink-0 d-flex justify-center align-center" style="width: 60px; height: 40px; background-color: var(--mud-palette-action-disabled-background);">
                                        <MudImage Src="@article.PublicationIconUrl" Width="40" Height="40" ObjectFit="ObjectFit.Contain" />
                                    </div>
                                }
                                else
                                {
                                    <div class="rounded-lg flex-shrink-0 d-flex justify-center align-center" style="width: 60px; height: 40px; background-color: var(--mud-palette-action-disabled-background);">
                                        <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Medium" />
                                    </div>
                                }
                                <div style="min-width: 0; flex: 1;">
                                    <MudText Typo="Typo.body2" Style="line-height: 1.2; max-height: 2.4em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@article.Title</MudText>
                                    <MudText Typo="Typo.caption" Style="font-size: 0.7rem; opacity: 0.8;" Class="mt-0">@article.PublicationName</MudText>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.BookmarkRemove" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(async () => await RemoveSaved(article.ArticleUrl, SavedArticleType.ReadLater))"
                                               OnClick:stopPropagation="true" Title="Remove" />
                            </div>
                        </MudListItem>
                    }
                }
            }
        </div>
    }
    else if (_overlayMode == RssOverlayMode.Favorites)
    {
        <div style="flex-grow: 1; overflow-y: auto; overflow-x: hidden;" class="pb-3">
            @if (!ArticleService.FavoriteItems.Any())
            {
                <div class="d-flex justify-center align-center" style="height: 100%;">
                    <MudText Color="Color.Secondary">No favorite articles yet.</MudText>
                </div>
            }
            else
            {
                @foreach (var pubGroup in ArticleService.FavoriteItems.GroupBy(a => a.PublicationName).OrderBy(g => g.Key))
                {
                    <MudText Typo="Typo.overline" Class="px-2 pt-3 pb-1" Style="opacity: 0.6; font-weight: 700; letter-spacing: 0.1em;">
                        @pubGroup.Key
                    </MudText>
                    <MudDivider Class="mx-2 mb-1" />
                    @foreach (var article in pubGroup.OrderByDescending(a => a.ArticleDate))
                    {
                        <MudListItem OnClick="@(() => OpenSavedItem(article))" Style="height: 80px; overflow: hidden;" Class="px-0 py-2" T="string">
                            <div class="d-flex align-center gap-4" style="height: 100%; width: 100%;">
                                @if (!string.IsNullOrEmpty(article.ImageUrl))
                                {
                                    <MudImage Src="@article.ImageUrl" Width="60" Height="40" ObjectFit="ObjectFit.Cover" Class="rounded-lg flex-shrink-0" />
                                }
                                else
                                {
                                    <div class="rounded-lg flex-shrink-0 d-flex justify-center align-center" style="width: 60px; height: 40px; background-color: var(--mud-palette-action-disabled-background);">
                                        <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Medium" />
                                    </div>
                                }
                                <div style="min-width: 0; flex: 1;">
                                    <MudText Typo="Typo.body2" Style="line-height: 1.2; max-height: 2.4em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@article.Title</MudText>
                                    <MudText Typo="Typo.caption" Style="font-size: 0.7rem; opacity: 0.8;" Class="mt-0">@article.ArticleDate.ToShortDateString()</MudText>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.StarBorder" Size="Size.Small" Color="Color.Warning"
                                               OnClick="@(async () => await RemoveSaved(article.ArticleUrl, SavedArticleType.Favorite))"
                                               OnClick:stopPropagation="true" Title="Remove from favorites" />
                            </div>
                        </MudListItem>
                    }
                }
            }
        </div>
    }
    else if (RssService.IsLoading)
    {
        <div class="d-flex justify-center align-center" style="height: 100%; width: 100%;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            <MudText Class="ml-2">Loading news...</MudText>
        </div>
    }
    else if (RssService.Error != null)
    {
        <MudAlert Severity="Severity.Error" Class="ma-2">@RssService.Error</MudAlert>
    }
    else if (RssService.Items != null && RssService.Items.Any())
    {
        <MudList T="RssItem" Clickable="true" Dense="true" DisablePadding="true" Style="flex-grow: 1; overflow-y: auto;">
            @foreach (var item in RssService.Items.Skip((_currentPage - 1) * _pageSize).Take(_pageSize))
            {
               // ... (existing list item) ...
               <MudListItem OnClick="@(() => OpenItem(item))" Style="height: 80px; overflow: hidden;" Class="px-0 py-2">
                     <div class="d-flex align-center gap-4" style="height: 100%; width: 100%;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <MudImage Src="@item.ImageUrl" Width="60" Height="40" ObjectFit="ObjectFit.Cover" Class="rounded-lg flex-shrink-0" />
                        }
                        else if (!string.IsNullOrEmpty(RssService.CurrentFeed?.IconUrl))
                        {
                             <div class="rounded-lg flex-shrink-0 d-flex justify-center align-center" style="width: 60px; height: 40px; background-color: var(--mud-palette-action-disabled-background);">
                                <MudImage Src="@RssService.CurrentFeed.IconUrl" Width="40" Height="40" ObjectFit="ObjectFit.Contain" />
                             </div>
                        }
                        else
                        {
                            <div class="rounded-lg flex-shrink-0 d-flex justify-center align-center" style="width: 60px; height: 40px; background-color: var(--mud-palette-action-disabled-background);">
                                <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Medium" />
                            </div>
                        }
                        <div style="min-width: 0; flex: 1;">
                            <div title="@item.Title" style="width: 100%; cursor: help;">
                                 <MudText Typo="Typo.body2" Style="line-height: 1.2; max-height: 2.4em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@item.Title</MudText>
                            </div>
                            <MudText Typo="Typo.caption" Style="font-size: 0.7rem; opacity: 0.8;" Class="mt-0">@item.PublishDate.ToShortDateString()</MudText>
                        </div>
                        <div class="d-flex flex-column flex-shrink-0" style="gap: 0;">
                            <MudIconButton Icon="@(ArticleService.IsSaved(item.Link, SavedArticleType.ReadLater) ? Icons.Material.Filled.Bookmark : Icons.Material.Filled.BookmarkBorder)" 
                                           Size="Size.Small" Color="@(ArticleService.IsSaved(item.Link, SavedArticleType.ReadLater) ? Color.Error : Color.Default)"
                                           OnClick="@(async () => await ToggleSave(item, SavedArticleType.ReadLater))" OnClick:stopPropagation="true"
                                           Title="Read Later" Style="padding: 2px;" />
                            <MudIconButton Icon="@(ArticleService.IsSaved(item.Link, SavedArticleType.Favorite) ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" 
                                           Size="Size.Small" Color="@(ArticleService.IsSaved(item.Link, SavedArticleType.Favorite) ? Color.Warning : Color.Default)"
                                           OnClick="@(async () => await ToggleSave(item, SavedArticleType.Favorite))" OnClick:stopPropagation="true"
                                           Title="Favorite" Style="padding: 2px;" />
                        </div>
                    </div>
                </MudListItem>
            }
        </MudList>

        @if (RssService.Items.Count > _pageSize)
        {
            <div class="d-flex justify-center mt-2 flex-shrink-0">
                 <MudPagination BoundaryCount="1" MiddleCount="1" Count="@_pageCount" SelectedChanged="OnPageChanged" Selected="@_currentPage" 
                                Class="pa-2" Variant="Variant.Outlined" Size="Size.Small" ShowFirstButton="false" ShowLastButton="false" />
            </div>
        }
    }
    else
    {
         <div class="d-flex justify-center align-center" style="height: 100%;">
             <MudText Color="Color.Secondary">No news items found.</MudText>
         </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? HeaderAction { get; set; }

    private int _currentPage = 1;
    private const int _pageSize = 5;
    private RssOverlayMode _overlayMode = RssOverlayMode.None;
    private bool _showRssMenu = false;

    private int _pageCount => RssService.Items != null ? (int)Math.Ceiling((double)RssService.Items.Count / _pageSize) : 0;

    private int _selectedFeedIndex = 0;

    // Helper to sync carousel with service state
    private void SyncIndexFromService()
    {
        if (RssService.CurrentFeed != null)
        {
            var index = RssService.Feeds.IndexOf(RssService.CurrentFeed);
            if (index >= 0 && index != _selectedFeedIndex)
            {
                _selectedFeedIndex = index;
                StateHasChanged();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        RssService.OnItemsUpdated += OnItemsUpdatedHandler;
        RssService.OnFeedChanged += OnFeedChanged;
        ArticleService.OnItemsChanged += OnArticleItemsChanged;
        RefreshService.RefreshRequested += OnRefreshRequested;

        await ArticleService.InitializeAsync();

        // Initial sync
        SyncIndexFromService();

        // If service is empty (first load), trigger load
        // GUARD: Do not auto-reload if already loading OR if in error state (prevents infinite retry loop)
        if (RssService.Items.Count == 0 && RssService.CurrentFeed != null && !RssService.IsLoading && string.IsNullOrEmpty(RssService.Error))
        {
             await RssService.ReloadCurrentFeedAsync();
        }

    }

    public void Dispose()
    {
        RssService.OnItemsUpdated -= OnItemsUpdatedHandler;
        RssService.OnFeedChanged -= OnFeedChanged;
        ArticleService.OnItemsChanged -= OnArticleItemsChanged;
        RefreshService.RefreshRequested -= OnRefreshRequested;
    }

    private async void OnItemsUpdatedHandler()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnArticleItemsChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnFeedChanged()
    {
        _currentPage = 1;
        SyncIndexFromService();
        await InvokeAsync(StateHasChanged);
    }

    private void OnCarouselIndexChanged(int index)
    {
        _selectedFeedIndex = index;
        if (index >= 0 && index < RssService.Feeds.Count)
        {
            var feed = RssService.Feeds[index];
            if (RssService.CurrentFeed != feed)
            {
                RssService.SelectFeed(feed);
            }
        }
    }

    private void OnPageChanged(int page)
    {
        _currentPage = page;
        StateHasChanged();
    }

    private async Task ForceRefreshFeed(FeedSource feed)
    {
        RssService.SelectFeed(feed);
        await RssService.LoadFeedAsync(feed, true);
    }

    private async Task OnRefreshRequested()
    {
        await RssService.ReloadCurrentFeedAsync();
    }

    private void OpenItem(RssItem item)
    {
        WindowManager.OpenDetail("RssFeed", item.Title, item);
        _ = SmartAgent.RecordEventAsync("RssFeedWidget", "read_article");
    }

    private void OpenSavedItem(LocalSavedArticle article)
    {
        var rssItem = new RssItem
        {
            Title = article.Title,
            Link = article.ArticleUrl,
            PublishDate = article.ArticleDate,
            ImageUrl = article.ImageUrl,
            Description = article.Description,
            Author = article.Author
        };
        WindowManager.OpenDetail("RssFeed", rssItem.Title, rssItem);
        _ = SmartAgent.RecordEventAsync("RssFeedWidget", "read_saved_article");
    }

    private void SetOverlayMode(RssOverlayMode mode)
    {
        _overlayMode = mode;
        _showRssMenu = false;
        StateHasChanged();
    }

    private void SelectPublication(FeedSource feed)
    {
        _overlayMode = RssOverlayMode.None;
        _currentPage = 1;
        var index = RssService.Feeds.IndexOf(feed);
        if (index >= 0)
        {
            _selectedFeedIndex = index;
        }
        RssService.SelectFeed(feed);
    }

    private async Task ToggleSave(RssItem item, SavedArticleType type)
    {
        var pubName = RssService.CurrentFeed?.Name ?? "Unknown";
        var pubIcon = RssService.CurrentFeed?.IconUrl;
        await ArticleService.ToggleArticleAsync(item, pubName, pubIcon, type);
    }

    private async Task RemoveSaved(string articleUrl, SavedArticleType type)
    {
        await ArticleService.RemoveArticleAsync(articleUrl, type);
    }

    private static string GetCategoryLabel(FeedCategory category) => category switch
    {
        FeedCategory.Local => "🇷🇴 Local",
        FeedCategory.Markets => "📈 Markets",
        FeedCategory.World => "🌍 World",
        FeedCategory.Tech => "💡 Tech",
        _ => category.ToString()
    };
}

<style>
    .rss-chip {
        border: none;
        color: var(--mud-palette-text-primary);
        background-color: rgba(0,0,0,0.08);
        transition: all 0.3s ease;
    }
    .rss-chip.selected {
        background-color: var(--mud-palette-primary) !important;
        color: var(--mud-palette-primary-text) !important;
    }
    
    .rss-chip:hover {
        opacity: 0.8;
    }

    body[data-theme='dark'] .rss-chip {
        background-color: var(--mud-palette-action-disabled-background);
    }

    .publication-item {
        border-radius: 8px;
        transition: background-color 0.15s ease;
    }

    .publication-item:hover {
        background-color: var(--mud-palette-action-default-hover);
    }

    .publication-selected {
        background-color: var(--mud-palette-primary-hover);
    }
</style>
