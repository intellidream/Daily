<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Daily_WinUI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DayOne – Settings"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- SVG Background - spans titlebar + content -->
        <Image Source="{ThemeResource AppBackgroundSource}" Stretch="UniformToFill" IsHitTestVisible="False" Grid.RowSpan="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

        <TitleBar x:Name="AppTitleBar" Title="Settings">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
