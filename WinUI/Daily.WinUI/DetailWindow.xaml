<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Daily_WinUI.DetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Daily_WinUI"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DayOne"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- SVG Background -->
        <Image Source="{ThemeResource AppBackgroundSource}" Stretch="UniformToFill" IsHitTestVisible="False" Grid.RowSpan="2" />

        <TitleBar x:Name="AppTitleBar" Title="DayOne">
            <TitleBar.IconSource>
                <BitmapIconSource UriSource="Assets/Square44x44Logo.targetsize-32_altform-unplated.png" ShowAsMonochrome="False" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
