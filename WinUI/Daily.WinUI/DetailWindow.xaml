<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Daily_WinUI.DetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Daily_WinUI"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DayOne"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- SVG Background - wavy gradient pattern -->
        <Image Source="{ThemeResource AppBackgroundSource}" Stretch="UniformToFill" IsHitTestVisible="False" Grid.RowSpan="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

        <!-- Custom TitleBar area to mirror main window behavior -->
        <Grid x:Name="AppTitleBar" Background="Transparent" VerticalAlignment="Top" Height="32" SizeChanged="AppTitleBar_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightPaddingColumn" Width="140" />
            </Grid.ColumnDefinitions>

            <Button x:Name="DetailTitleBarRefreshButton"
                    Grid.Column="0"
                    Height="32"
                    Background="Transparent" BorderThickness="0"
                    CornerRadius="0" Padding="14,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Click="DetailTitleBarRefreshButton_Click"
                    ToolTipService.ToolTip="Refresh section">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon x:Name="DetailTitleBarSectionIcon"
                              Glyph="&#xE706;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="14"
                              Foreground="{ThemeResource AppFgColorBrush}" />
                    <TextBlock x:Name="DetailTitleBarSectionText"
                               Text="DayOne - Detail"
                               FontSize="12"
                               Foreground="{ThemeResource AppFgColorBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
