<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Daily_WinUI.DetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Daily_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Daily Detail"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Daily Detail">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- Top-bar artwork: declared after Frame so it overlays the top 110px, matching MainPage -->
        <Image Source="Assets/apptopbar.png"
               Grid.Row="1"
               VerticalAlignment="Top" HorizontalAlignment="Stretch"
               Height="110" Stretch="Fill"
               Opacity="0.20" IsHitTestVisible="False"/>
    </Grid>
</Window>
