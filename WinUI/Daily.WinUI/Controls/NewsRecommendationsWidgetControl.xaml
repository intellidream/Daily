<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Daily_WinUI.Controls.NewsRecommendationsWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Daily_WinUI.Controls"
    mc:Ignorable="d"
    d:DesignHeight="220" d:DesignWidth="360"
    Loaded="UserControl_Loaded">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <FontIcon Glyph="&#xE7C3;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#FF00E5FF"/>
            <TextBlock Text="AI News Recommendations" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}"/>
        </StackPanel>

        <!-- Loading / Content Area -->
        <Grid Grid.Row="1">
            <ProgressRing x:Name="LoadingRing" IsActive="True" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF00E5FF"/>
            
            <TextBlock x:Name="NoDataText" Text="No recommendations available right now." FontSize="12" Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="{ThemeResource AppFgColorBrush}"/>

            <StackPanel x:Name="ContentPanel" Spacing="12" Visibility="Collapsed" VerticalAlignment="Center">
                <!-- Rec 1 -->
                <local:HandCursorGrid x:Name="Rec1Grid" Background="Transparent" PointerEntered="RecGrid_PointerEntered" PointerExited="RecGrid_PointerExited" Tapped="RecGrid_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="Rec1Title" Text="Loading recommended article..." FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1" Foreground="{ThemeResource AppFgColorBrush}"/>
                        <TextBlock x:Name="Rec1Reason" Text="..." FontSize="11" Opacity="0.6" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="Rec1Source" Grid.Column="1" Text="..." FontSize="11" FontWeight="Bold" Opacity="0.8" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </local:HandCursorGrid>

                <!-- Divider -->
                <Border Height="0.5" Background="{ThemeResource AppGlassBorderColorBrush}" Opacity="0.5"/>

                <!-- Rec 2 -->
                <local:HandCursorGrid x:Name="Rec2Grid" Background="Transparent" PointerEntered="RecGrid_PointerEntered" PointerExited="RecGrid_PointerExited" Tapped="RecGrid_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="Rec2Title" Text="Loading recommended article..." FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1" Foreground="{ThemeResource AppFgColorBrush}"/>
                        <TextBlock x:Name="Rec2Reason" Text="..." FontSize="11" Opacity="0.6" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="Rec2Source" Grid.Column="1" Text="..." FontSize="11" FontWeight="Bold" Opacity="0.8" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </local:HandCursorGrid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
