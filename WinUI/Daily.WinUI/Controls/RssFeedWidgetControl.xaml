<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Daily_WinUI.Controls.RssFeedWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="16,16,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <FontIcon Glyph="&#xE736;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="News" FontSize="16" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
            
            <!-- Feed Selector -->
            <ComboBox Grid.Column="2" x:Name="FeedComboBox" 
                      Width="160" Height="36" 
                      DisplayMemberPath="Name"
                      SelectionChanged="FeedComboBox_SelectionChanged"
                      Background="Transparent"
                      BorderThickness="0"/>

            <!-- Refresh Button -->
            <Button Grid.Column="3" 
                    Margin="8,0,0,0"
                    Background="Transparent" BorderThickness="0"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh Feed">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <!-- Loading State -->
            <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32"/>
                <TextBlock Text="Fetching news..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <!-- List of Articles -->
            <ListView x:Name="ArticlesListView" 
                      SelectionMode="None"
                      ShowsScrollingPlaceholders="False"
                      Visibility="Collapsed"
                      Padding="16,0,16,16"
                      IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ListViewItemPresenter 
                                        ContentMargin="0"
                                        PointerOverBackground="Transparent"
                                        SelectedBackground="Transparent"
                                        PressedBackground="Transparent"
                                        SelectedPointerOverBackground="Transparent"
                                        SelectedPressedBackground="Transparent"
                                        FocusBorderBrush="Transparent"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,12"
                                Padding="12"
                                HorizontalAlignment="Stretch"
                                Tapped="Article_Tapped">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Article Thumbnail -->
                                <Border Width="80" Height="80" CornerRadius="6" Background="{ThemeResource ControlFillColorDisabledBrush}">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <!-- Title -->
                                    <TextBlock Text="{Binding Title}" 
                                               FontSize="15" 
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" 
                                               MaxLines="2" 
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- Meta Info -->
                                    <TextBlock Text="{Binding PublishDate}" 
                                               FontSize="12" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
