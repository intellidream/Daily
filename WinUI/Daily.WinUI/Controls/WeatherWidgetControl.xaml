<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Daily_WinUI.Controls.WeatherWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="200" d:DesignWidth="400"
    Background="Transparent">

    <!-- Make the control fill the Border and be transparent to ensure it doesn't block tap if needed,
         or just let the Grid handle layout. Background="Transparent" makes sure it is hit-testable if needed -->
    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Top Section: Location -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
            <TextBlock x:Name="LocationText" Text="Loading..." FontSize="16" FontWeight="SemiBold" Opacity="0.9" />
            <FontIcon Glyph="&#xE707;" FontFamily="Segoe Fluent Icons" FontSize="14" Opacity="0.7" VerticalAlignment="Center" Margin="0,2,0,0"/> <!-- Map pin / NearMe icon -->
        </StackPanel>

        <!-- Middle Section: Temps and Icon -->
        <Grid Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock x:Name="TempText" Text="--" FontSize="64" FontWeight="Bold" FontFamily="Segoe UI Variable Display" LineHeight="64" />
                
                <Border BorderBrush="#33FFFFFF" BorderThickness="2,0,0,0" Padding="14,0,0,0" Margin="0,4,0,4">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="FEELS LIKE" FontSize="11" FontWeight="Bold" Opacity="0.6" CharacterSpacing="50" />
                        <TextBlock x:Name="FeelsLikeText" Text="--°" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Image Grid.Column="1" x:Name="ConditionIcon" Width="80" Height="80" VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Bottom Section: Description and High/Low -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" VerticalAlignment="Bottom">
            <TextBlock x:Name="DescText" Text="--" FontSize="18" FontWeight="SemiBold" Opacity="0.9" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="200" />
            <TextBlock x:Name="HighLowText" Text="H: --° · L: --°" FontSize="14" FontWeight="Medium" Opacity="0.7" VerticalAlignment="Bottom" Margin="0,0,0,2" />
        </StackPanel>

        <!-- Loading / Error overlay -->
        <Grid x:Name="LoadingOverlay" Background="#20000000" Grid.RowSpan="3" Visibility="Collapsed">
            <ProgressRing IsActive="True" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</UserControl>
