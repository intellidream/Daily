<UserControl
    x:Class="Daily_WinUI.Controls.HabitsWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:gauge="using:Syncfusion.UI.Xaml.Gauges"
    xmlns:local="using:Daily_WinUI.Controls"
    mc:Ignorable="d"
    d:DesignHeight="320"
    d:DesignWidth="420"
    Tapped="Widget_Tapped"
    Background="Transparent">

    <Grid Padding="16,12,16,14">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <!-- SmallState: 1x1, Gauge/Buttons scroll vertically. Extended is hidden. -->
                <VisualState x:Name="SmallState">
                    <VisualState.Setters>
                        <Setter Target="WaterMainCol1.Width" Value="0" />
                        <Setter Target="WaterMainRow0.Height" Value="*" />
                        <Setter Target="WaterMainRow1.Height" Value="0" />
                        <Setter Target="WaterControlsStack.Orientation" Value="Vertical" />
                        <Setter Target="WaterLegend.Visibility" Value="Collapsed" />
                        <Setter Target="WaterExtendedPanel.Visibility" Value="Collapsed" />

                        <Setter Target="SmokesMainCol1.Width" Value="0" />
                        <Setter Target="SmokesMainRow0.Height" Value="*" />
                        <Setter Target="SmokesMainRow1.Height" Value="0" />
                        <Setter Target="SmokesControlsStack.Orientation" Value="Vertical" />
                        <Setter Target="SmokesLegend.Visibility" Value="Collapsed" />
                        <Setter Target="SmokesExtendedPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                
                <!-- TallState: 1x2, 50/50 vertical split. Scroller gets top, Extended gets bottom. -->
                <VisualState x:Name="TallState">
                    <VisualState.Setters>
                        <Setter Target="WaterMainCol1.Width" Value="0" />
                        <Setter Target="WaterMainRow0.Height" Value="*" />
                        <Setter Target="WaterMainRow1.Height" Value="*" />
                        <Setter Target="WaterControlsStack.Orientation" Value="Vertical" />
                        <Setter Target="WaterLegend.Visibility" Value="Visible" />
                        <Setter Target="WaterExtendedPanel.(Grid.Row)" Value="1" />
                        <Setter Target="WaterExtendedPanel.(Grid.Column)" Value="0" />
                        <Setter Target="WaterExtendedPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="WaterExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="WaterExtendedPanel.Margin" Value="0,16,0,0" />

                        <Setter Target="SmokesMainCol1.Width" Value="0" />
                        <Setter Target="SmokesMainRow0.Height" Value="*" />
                        <Setter Target="SmokesMainRow1.Height" Value="*" />
                        <Setter Target="SmokesControlsStack.Orientation" Value="Vertical" />
                        <Setter Target="SmokesLegend.Visibility" Value="Visible" />
                        <Setter Target="SmokesExtendedPanel.(Grid.Row)" Value="1" />
                        <Setter Target="SmokesExtendedPanel.(Grid.Column)" Value="0" />
                        <Setter Target="SmokesExtendedPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="SmokesExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="SmokesExtendedPanel.Margin" Value="0,16,0,0" />
                    </VisualState.Setters>
                </VisualState>
                
                <!-- NormalState (Wide): 2x1, Scroller takes all space, Gauge/Buttons stack horizontally! -->
                <VisualState x:Name="NormalState">
                    <VisualState.Setters>
                        <Setter Target="WaterMainCol1.Width" Value="0" />
                        <Setter Target="WaterMainRow0.Height" Value="*" />
                        <Setter Target="WaterMainRow1.Height" Value="0" />
                        <Setter Target="WaterControlsStack.Orientation" Value="Horizontal" />
                        <Setter Target="WaterLegend.Visibility" Value="Visible" />
                        <Setter Target="WaterExtendedPanel.Visibility" Value="Collapsed" />

                        <Setter Target="SmokesMainCol1.Width" Value="0" />
                        <Setter Target="SmokesMainRow0.Height" Value="*" />
                        <Setter Target="SmokesMainRow1.Height" Value="0" />
                        <Setter Target="SmokesControlsStack.Orientation" Value="Horizontal" />
                        <Setter Target="SmokesLegend.Visibility" Value="Visible" />
                        <Setter Target="SmokesExtendedPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                
                <!-- LargeState: 2x2, 50/50 horizontal split. Scroller gets left, Extended gets right. -->
                <VisualState x:Name="LargeState">
                    <VisualState.Setters>
                        <Setter Target="WaterMainCol1.Width" Value="*" />
                        <Setter Target="WaterMainRow0.Height" Value="*" />
                        <Setter Target="WaterMainRow1.Height" Value="0" />
                        <Setter Target="WaterControlsStack.Orientation" Value="Vertical" />
                        <Setter Target="WaterLegend.Visibility" Value="Visible" />
                        <Setter Target="WaterExtendedPanel.(Grid.Row)" Value="0" />
                        <Setter Target="WaterExtendedPanel.(Grid.Column)" Value="1" />
                        <Setter Target="WaterExtendedPanel.(Grid.RowSpan)" Value="2" />
                        <Setter Target="WaterExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="WaterExtendedPanel.Margin" Value="16,0,0,0" />

                        <Setter Target="SmokesMainCol1.Width" Value="*" />
                        <Setter Target="SmokesMainRow0.Height" Value="*" />
                        <Setter Target="SmokesMainRow1.Height" Value="0" />
                        <Setter Target="SmokesControlsStack.Orientation" Value="Vertical" />
                        <Setter Target="SmokesLegend.Visibility" Value="Visible" />
                        <Setter Target="SmokesExtendedPanel.(Grid.Row)" Value="0" />
                        <Setter Target="SmokesExtendedPanel.(Grid.Column)" Value="1" />
                        <Setter Target="SmokesExtendedPanel.(Grid.RowSpan)" Value="2" />
                        <Setter Target="SmokesExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="SmokesExtendedPanel.Margin" Value="16,0,0,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              x:Name="HeaderGrid"
              Background="Transparent"
              PointerEntered="Header_PointerEntered"
              PointerExited="Header_PointerExited"
              Tapped="Header_Tapped"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Grid.Column="0" Glyph="&#xed23;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,8,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Habits" FontSize="14" FontWeight="SemiBold" Opacity="0.9" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind CurrentViewLabel, Mode=OneWay}" FontSize="11" Opacity="0.55" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button x:Name="PrevBtn" Background="Transparent" BorderThickness="0" Padding="4" Height="24" Width="24" Click="Prev_Click">
                    <FontIcon Glyph="&#xea60;" FontFamily="{StaticResource TablerIconsFont}" FontSize="12" />
                </Button>
                <Button x:Name="NextBtn" Background="Transparent" BorderThickness="0" Padding="4" Height="24" Width="24" Click="Next_Click">
                    <FontIcon Glyph="&#xea61;" FontFamily="{StaticResource TablerIconsFont}" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <FlipView x:Name="HabitsFlipView" Grid.Row="1" SelectionChanged="HabitsFlipView_SelectionChanged" Background="Transparent">
            <!-- WATER VIEW -->
            <FlipViewItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" x:Name="WaterMainCol0" />
                        <ColumnDefinition Width="0" x:Name="WaterMainCol1" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="WaterMainRow0" />
                        <RowDefinition Height="0" x:Name="WaterMainRow1" />
                    </Grid.RowDefinitions>

                    <!-- Left/Top Scroller -->
                    <ScrollViewer x:Name="WaterScroller" Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                        <StackPanel x:Name="WaterControlsStack" Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
                            
                            <!-- Gauge -->
                            <gauge:SfRadialGauge x:Name="WaterGauge" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="130" MaxWidth="130" MinHeight="80" MinWidth="80">
                                <gauge:SfRadialGauge.Axes>
                                    <gauge:RadialAxis x:Name="WaterRadialAxis" StartAngle="135" EndAngle="405" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowAxisLine="False" TickLengthUnit="Factor" MajorTickLength="0.265" MinorTickLength="0.13" MinorTicksPerInterval="4" TickOffset="0">
                                        <gauge:RadialAxis.Ranges>
                                            <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" StartWidth="0.265" EndWidth="0.265" WidthUnit="Factor" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                        </gauge:RadialAxis.Ranges>
                                        <gauge:RadialAxis.Annotations>
                                            <gauge:GaugeAnnotation PositionFactor="0" DirectionValue="90">
                                                <gauge:GaugeAnnotation.Content>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                                        <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                                                        <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </gauge:GaugeAnnotation.Content>
                                            </gauge:GaugeAnnotation>
                                        </gauge:RadialAxis.Annotations>
                                    </gauge:RadialAxis>
                                </gauge:SfRadialGauge.Axes>
                            </gauge:SfRadialGauge>

                            <!-- Legend & 2x2 Buttons -->
                            <StackPanel x:Name="WaterLegendAndButtons" Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Legend -->
                                <Border x:Name="WaterLegend" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel Spacing="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF0288D1" />
                                                <TextBlock Text="Water" FontSize="12" Opacity="0.7" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFF2994A" />
                                                <TextBlock Text="Coffee" FontSize="12" Opacity="0.7" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xef28;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF27AE60" />
                                                <TextBlock Text="Tea" FontSize="12" Opacity="0.7" />
                                            </StackPanel>
                                        </Grid>
                                        <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Goal" FontSize="12" Opacity="0.55" Margin="0,0,16,0" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Quick Add Buttons (2x2 Grid) -->
                                <Grid x:Name="WaterButtonsStack" HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <Button Grid.Row="0" Grid.Column="0" Click="AddWater_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1A0288D1" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF0288D1" />
                                            <TextBlock Text="250" FontSize="11" FontWeight="SemiBold" Foreground="#FF0288D1" />
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Grid.Row="0" Grid.Column="1" Click="AddJuice_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1AE91E63" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xeab8;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFE91E63" />
                                            <TextBlock Text="250" FontSize="11" FontWeight="SemiBold" Foreground="#FFE91E63" />
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Grid.Row="1" Grid.Column="0" Click="AddCoffee_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1AF2994A" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFF2994A" />
                                            <TextBlock Text="150" FontSize="11" FontWeight="SemiBold" Foreground="#FFF2994A" />
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Grid.Row="1" Grid.Column="1" Click="AddTea_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1A27AE60" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xef28;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF27AE60" />
                                            <TextBlock Text="200" FontSize="11" FontWeight="SemiBold" Foreground="#FF27AE60" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Extended Data (Logs & Graph) -->
                    <Grid x:Name="WaterExtendedPanel" Grid.Row="1" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Graph -->
                        <Border Grid.Row="0" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12" Height="100">
                            <ItemsControl ItemsSource="{x:Bind History, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:WidgetChartData">
                                        <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{x:Bind Value}">
                                            <Border Background="{x:Bind ColorHex}" Width="16" Height="{x:Bind BarHeight}" CornerRadius="4,4,0,0" MinHeight="4" />
                                            <TextBlock Text="{x:Bind DateLabel}" FontSize="9" Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Empty Placeholder -->
                        <TextBlock Grid.Row="1" Text="No habits logged yet today" Visibility="{x:Bind HasNoLogs, Mode=OneWay}" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Logs List -->
                        <ListView Grid.Row="1" ItemsSource="{x:Bind Logs, Mode=OneWay}" Visibility="{x:Bind HasLogs, Mode=OneWay}" SelectionMode="None" VerticalAlignment="Stretch">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:WidgetLogEntryViewModel">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="{x:Bind Icon}" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{x:Bind ColorHex}" Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Label}" FontSize="14" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Amount}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind TimeText}" FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </FlipViewItem>

            <!-- SMOKES VIEW -->
            <FlipViewItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" x:Name="SmokesMainCol0" />
                        <ColumnDefinition Width="0" x:Name="SmokesMainCol1" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="SmokesMainRow0" />
                        <RowDefinition Height="0" x:Name="SmokesMainRow1" />
                    </Grid.RowDefinitions>

                    <!-- Left/Top Scroller -->
                    <ScrollViewer x:Name="SmokesScroller" Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                        <StackPanel x:Name="SmokesControlsStack" Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
                            
                            <!-- Gauge -->
                            <gauge:SfRadialGauge x:Name="SmokesGauge" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="130" MaxWidth="130" MinHeight="80" MinWidth="80">
                                <gauge:SfRadialGauge.Axes>
                                    <gauge:RadialAxis x:Name="SmokesRadialAxis" StartAngle="135" EndAngle="405" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowAxisLine="False" TickLengthUnit="Factor" MajorTickLength="0.265" MinorTickLength="0.13" MinorTicksPerInterval="4" TickOffset="0">
                                        <gauge:RadialAxis.Ranges>
                                            <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" StartWidth="0.265" EndWidth="0.265" WidthUnit="Factor" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                        </gauge:RadialAxis.Ranges>
                                        <gauge:RadialAxis.Annotations>
                                            <gauge:GaugeAnnotation PositionFactor="0" DirectionValue="90">
                                                <gauge:GaugeAnnotation.Content>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                                        <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{x:Bind GaugeColor, Mode=OneWay}" />
                                                        <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </gauge:GaugeAnnotation.Content>
                                            </gauge:GaugeAnnotation>
                                        </gauge:RadialAxis.Annotations>
                                    </gauge:RadialAxis>
                                </gauge:SfRadialGauge.Axes>
                            </gauge:SfRadialGauge>

                            <!-- Legend & Buttons -->
                            <StackPanel x:Name="SmokesLegendAndButtons" Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Legend -->
                                <Border x:Name="SmokesLegend" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Smokes Today" FontSize="12" Opacity="0.7" />
                                        <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="{x:Bind GaugeColor, Mode=OneWay}" />
                                        <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="11" Opacity="0.55" />
                                    </StackPanel>
                                </Border>

                                <!-- Quick Add Buttons (2x2) -->
                                <Grid x:Name="SmokesButtonsStack" HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <Button Grid.Row="0" Grid.Column="0" Click="AddCigarette_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1AF44336" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFF44336" />
                                            <TextBlock Text="Cigarette" FontSize="11" FontWeight="SemiBold" Foreground="#FFF44336" />
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Grid.Row="0" Grid.Column="1" Click="AddVape_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1A1976D2" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF1976D2" />
                                            <TextBlock Text="Vape" FontSize="11" FontWeight="SemiBold" Foreground="#FF1976D2" />
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Grid.Row="1" Grid.Column="0" Click="AddRolled_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1AEF6C00" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFEF6C00" />
                                            <TextBlock Text="Rolled" FontSize="11" FontWeight="SemiBold" Foreground="#FFEF6C00" />
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Grid.Row="1" Grid.Column="1" Click="AddCigarillo_Click" CornerRadius="18" Width="72" Height="36" Padding="0" Background="#1A8E24AA" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF8E24AA" />
                                            <TextBlock Text="Cigarillo" FontSize="11" FontWeight="SemiBold" Foreground="#FF8E24AA" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Extended Data (Logs & Graph) -->
                    <Grid x:Name="SmokesExtendedPanel" Grid.Row="1" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Graph -->
                        <Border Grid.Row="0" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12" Height="100">
                            <ItemsControl ItemsSource="{x:Bind History, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Center" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:WidgetChartData">
                                        <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{x:Bind Value}">
                                            <Border Background="{x:Bind ColorHex}" Width="16" Height="{x:Bind BarHeight}" CornerRadius="4,4,0,0" MinHeight="4" />
                                            <TextBlock Text="{x:Bind DateLabel}" FontSize="9" Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Empty Placeholder -->
                        <TextBlock Grid.Row="1" Text="No habits logged yet today" Visibility="{x:Bind HasNoLogs, Mode=OneWay}" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Logs List -->
                        <ListView Grid.Row="1" ItemsSource="{x:Bind Logs, Mode=OneWay}" Visibility="{x:Bind HasLogs, Mode=OneWay}" SelectionMode="None" VerticalAlignment="Stretch">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:WidgetLogEntryViewModel">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="{x:Bind Icon}" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{x:Bind ColorHex}" Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Label}" FontSize="14" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Amount}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind TimeText}" FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </FlipViewItem>
        </FlipView>
    </Grid>
</UserControl>
