<UserControl
    x:Class="Daily_WinUI.Controls.HabitsWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:gauge="using:Syncfusion.UI.Xaml.Gauges"
    mc:Ignorable="d"
    d:DesignHeight="320"
    d:DesignWidth="420"
    Tapped="Widget_Tapped"
    Background="Transparent">

    <Grid Padding="16,12,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              x:Name="HeaderGrid"
              Background="Transparent"
              PointerEntered="Header_PointerEntered"
              PointerExited="Header_PointerExited"
              Tapped="Header_Tapped"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Grid.Column="0" Glyph="&#xed23;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,8,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Habits" FontSize="14" FontWeight="SemiBold" Opacity="0.9" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind CurrentViewLabel, Mode=OneWay}" FontSize="11" Opacity="0.55" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button x:Name="PrevBtn" Background="Transparent" BorderThickness="0" Padding="4" Height="24" Width="24" Click="Prev_Click">
                    <FontIcon Glyph="&#xea60;" FontFamily="{StaticResource TablerIconsFont}" FontSize="12" />
                </Button>
                <Button x:Name="NextBtn" Background="Transparent" BorderThickness="0" Padding="4" Height="24" Width="24" Click="Next_Click">
                    <FontIcon Glyph="&#xea61;" FontFamily="{StaticResource TablerIconsFont}" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <FlipView x:Name="HabitsFlipView" Grid.Row="1" SelectionChanged="HabitsFlipView_SelectionChanged" Background="Transparent">
            <FlipViewItem>
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="24"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Grid>
                            <gauge:SfRadialGauge Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <gauge:SfRadialGauge.Axes>
                                    <gauge:RadialAxis x:Name="WaterRadialAxis" StartAngle="135" EndAngle="405" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowAxisLine="False" TickLengthUnit="Factor" MajorTickLength="0.265" MinorTickLength="0.13" MinorTicksPerInterval="4" TickOffset="0">
                                        <gauge:RadialAxis.Ranges>
                                            <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" StartWidth="0.265" EndWidth="0.265" WidthUnit="Factor" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                        </gauge:RadialAxis.Ranges>
                                        <gauge:RadialAxis.Pointers>
                                            <gauge:NeedlePointer Value="{x:Bind CurrentProgress, Mode=OneWay}"
                                                                 NeedleFill="{ThemeResource TextFillColorPrimaryBrush}"
                                                                 NeedleLength="0.6"
                                                                 NeedleStartWidth="1"
                                                                 NeedleEndWidth="16"
                                                                 KnobFill="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                                                 KnobStroke="{ThemeResource TextFillColorPrimaryBrush}"
                                                                 KnobStrokeThickness="0.05"
                                                                 KnobRadius="0.08"
                                                                 TailFill="{ThemeResource TextFillColorPrimaryBrush}"
                                                                 TailLength="0.2"
                                                                 TailWidth="16" />
                                        </gauge:RadialAxis.Pointers>
                                        <gauge:RadialAxis.Annotations>
                                            <gauge:GaugeAnnotation PositionFactor="0.85" DirectionValue="90">
                                                <gauge:GaugeAnnotation.Content>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                                        <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                                                        <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </gauge:GaugeAnnotation.Content>
                                            </gauge:GaugeAnnotation>
                                        </gauge:RadialAxis.Annotations>
                                    </gauge:RadialAxis>
                                </gauge:SfRadialGauge.Axes>
                            </gauge:SfRadialGauge>

                            
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <Border CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="10">
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF2D9CDB" />
                                    <TextBlock Grid.Column="1" Text="Water" FontSize="12" Opacity="0.7" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFF2994A" />
                                    <TextBlock Grid.Column="1" Text="Coffee" FontSize="12" Opacity="0.7" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xef28;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF27AE60" />
                                    <TextBlock Grid.Column="1" Text="Tea" FontSize="12" Opacity="0.7" />
                                </Grid>
                                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,2,0,0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Goal" FontSize="11" Opacity="0.55" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="11" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Click="AddWater_Click" CornerRadius="18" Padding="8" Background="#FF2196F3" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Water" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1" Click="AddJuice_Click" CornerRadius="18" Padding="8" Background="#FFE91E63" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xeab8;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Juice" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="0" Click="AddCoffee_Click" CornerRadius="18" Padding="8" Background="#FFF2994A" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Coffee" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1" Click="AddTea_Click" CornerRadius="18" Padding="8" Background="#FF27AE60" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xef28;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Tea" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <FlipViewItem>
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="24"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Grid>
                            <gauge:SfRadialGauge Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <gauge:SfRadialGauge.Axes>
                                    <gauge:RadialAxis x:Name="SmokesRadialAxis" StartAngle="135" EndAngle="405" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowAxisLine="False" TickLengthUnit="Factor" MajorTickLength="0.265" MinorTickLength="0.13" MinorTicksPerInterval="4" TickOffset="0">
                                        <gauge:RadialAxis.Ranges>
                                            <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" StartWidth="0.265" EndWidth="0.265" WidthUnit="Factor" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                                        </gauge:RadialAxis.Ranges>
                                        <gauge:RadialAxis.Pointers>
                                            <gauge:NeedlePointer Value="{x:Bind CurrentProgress, Mode=OneWay}"
                                                                 NeedleFill="{ThemeResource TextFillColorPrimaryBrush}"
                                                                 NeedleLength="0.6"
                                                                 NeedleStartWidth="1"
                                                                 NeedleEndWidth="16"
                                                                 KnobFill="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                                                 KnobStroke="{ThemeResource TextFillColorPrimaryBrush}"
                                                                 KnobStrokeThickness="0.05"
                                                                 KnobRadius="0.08"
                                                                 TailFill="{ThemeResource TextFillColorPrimaryBrush}"
                                                                 TailLength="0.2"
                                                                 TailWidth="16" />
                                        </gauge:RadialAxis.Pointers>
                                        <gauge:RadialAxis.Annotations>
                                            <gauge:GaugeAnnotation PositionFactor="0.85" DirectionValue="90">
                                                <gauge:GaugeAnnotation.Content>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                                        <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{x:Bind GaugeColor, Mode=OneWay}" />
                                                        <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </gauge:GaugeAnnotation.Content>
                                            </gauge:GaugeAnnotation>
                                        </gauge:RadialAxis.Annotations>
                                    </gauge:RadialAxis>
                                </gauge:SfRadialGauge.Axes>
                            </gauge:SfRadialGauge>

                            
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <Border CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Smokes Today" FontSize="12" Opacity="0.7" />
                                <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="{x:Bind GaugeColor, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="11" Opacity="0.55" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Click="AddCigarette_Click" CornerRadius="18" Padding="8" Background="#FFF44336" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Cigarette" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1" Click="AddVape_Click" CornerRadius="18" Padding="8" Background="#FF1976D2" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Vape" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="0" Click="AddRolled_Click" CornerRadius="18" Padding="8" Background="#FFEF6C00" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Rolled" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1" Click="AddCigarillo_Click" CornerRadius="18" Padding="8" Background="#FF8E24AA" BorderThickness="0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="White" HorizontalAlignment="Center" />
                                    <TextBlock Text="Cigarillo" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </FlipViewItem>
        </FlipView>
    </Grid>
</UserControl>

