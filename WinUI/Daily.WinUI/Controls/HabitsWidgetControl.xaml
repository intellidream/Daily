                <TextBlock Grid.Column="1" Text="{x:Bind Label}" FontSize="10" Opacity="0.8" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{x:Bind Amount}" FontSize="10" FontWeight="SemiBold" Margin="8,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
