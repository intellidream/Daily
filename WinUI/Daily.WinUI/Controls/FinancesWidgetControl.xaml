<UserControl
    x:Class="Daily_WinUI.Controls.FinancesWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Daily.Models.Finances"
    mc:Ignorable="d"
    d:DesignHeight="320"
    d:DesignWidth="420"
    Background="Transparent">

    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:PercentConverter x:Key="PercentConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
    </UserControl.Resources>

    <Grid Padding="16,12,16,14">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <!-- SmallState: 1x1, Everything vertical. Extended hidden. -->
                <VisualState x:Name="SmallState">
                    <VisualState.Setters>
                        <Setter Target="WorldMainCol1.Width" Value="0" />
                        <Setter Target="WorldMainRow0.Height" Value="*" />
                        <Setter Target="WorldMainRow1.Height" Value="0" />
                        <Setter Target="WorldExtendedPanel.Visibility" Value="Collapsed" />

                        <Setter Target="StocksMainCol1.Width" Value="0" />
                        <Setter Target="StocksMainRow0.Height" Value="*" />
                        <Setter Target="StocksMainRow1.Height" Value="0" />
                        <Setter Target="StocksExtendedPanel.Visibility" Value="Collapsed" />

                        <Setter Target="MoneyMainCol1.Width" Value="0" />
                        <Setter Target="MoneyMainRow0.Height" Value="*" />
                        <Setter Target="MoneyMainRow1.Height" Value="0" />
                        <Setter Target="MoneyExtendedPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                
                <!-- TallState: 1x2, 50/50 vertical split. Extended is at bottom. -->
                <VisualState x:Name="TallState">
                    <VisualState.Setters>
                        <Setter Target="WorldMainCol1.Width" Value="0" />
                        <Setter Target="WorldMainRow0.Height" Value="*" />
                        <Setter Target="WorldMainRow1.Height" Value="*" />
                        <Setter Target="WorldExtendedPanel.(Grid.Row)" Value="1" />
                        <Setter Target="WorldExtendedPanel.(Grid.Column)" Value="0" />
                        <Setter Target="WorldExtendedPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="WorldExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="WorldExtendedPanel.Margin" Value="0,16,0,0" />

                        <Setter Target="StocksMainCol1.Width" Value="0" />
                        <Setter Target="StocksMainRow0.Height" Value="*" />
                        <Setter Target="StocksMainRow1.Height" Value="*" />
                        <Setter Target="StocksExtendedPanel.(Grid.Row)" Value="1" />
                        <Setter Target="StocksExtendedPanel.(Grid.Column)" Value="0" />
                        <Setter Target="StocksExtendedPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="StocksExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="StocksExtendedPanel.Margin" Value="0,16,0,0" />

                        <Setter Target="MoneyMainCol1.Width" Value="0" />
                        <Setter Target="MoneyMainRow0.Height" Value="*" />
                        <Setter Target="MoneyMainRow1.Height" Value="*" />
                        <Setter Target="MoneyExtendedPanel.(Grid.Row)" Value="1" />
                        <Setter Target="MoneyExtendedPanel.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyExtendedPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="MoneyExtendedPanel.Margin" Value="0,16,0,0" />
                    </VisualState.Setters>
                </VisualState>
                
                <!-- NormalState (Wide): 2x1. Scroller takes all space. Left stacks can switch to Horizontal if we want, but since it's just lists, we leave it vertical but allow grid reflow. -->
                <VisualState x:Name="NormalState">
                    <VisualState.Setters>
                        <Setter Target="WorldMainCol1.Width" Value="0" />
                        <Setter Target="WorldMainRow0.Height" Value="*" />
                        <Setter Target="WorldMainRow1.Height" Value="0" />
                        <Setter Target="WorldExtendedPanel.Visibility" Value="Collapsed" />

                        <Setter Target="StocksMainCol1.Width" Value="0" />
                        <Setter Target="StocksMainRow0.Height" Value="*" />
                        <Setter Target="StocksMainRow1.Height" Value="0" />
                        <Setter Target="StocksExtendedPanel.Visibility" Value="Collapsed" />

                        <Setter Target="MoneyMainCol1.Width" Value="0" />
                        <Setter Target="MoneyMainRow0.Height" Value="*" />
                        <Setter Target="MoneyMainRow1.Height" Value="0" />
                        <Setter Target="MoneyExtendedPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                
                <!-- LargeState: 2x2, 50/50 horizontal split. Left gets left, Extended gets right. -->
                <VisualState x:Name="LargeState">
                    <VisualState.Setters>
                        <Setter Target="WorldMainCol1.Width" Value="*" />
                        <Setter Target="WorldMainRow0.Height" Value="*" />
                        <Setter Target="WorldMainRow1.Height" Value="0" />
                        <Setter Target="WorldExtendedPanel.(Grid.Row)" Value="0" />
                        <Setter Target="WorldExtendedPanel.(Grid.Column)" Value="1" />
                        <Setter Target="WorldExtendedPanel.(Grid.RowSpan)" Value="2" />
                        <Setter Target="WorldExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="WorldExtendedPanel.Margin" Value="16,0,0,0" />

                        <Setter Target="StocksMainCol1.Width" Value="*" />
                        <Setter Target="StocksMainRow0.Height" Value="*" />
                        <Setter Target="StocksMainRow1.Height" Value="0" />
                        <Setter Target="StocksExtendedPanel.(Grid.Row)" Value="0" />
                        <Setter Target="StocksExtendedPanel.(Grid.Column)" Value="1" />
                        <Setter Target="StocksExtendedPanel.(Grid.RowSpan)" Value="2" />
                        <Setter Target="StocksExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="StocksExtendedPanel.Margin" Value="16,0,0,0" />

                        <Setter Target="MoneyMainCol1.Width" Value="*" />
                        <Setter Target="MoneyMainRow0.Height" Value="*" />
                        <Setter Target="MoneyMainRow1.Height" Value="0" />
                        <Setter Target="MoneyExtendedPanel.(Grid.Row)" Value="0" />
                        <Setter Target="MoneyExtendedPanel.(Grid.Column)" Value="1" />
                        <Setter Target="MoneyExtendedPanel.(Grid.RowSpan)" Value="2" />
                        <Setter Target="MoneyExtendedPanel.Visibility" Value="Visible" />
                        <Setter Target="MoneyExtendedPanel.Margin" Value="16,0,0,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              x:Name="HeaderGrid"
              Background="Transparent"
              PointerEntered="Header_PointerEntered"
              PointerExited="Header_PointerExited"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Grid.Column="0" Glyph="&#xE825;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,8,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Finances" FontSize="14" FontWeight="SemiBold" Opacity="0.9" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind CurrentViewLabel, Mode=OneWay}" FontSize="11" Opacity="0.55" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button x:Name="PrevBtn" Background="Transparent" BorderThickness="0" Padding="4" Height="24" Width="24" Click="Prev_Click">
                    <FontIcon Glyph="&#xE76B;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                </Button>
                <Button x:Name="NextBtn" Background="Transparent" BorderThickness="0" Padding="4" Height="24" Width="24" Click="Next_Click">
                    <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <FlipView x:Name="FinancesFlipView" Grid.Row="1" SelectionChanged="FlipView_SelectionChanged" Background="Transparent">
            <!-- 1. WORLD VIEW -->
            <FlipViewItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" x:Name="WorldMainCol0" />
                        <ColumnDefinition Width="0" x:Name="WorldMainCol1" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="WorldMainRow0" />
                        <RowDefinition Height="0" x:Name="WorldMainRow1" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                        <ItemsControl ItemsSource="{x:Bind MacroIndicators, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MacroIndicator">
                                    <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Emoji}" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind Pillar}" FontSize="10" Opacity="0.5" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" />
                                                <TextBlock Text="{x:Bind PercentChange, Converter={StaticResource PercentConverter}}" FontSize="11" Foreground="{ThemeResource SystemFillColorSuccessBrush}" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid x:Name="WorldExtendedPanel" Grid.Row="1" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Stretch">
                        <ListView ItemsSource="{x:Bind HeatmapData, Mode=OneWay}" SelectionMode="None">
                            <ListView.Header>
                                <TextBlock Text="Real Interest Rates" FontSize="12" Opacity="0.5" Margin="0,0,0,8" />
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:CountryEconomicData">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind CountryCode}" FontSize="14" Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CountryName}" FontSize="14" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind RealRate}" FontSize="14" FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </FlipViewItem>

            <!-- 2. STOCKS VIEW -->
            <FlipViewItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" x:Name="StocksMainCol0" />
                        <ColumnDefinition Width="0" x:Name="StocksMainCol1" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="StocksMainRow0" />
                        <RowDefinition Height="0" x:Name="StocksMainRow1" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                        <ItemsControl ItemsSource="{x:Bind TopStocks, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:StockQuote">
                                    <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <PersonPicture Grid.Column="0" ProfilePicture="{Binding LogoUrl}" DisplayName="{Binding Symbol}" Width="24" Height="24" Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Symbol}" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind CompanyName}" FontSize="10" Opacity="0.5" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" />
                                                <TextBlock Text="{x:Bind PercentChange, Converter={StaticResource PercentConverter}}" FontSize="11" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid x:Name="StocksExtendedPanel" Grid.Row="1" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Stretch">
                        <ListView ItemsSource="{x:Bind ExtendedStocks, Mode=OneWay}" SelectionMode="None">
                            <ListView.Header>
                                <TextBlock Text="Crypto Watchlist" FontSize="12" Opacity="0.5" Margin="0,0,0,8" />
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:StockQuote">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Symbol}" FontSize="14" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="14" FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </FlipViewItem>

            <!-- 3. MONEY VIEW -->
            <FlipViewItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" x:Name="MoneyMainCol0" />
                        <ColumnDefinition Width="0" x:Name="MoneyMainCol1" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" x:Name="MoneyMainRow0" />
                        <RowDefinition Height="0" x:Name="MoneyMainRow1" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                        <StackPanel Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Net Worth" FontSize="12" Opacity="0.5" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind NetWorthDisplay, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" HorizontalAlignment="Center" Margin="0,-8,0,0"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                <Border Background="#1A0288D1" CornerRadius="12" Padding="12,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE825;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#FF0288D1" />
                                        <TextBlock Text="{x:Bind CashDisplay, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="#FF0288D1" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A8E24AA" CornerRadius="12" Padding="12,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#FF8E24AA" />
                                        <TextBlock Text="{x:Bind InvestmentsDisplay, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="#FF8E24AA" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="MoneyExtendedPanel" Grid.Row="1" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Stretch">
                        <ListView ItemsSource="{x:Bind Accounts, Mode=OneWay}" SelectionMode="None">
                            <ListView.Header>
                                <TextBlock Text="Accounts" FontSize="12" Opacity="0.5" Margin="0,0,0,8" />
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalAccount">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Type}" FontSize="11" Opacity="0.5" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind CurrentBalance, Converter={StaticResource CurrencyConverter}}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </FlipViewItem>
        </FlipView>
    </Grid>
</UserControl>
