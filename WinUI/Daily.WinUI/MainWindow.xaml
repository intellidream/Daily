<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Daily_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Daily_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Daily.WinUI"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom TitleBar Grid bypassing the buggy TitleBar control entirely -->
        <Grid x:Name="AppTitleBar" Background="Transparent" VerticalAlignment="Top" SizeChanged="AppTitleBar_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- 0: Icon -->
                <ColumnDefinition Width="Auto" /> <!-- 1: Title -->
                <ColumnDefinition Width="Auto" /> <!-- 2: Date -->
                <ColumnDefinition Width="*" />    <!-- 3: Spacer -->
                <ColumnDefinition Width="Auto" /> <!-- 4: Right Buttons -->
                <ColumnDefinition x:Name="RightPaddingColumn" Width="140" /> <!-- 5: System Caption Buttons Area -->
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Image Grid.Column="0" Source="Assets/Square44x44Logo.targetsize-32_altform-unplated.png" Width="16" Height="16" Margin="16,0,12,0" VerticalAlignment="Center" IsHitTestVisible="False"/>

            <!-- App Title -->
            <TextBlock Grid.Column="1" Text="DayOne" FontSize="12" VerticalAlignment="Center" IsHitTestVisible="False"/>

            <!-- Date text, immediately following the App Title -->
            <TextBlock x:Name="TitleBarDateText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0.6"
                       Margin="12,0,0,0"
                       IsHitTestVisible="False"/>

            <!-- Right side: Theme toggle and User account -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">

                <!-- Theme toggle -->
                <Button x:Name="TitleBarThemeButton"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="0" Padding="10,0"
                        VerticalAlignment="Stretch"
                        Click="TitleBarTheme_Click"
                        ToolTipService.ToolTip="Toggle light/dark theme">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon x:Name="TitleBarThemeIcon" Glyph="&#xE708;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                        <TextBlock x:Name="TitleBarThemeText" Text="Light" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- User account -->
                <Button x:Name="TitleBarAccountButton"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="0" Padding="10,0"
                        VerticalAlignment="Stretch"
                        ToolTipService.ToolTip="Account">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PersonPicture x:Name="TitleBarUserAvatar" Width="22" Height="22" DisplayName="?" />
                        <TextBlock x:Name="TitleBarUserEmailText"
                                   Text="Not signed in" FontSize="11"
                                   VerticalAlignment="Center" MaxWidth="130"
                                   TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Name="TitleBarSignOutItem" Text="Sign Out" Click="TitleBarSignOut_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF3B1;" FontFamily="Segoe Fluent Icons"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

            </StackPanel>
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
