<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Daily_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Daily_WinUI"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DayOne"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.Resources>
            <!-- Squash and stretch jumping animation of GemIcon with pulsing show lights -->
            <Storyboard x:Name="LoadingStoryboard" RepeatBehavior="Forever">
                <!-- Icon Translation Y (jumping up and landing) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconTranslate" Storyboard.TargetProperty="Y">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="-10" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="-80" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="-15" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Icon Scale X (squash and stretch) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.85" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.02" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.85" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="1.25" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Icon Scale Y (squash and stretch) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.8" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.98" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.2" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.75" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Shadow Scale X -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowScale" Storyboard.TargetProperty="ScaleX">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.85" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.4" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.85" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="1.25" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Shadow Opacity -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoadingShadow" Storyboard.TargetProperty="Opacity">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.4" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.5" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.35" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.1" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.35" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.55" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.4" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Glow Scale X -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleX">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.95" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.1" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.3" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.1" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.8" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Glow Scale Y -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleY">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.95" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.1" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.3" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.1" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.8" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Glow Opacity -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoadingGlow" Storyboard.TargetProperty="Opacity">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.5" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.6" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.45" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.25" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.45" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.65" KeySpline="0.8,0,0.9,0.1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.5" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Text Squash & Stretch (X) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TextScale" Storyboard.TargetProperty="ScaleX">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="1.15" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.75" Value="0.9" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.02" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.85" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Text Squash & Stretch (Y) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TextScale" Storyboard.TargetProperty="ScaleY">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.75" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.75" Value="1.15" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.98" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.85" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Text Translation Y (pushed down and rebound) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TextTranslate" Storyboard.TargetProperty="Y">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="8" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.75" Value="-4" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.85" Value="0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>

                <!-- Text Skew X (horizontal wobble) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TextSkew" Storyboard.TargetProperty="AngleX">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="6" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.75" Value="-6" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="2" KeySpline="0.1,0.9,0.2,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.85" Value="0" KeySpline="0.1,0.9,0.2,1" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <Storyboard x:Name="FadeOutStoryboard">
                <!-- Fade out the LoadingOverlay -->
                <DoubleAnimation Storyboard.TargetName="LoadingOverlay"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1.0" To="0.0"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- Scale up the LoadingOverlay background slightly as it expands away -->
                <DoubleAnimation Storyboard.TargetName="OverlayScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="1.0" To="1.05"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="OverlayScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="1.0" To="1.05"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- Scale down the central loading elements (icon, text, glow, shadow) to recede -->
                <DoubleAnimation Storyboard.TargetName="ContentPanelScale"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="1.0" To="0.75"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ContentPanelScale"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="1.0" To="0.75"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>



                <!-- Fade in the RootFrame -->
                <DoubleAnimation Storyboard.TargetName="RootFrame"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0"
                                 Duration="0:0:0.7">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- SVG Background - spans titlebar + content -->
        <Image Source="{ThemeResource AppBackgroundSource}" Stretch="UniformToFill" IsHitTestVisible="False" Grid.RowSpan="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

        <!-- Custom TitleBar Grid bypassing the buggy TitleBar control entirely -->
        <Grid x:Name="AppTitleBar" Background="Transparent" VerticalAlignment="Top" SizeChanged="AppTitleBar_SizeChanged" Opacity="0.0" IsHitTestVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- 0: Icon -->
                <ColumnDefinition Width="Auto" /> <!-- 1: Title -->
                <ColumnDefinition Width="Auto" /> <!-- 2: Date -->
                <ColumnDefinition Width="*" />    <!-- 3: Spacer -->
                <ColumnDefinition Width="Auto" /> <!-- 4: Right Buttons -->
                <ColumnDefinition x:Name="RightPaddingColumn" Width="140" /> <!-- 5: System Caption Buttons Area -->
            </Grid.ColumnDefinitions>

            <!-- DayOne refresh button (replaces static icon + title) -->
            <Button x:Name="TitleBarRefreshButton"
                    Grid.Column="0" Grid.ColumnSpan="2"
                    Background="Transparent" BorderThickness="0"
                    CornerRadius="0" Padding="12,0"
                    VerticalAlignment="Stretch"
                    Click="TitleBarRefresh_Click"
                    ToolTipService.ToolTip="Refresh dashboard">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Width="16" Height="16" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/GemIcon.svg" RasterizePixelWidth="64" RasterizePixelHeight="64"/>
                        </Image.Source>
                    </Image>
                    <TextBlock Text="DayOne" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Date text, immediately following the App Title -->
            <TextBlock x:Name="TitleBarDateText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0.6"
                       Margin="12,0,0,0"
                       IsHitTestVisible="False"/>

            <!-- Right side: Theme toggle and User account -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">

                <!-- Theme toggle -->
                <Button x:Name="TitleBarThemeButton"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="0" Padding="10,0"
                        VerticalAlignment="Stretch"
                        Click="TitleBarTheme_Click"
                        ToolTipService.ToolTip="Toggle light/dark theme">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon x:Name="TitleBarThemeIcon" Glyph="&#xE708;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                    </StackPanel>
                </Button>

                <!-- Settings -->
                <Button x:Name="TitleBarSettingsButton"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="0" Padding="10,0"
                        VerticalAlignment="Stretch"
                        Click="TitleBarSettings_Click"
                        ToolTipService.ToolTip="Settings">
                    <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                </Button>

                <!-- User account -->
                <Button x:Name="TitleBarAccountButton"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="0" Padding="10,0"
                        VerticalAlignment="Stretch"
                        ToolTipService.ToolTip="Account">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PersonPicture x:Name="TitleBarUserAvatar" Width="22" Height="22" DisplayName="?" />
                        <TextBlock x:Name="TitleBarUserEmailText"
                                   Text="Not signed in" FontSize="11"
                                   VerticalAlignment="Center" MaxWidth="130"
                                   TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Name="TitleBarAuthItem" Text="Sign In" Click="TitleBarAuth_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon x:Name="TitleBarAuthIcon" Glyph="&#xE77B;" FontFamily="Segoe Fluent Icons"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!-- Window Docking & Layout Options -->
                <Button x:Name="TitleBarDockButton"
                        Background="Transparent" BorderThickness="0"
                        CornerRadius="0" Padding="10,0"
                        VerticalAlignment="Stretch"
                        ToolTipService.ToolTip="Window layout options">
                    <FontIcon Glyph="&#xE952;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Float Center (Default)" Click="DockNormal_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE73F;" FontFamily="Segoe Fluent Icons"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Dock Left" Click="DockLeft_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE90C;" FontFamily="Segoe Fluent Icons"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Dock Right" Click="DockRight_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE90D;" FontFamily="Segoe Fluent Icons"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

            </StackPanel>
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" Opacity="0.0" />

        <!-- Full-screen Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Background="{ThemeResource LoadingOverlayBgBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.RowSpan="2" Canvas.ZIndex="9999" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="OverlayScale" ScaleX="1.0" ScaleY="1.0" />
            </Grid.RenderTransform>
            <StackPanel x:Name="LoadingContentPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0" RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <ScaleTransform x:Name="ContentPanelScale" ScaleX="1.0" ScaleY="1.0" />
                </StackPanel.RenderTransform>
                <!-- Container for the icon to keep it positioned relative to the ground -->
                <Grid Height="120" Width="120" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Height="80" Width="80" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                        <Image x:Name="LoadingGemIcon" Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,1.0">
                            <Image.Source>
                                <SvgImageSource UriSource="ms-appx:///Assets/GemIcon.svg" RasterizePixelWidth="240" RasterizePixelHeight="240"/>
                            </Image.Source>
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1.0" ScaleY="1.0" />
                                    <TranslateTransform x:Name="IconTranslate" Y="0" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>

                        <!-- Glowing show lights aura over the icon -->
                        <Ellipse x:Name="LoadingGlow" Width="140" Height="140" Fill="{ThemeResource LoadingGlowBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-30" RenderTransformOrigin="0.5,0.5" Opacity="0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="GlowScale" ScaleX="1.0" ScaleY="1.0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                </Grid>
                <!-- Shadow sits on the ground below the grid container -->
                <Ellipse x:Name="LoadingShadow" Width="64" Height="8" Fill="Black" Opacity="0.4" HorizontalAlignment="Center" Margin="0,8,0,0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="ShadowScale" ScaleX="1.0" ScaleY="1.0" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <TextBlock x:Name="LoadingText" Text="Loading your day..." Foreground="{ThemeResource AppFgColorBrush}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,24,0,0" Opacity="0.75" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="TextScale" ScaleX="1.0" ScaleY="1.0" />
                            <SkewTransform x:Name="TextSkew" AngleX="0" AngleY="0" />
                            <TranslateTransform x:Name="TextTranslate" Y="0" />
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon" ToolTipText="DayOne">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Show" Click="TrayShow_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE737;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="TrayExit_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE711;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
