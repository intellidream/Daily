<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Daily_WinUI"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <LinearGradientBrush x:Key="DashboardBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="0.35" />
            <GradientStop Color="#600B1121" Offset="0.6" />
            <GradientStop Color="#600B1121" Offset="1" />
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="TopBarOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#000B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WidgetBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="WidgetBorderBrush" Color="#46FFFFFF" />

        <DataTemplate x:Key="WeatherWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:WeatherWidgetControl x:Name="WeatherWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="FinancesWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:FinancesWidgetControl x:Name="FinancesWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HabitsWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:HabitsWidgetControl x:Name="HabitsWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HealthWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:HealthWidgetControl x:Name="HealthWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="CalendarWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Calendar Widget Coming Soon" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="RssFeedWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:RssFeedWidgetControl x:Name="RssFeedWidget" ArticleTapped="RssFeedWidget_ArticleTapped" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NotesWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Notes Widget Coming Soon" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MediaWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Media Widget Coming Soon" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SystemInfoWidgetTemplate">
            <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="System Info Widget Coming Soon" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <controls:WidgetTemplateSelector x:Key="WidgetSelector"
            WeatherTemplate="{StaticResource WeatherWidgetTemplate}"
            FinancesTemplate="{StaticResource FinancesWidgetTemplate}"
            HabitsTemplate="{StaticResource HabitsWidgetTemplate}"
            HealthTemplate="{StaticResource HealthWidgetTemplate}"
            CalendarTemplate="{StaticResource CalendarWidgetTemplate}"
            RssFeedTemplate="{StaticResource RssFeedWidgetTemplate}"
            NotesTemplate="{StaticResource NotesWidgetTemplate}"
            MediaTemplate="{StaticResource MediaWidgetTemplate}"
            SystemInfoTemplate="{StaticResource SystemInfoWidgetTemplate}" />
    </Page.Resources>

    <Grid Background="{StaticResource DashboardBackgroundBrush}">
        <!-- Top Artwork -->
        <Grid VerticalAlignment="Top" Height="350">
            <Image Source="ms-appx:///Assets/apptopbar.png" Stretch="UniformToFill" Opacity="0.4" />
            <Rectangle Fill="{StaticResource TopBarOverlayBrush}" />
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32" Spacing="24">
                <!-- Header Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Dashboard" FontFamily="Segoe UI Variable Display" FontSize="42" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    
                    <!-- User Account Button -->
                    <Button x:Name="AccountButton" Grid.Column="1" VerticalAlignment="Center"
                            Background="#20FFFFFF" BorderThickness="0" CornerRadius="20" Padding="12,6"
                            Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PersonPicture x:Name="UserAvatar" Width="28" Height="28" DisplayName="?" />
                            <TextBlock x:Name="UserEmailText" Text="Not signed in" FontSize="13" 
                                       Foreground="#BBFFFFFF" VerticalAlignment="Center" MaxWidth="150"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="SignOutItem" Text="Sign Out" Click="SignOut_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF3B1;" FontFamily="Segoe Fluent Icons"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
                
                <!-- Dynamic Widget Grid -->
                <local:DashboardGridView x:Name="WidgetGridView"
                          SelectionMode="None"
                          HorizontalAlignment="Stretch"
                          Padding="0"
                          CanDragItems="True"
                          CanReorderItems="False"
                          AllowDrop="True"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          DragItemsStarting="WidgetGridView_DragItemsStarting"
                          DragOver="WidgetGridView_DragOver"
                          Drop="WidgetGridView_Drop"
                          SizeChanged="WidgetGridView_SizeChanged"
                          ItemTemplateSelector="{StaticResource WidgetSelector}">
                    
                    <local:DashboardGridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid x:Name="DashboardWrapGrid" Orientation="Horizontal" MaximumRowsOrColumns="2" />
                        </ItemsPanelTemplate>
                    </local:DashboardGridView.ItemsPanel>
                    
                    <local:DashboardGridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Size: Small (1x1)" Tag="1x1" Click="WidgetResize_Click"/>
                                        <MenuFlyoutItem Text="Size: Wide (2x1)" Tag="2x1" Click="WidgetResize_Click"/>
                                        <MenuFlyoutItem Text="Size: Tall (1x2)" Tag="1x2" Click="WidgetResize_Click"/>
                                        <MenuFlyoutItem Text="Size: Large (2x2)" Tag="2x2" Click="WidgetResize_Click"/>
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </local:DashboardGridView.ItemContainerStyle>
                </local:DashboardGridView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
