<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Daily_WinUI"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="DashboardBackgroundBrush" Color="#FF0B1121" />
        <SolidColorBrush x:Key="DashboardBackgroundBrushLight" Color="#FFF5F0E8" />
        
        <LinearGradientBrush x:Key="TopBarOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#000B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WidgetBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="WidgetBorderBrush" Color="#46FFFFFF" />

        <DataTemplate x:Key="WeatherWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:WeatherWidgetControl x:Name="WeatherWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="FinancesWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:FinancesWidgetControl x:Name="FinancesWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HabitsWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:HabitsWidgetControl x:Name="HabitsWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HealthWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:HealthWidgetControl x:Name="HealthWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="CalendarWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Calendar Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="RssFeedWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:RssFeedWidgetControl x:Name="RssFeedWidget" ArticleTapped="RssFeedWidget_ArticleTapped" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NotesWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Notes Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MediaWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Media Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SystemInfoWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="System Info Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <controls:WidgetTemplateSelector x:Key="WidgetSelector"
            WeatherTemplate="{StaticResource WeatherWidgetTemplate}"
            FinancesTemplate="{StaticResource FinancesWidgetTemplate}"
            HabitsTemplate="{StaticResource HabitsWidgetTemplate}"
            HealthTemplate="{StaticResource HealthWidgetTemplate}"
            CalendarTemplate="{StaticResource CalendarWidgetTemplate}"
            RssFeedTemplate="{StaticResource RssFeedWidgetTemplate}"
            NotesTemplate="{StaticResource NotesWidgetTemplate}"
            MediaTemplate="{StaticResource MediaWidgetTemplate}"
            SystemInfoTemplate="{StaticResource SystemInfoWidgetTemplate}" />

        <Storyboard x:Name="FadeInContentStoryboard">
            <!-- Fade in the ContentGrid -->
            <DoubleAnimation Storyboard.TargetName="ContentGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Scale up the ContentGrid with spring overshoot -->
            <DoubleAnimation Storyboard.TargetName="ContentScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.94" To="1.0"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.94" To="1.0"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Fade in/out for Smart Briefing Overlay (Fading Acrylic Blur + Card) -->
        <Storyboard x:Name="FadeInBriefingStoryboard">
            <DoubleAnimation Storyboard.TargetName="SmartBriefingOverlay"
                             Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="FadeOutBriefingStoryboard">
            <DoubleAnimation Storyboard.TargetName="SmartBriefingOverlay"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.0"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="RotatingLoadingIconStoryboard">
            <DoubleAnimation Storyboard.TargetName="LoadingAIIcon"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360"
                             Duration="0:0:3.0"
                             RepeatBehavior="Forever" />
        </Storyboard>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid x:Name="ContentGrid" Background="Transparent" Opacity="0.0" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="ContentScale" ScaleX="0.94" ScaleY="0.94" />
            </Grid.RenderTransform>
            <!-- Scrollable content: widgets -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,16,20,20" Spacing="20">
                    <!-- Dynamic Widget Grid -->
                    <local:DashboardGridView x:Name="WidgetGridView"
                              SelectionMode="None"
                              HorizontalAlignment="Stretch"
                              Padding="0"
                              CanDragItems="True"
                              CanReorderItems="False"
                              AllowDrop="True"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              DragItemsStarting="WidgetGridView_DragItemsStarting"
                              DragOver="WidgetGridView_DragOver"
                              Drop="WidgetGridView_Drop"
                              SizeChanged="WidgetGridView_SizeChanged"
                              ItemTemplateSelector="{StaticResource WidgetSelector}">

                        <local:DashboardGridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid x:Name="DashboardWrapGrid" Orientation="Horizontal" MaximumRowsOrColumns="2" />
                            </ItemsPanelTemplate>
                        </local:DashboardGridView.ItemsPanel>

                        <local:DashboardGridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="6" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="ContextFlyout">
                                    <Setter.Value>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Size: Small (1x1)" Tag="1x1" Click="WidgetResize_Click"/>
                                            <MenuFlyoutItem Text="Size: Wide (2x1)" Tag="2x1" Click="WidgetResize_Click"/>
                                            <MenuFlyoutItem Text="Size: Tall (1x2)" Tag="1x2" Click="WidgetResize_Click"/>
                                            <MenuFlyoutItem Text="Size: Large (2x2)" Tag="2x2" Click="WidgetResize_Click"/>
                                        </MenuFlyout>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </local:DashboardGridView.ItemContainerStyle>
                    </local:DashboardGridView>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Smart Briefing Overlay -->
        <Grid x:Name="SmartBriefingOverlay" Visibility="Collapsed" Opacity="0.0" Background="{ThemeResource AppBriefingBackdropBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <!-- Glass Overlay Card -->
            <Border x:Name="BriefingCardBorder" MaxWidth="1400" MaxHeight="900" Margin="24"
                    Background="{ThemeResource AppGlassColorBrush}"
                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                    BorderThickness="1" CornerRadius="24" Padding="32" Translation="0,0,32"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                
                <Grid>
                    <!-- Loading Panel -->
                    <Grid x:Name="BriefingLoadingPanel" Visibility="Visible" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="LoadingAIIcon"
                                   Source="Assets/GemAIcon.svg"
                                   Width="64"
                                   Height="64"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Image.RenderTransform>
                            </Image>
                            <TextBlock Text="DayOne AI is compiling your briefing..." 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="{ThemeResource AppFgColorBrush}" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Gathering news, weather, finances, habits, and health insights." 
                                       FontSize="13" 
                                       Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="BriefingOuterScrollViewer" 
                                  VerticalScrollBarVisibility="Disabled" 
                                  HorizontalScrollBarVisibility="Disabled" 
                                  VerticalScrollMode="Disabled">
                        <Grid x:Name="BriefingGrid" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" /> <!-- Left Panel: text narrative -->
                        <ColumnDefinition Width="2*" /> <!-- Right Panel: visual cards -->
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Column: Narratives -->
                    <Grid x:Name="BriefingNarrativePanel" Grid.Column="0" Margin="0,0,24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header (Icon + Greeting + Description) -->
                            <RowDefinition Height="*"/>    <!-- Body (Typed body + Outro) -->
                            <RowDefinition Height="Auto"/> <!-- Actions / Checkbox -->
                        </Grid.RowDefinitions>
                        
                        <!-- Header Row (Row 0) -->
                        <Grid x:Name="BriefingHeaderGrid" Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- AI Icon on Left -->
                                <ColumnDefinition Width="*"/>    <!-- Greeting & Intro on Right -->
                            </Grid.ColumnDefinitions>
                            
                            <!-- GemAIcon SVG Image & Pulsating Glow Container -->
                            <Grid x:Name="BriefingIconContainer" Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" Width="96" Height="96">
                                <Ellipse x:Name="AIIconGlow"
                                         Width="64"
                                         Height="64"
                                         Opacity="0.3"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                            <GradientStop Color="{ThemeResource AppBriefingIconGlowColor}" Offset="0" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="GlowScale" ScaleX="1.0" ScaleY="1.0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                
                                <Image x:Name="SmartBriefAIIcon"
                                       Source="Assets/GemAIcon.svg"
                                       Width="64"
                                       Height="64"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform x:Name="IconScale" ScaleX="1.0" ScaleY="1.0"/>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>

                            <!-- Vertical stack for Greeting & Intro on the Right -->
                            <StackPanel x:Name="BriefingHeaderTextPanel" Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                <!-- Greeting (Muted as requested) -->
                                <TextBlock x:Name="BriefingGreetingText" 
                                           Text="Good morning, User!" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                           Opacity="0.8"/>

                                <!-- Descriptive Intro (Muted as requested) -->
                                <TextBlock x:Name="BriefingIntroText" 
                                           Text="Here is your on-device DayOne AI Smart Briefing for today." 
                                           FontSize="14" 
                                           Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                           Opacity="0.75"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <!-- Body Row (Row 1): Content flows underneath the entire Header Grid, aligned to the left edge -->
                        <ScrollViewer x:Name="BriefingTextScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                            <StackPanel Spacing="16">
                                <!-- Main Typed Text (Body, pops out) -->
                                <TextBlock x:Name="BriefingTypedText" 
                                           Text="" 
                                           FontSize="16" 
                                           Foreground="{ThemeResource AppFgColorBrush}" 
                                           TextWrapping="Wrap" 
                                           LineHeight="26"
                                           Opacity="1.0"/>
                                           
                                <!-- Sign-off / Outro Text (Muted, shown at the end) -->
                                <TextBlock x:Name="BriefingOutroText" 
                                           Text="Have a highly productive day!" 
                                           FontSize="14" 
                                           Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                           Opacity="0.0" 
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                        
                        <!-- Actions / Close (Centered Layout) -->
                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,0">
                            <Button Content="Start My Day" Click="CloseBriefing_Click" Style="{ThemeResource AccentButtonStyle}" Padding="32,10" CornerRadius="8" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <CheckBox x:Name="ShowBriefingStartupCheck" Content="Show at startup" IsChecked="True" Checked="ShowBriefingStartupCheck_Changed" Unchecked="ShowBriefingStartupCheck_Changed" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Right Column: Visual Cards with ScrollViewer -->
                    <ScrollViewer x:Name="BriefingWidgetsPanel" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="BriefingWidgetsGrid" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        
                        <!-- Card 1: Weather (Row 0, Col 0) -->
                        <Border x:Name="BriefingWeatherCard" Grid.Row="0" Grid.Column="0" 
                                Background="{ThemeResource AppGlassSubColorBrush}" 
                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                                BorderThickness="1" 
                                CornerRadius="16" 
                                Margin="6" 
                                Padding="16"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="WeatherCardTransform" Y="30"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <FontIcon Glyph="&#xE706;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FFC107"/>
                                    <TextBlock Text="Weather" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                    <TextBlock x:Name="BriefingWeatherTempText" Text="21°C" FontSize="26" FontWeight="Light" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    <TextBlock x:Name="BriefingWeatherCondText" Text="sunny" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,4" Foreground="{ThemeResource AppFgMutedColorBrush}"/>
                                </StackPanel>
                                <!-- Horizontal 5-day forecast columns -->
                                <Grid Grid.Row="2" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock x:Name="ForecastDay1Text" Text="Mon" FontSize="10" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        <FontIcon x:Name="ForecastDay1Icon" Glyph="&#xE706;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#FF9800"/>
                                        <TextBlock x:Name="ForecastDay1Temp" Text="22°" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock x:Name="ForecastDay2Text" Text="Tue" FontSize="10" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        <FontIcon x:Name="ForecastDay2Icon" Glyph="&#xE753;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#B0BEC5"/>
                                        <TextBlock x:Name="ForecastDay2Temp" Text="20°" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock x:Name="ForecastDay3Text" Text="Wed" FontSize="10" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        <FontIcon x:Name="ForecastDay3Icon" Glyph="&#x26C6;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#2196F3"/>
                                        <TextBlock x:Name="ForecastDay3Temp" Text="19°" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock x:Name="ForecastDay4Text" Text="Thu" FontSize="10" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        <FontIcon x:Name="ForecastDay4Icon" Glyph="&#xE706;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#FF9800"/>
                                        <TextBlock x:Name="ForecastDay4Temp" Text="21°" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock x:Name="ForecastDay5Text" Text="Fri" FontSize="10" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        <FontIcon x:Name="ForecastDay5Icon" Glyph="&#xE753;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#B0BEC5"/>
                                        <TextBlock x:Name="ForecastDay5Temp" Text="18°" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <!-- AI/Rule Advice -->
                                <TextBlock x:Name="WeatherAdviceText" Grid.Row="3" Text="" FontSize="10" Foreground="{ThemeResource AppFgMutedColorBrush}" TextWrapping="Wrap" Margin="0,8,0,0" Opacity="0.8"/>
                            </Grid>
                        </Border>
                        
                        <!-- Card 2: Health (Row 0, Col 1) -->
                        <Border x:Name="BriefingHealthCard" Grid.Row="0" Grid.Column="1" 
                                Background="{ThemeResource AppGlassSubColorBrush}" 
                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                                BorderThickness="1" 
                                CornerRadius="16" 
                                Margin="6" 
                                Padding="16"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="HealthCardTransform" Y="30"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <FontIcon Glyph="&#xEC92;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FF5252"/>
                                    <TextBlock Text="Vitals" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Spacing="8" VerticalAlignment="Center">
                                    <!-- Steps -->
                                    <StackPanel Spacing="2">
                                        <Grid>
                                            <TextBlock Text="Steps" FontSize="11" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                            <TextBlock x:Name="BriefingStepsText" Text="4,250" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        </Grid>
                                        <ProgressBar x:Name="BriefingStepsProgress" Minimum="0" Maximum="10000" Value="4250" Height="3" Foreground="#FF9800" Background="#33FFFFFF"/>
                                    </StackPanel>
                                    <!-- Sleep -->
                                    <StackPanel Spacing="2">
                                        <Grid>
                                            <TextBlock Text="Sleep" FontSize="11" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                            <TextBlock x:Name="BriefingSleepText" Text="7.2 hrs" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        </Grid>
                                        <ProgressBar x:Name="BriefingSleepProgress" Minimum="0" Maximum="8" Value="7.2" Height="3" Foreground="#7C4DFF" Background="#33FFFFFF"/>
                                    </StackPanel>
                                    <!-- Heart Rate -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xEB51;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#FF5252" VerticalAlignment="Center"/>
                                        <TextBlock Text="Resting HR:" FontSize="11" Opacity="0.7" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        <TextBlock x:Name="BriefingHeartRateText" Text="64 bpm" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- AI/Rule Advice -->
                                <TextBlock x:Name="HealthAdviceText" Grid.Row="2" Text="" FontSize="10" Foreground="{ThemeResource AppFgMutedColorBrush}" TextWrapping="Wrap" Margin="0,8,0,0" Opacity="0.8"/>
                            </Grid>
                        </Border>
                        
                        <!-- Card 3: Finances (Row 1, Col 0) -->
                        <Border x:Name="BriefingFinancesCard" Grid.Row="1" Grid.Column="0" 
                                Background="{ThemeResource AppGlassSubColorBrush}" 
                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                                BorderThickness="1" 
                                CornerRadius="16" 
                                Margin="6" 
                                Padding="16"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="FinancesCardTransform" Y="30"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <FontIcon Glyph="&#xE8C7;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#4CAF50"/>
                                    <TextBlock Text="Finances" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                    <TextBlock Text="Net Worth" FontSize="10" Opacity="0.6" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    <TextBlock x:Name="BriefingNetWorthText" Text="$24,530" FontSize="20" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}"/>
                                </StackPanel>
                                <!-- Stock rows -->
                                <StackPanel Grid.Row="2" Spacing="6" VerticalAlignment="Bottom">
                                    <Grid x:Name="StockRow1" Height="20">
                                        <TextBlock x:Name="Stock1Symbol" Text="MSFT" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock x:Name="Stock1Price" Text="421.90" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}"/>
                                            <Border x:Name="Stock1Badge" Background="#334CAF50" CornerRadius="4" Padding="4,2">
                                                <TextBlock x:Name="Stock1Change" Text="+1.4%" FontSize="9" FontWeight="Bold" Foreground="#FF4CAF50"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <Grid x:Name="StockRow2" Height="20">
                                        <TextBlock x:Name="Stock2Symbol" Text="AAPL" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock x:Name="Stock2Price" Text="189.84" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}"/>
                                            <Border x:Name="Stock2Badge" Background="#33F44336" CornerRadius="4" Padding="4,2">
                                                <TextBlock x:Name="Stock2Change" Text="-0.3%" FontSize="9" FontWeight="Bold" Foreground="#FFF44336"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <!-- AI/Rule Advice -->
                                <TextBlock x:Name="FinancesAdviceText" Grid.Row="3" Text="" FontSize="10" Foreground="{ThemeResource AppFgMutedColorBrush}" TextWrapping="Wrap" Margin="0,8,0,0" Opacity="0.8"/>
                            </Grid>
                        </Border>
                        
                        <!-- Card 4: Habits (Row 1, Col 1) -->
                        <Border x:Name="BriefingHabitsCard" Grid.Row="1" Grid.Column="1" 
                                Background="{ThemeResource AppGlassSubColorBrush}" 
                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                                BorderThickness="1" 
                                CornerRadius="16" 
                                Margin="6" 
                                Padding="16"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="HabitsCardTransform" Y="30"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                    <FontIcon Glyph="&#xE1D2;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FF9800"/>
                                    <TextBlock Text="Habits" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Radial progress -->
                                    <Grid Width="50" Height="50" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <ProgressRing x:Name="BriefingHabitsProgress" Minimum="0" Maximum="4" Value="1" Width="50" Height="50" Foreground="#FF9800" Background="#33FFFFFF"/>
                                        <TextBlock x:Name="BriefingHabitsProgressText" Text="1/4" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}"/>
                                    </Grid>
                                    <!-- Dynamic text bullet checklist -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                        <StackPanel x:Name="BriefingHabit1Panel" Orientation="Horizontal" Spacing="4">
                                            <FontIcon x:Name="BriefingHabit1Icon" Glyph="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="BriefingHabit1Text" Text="Water: 0/2000 ml" FontSize="10" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        </StackPanel>
                                        <StackPanel x:Name="BriefingHabit2Panel" Orientation="Horizontal" Spacing="4">
                                            <FontIcon x:Name="BriefingHabit2Icon" Glyph="&#xE739;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="BriefingHabit2Text" Text="Smokes: 0/20 today" FontSize="10" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppFgColorBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <!-- AI/Rule Advice -->
                                <TextBlock x:Name="HabitsAdviceText" Grid.Row="2" Text="" FontSize="10" Foreground="{ThemeResource AppFgMutedColorBrush}" TextWrapping="Wrap" Margin="0,8,0,0" Opacity="0.8"/>
                            </Grid>
                        </Border>

                            <!-- Card 5: News recommendations (Row 2, Col 0, ColSpan 2) -->
                            <Border x:Name="BriefingNewsCard" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                    Background="{ThemeResource AppGlassSubColorBrush}" 
                                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="16" 
                                    Margin="6" 
                                    Opacity="0" 
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="NewsCardTransform" Y="30"/>
                                </Border.RenderTransform>
                                <controls:NewsRecommendationsWidgetControl x:Name="BriefingNewsWidget" />
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
                </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Animations for visual cards -->
            <Grid.Resources>
                <!-- Storyboard for Weather Card -->
                <Storyboard x:Name="FadeInWeatherStoryboard">
                    <DoubleAnimation Storyboard.TargetName="BriefingWeatherCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="WeatherCardTransform" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <!-- Storyboard for Health Card -->
                <Storyboard x:Name="FadeInHealthStoryboard">
                    <DoubleAnimation Storyboard.TargetName="BriefingHealthCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="HealthCardTransform" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <!-- Storyboard for Finances Card -->
                <Storyboard x:Name="FadeInFinancesStoryboard">
                    <DoubleAnimation Storyboard.TargetName="BriefingFinancesCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="FinancesCardTransform" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <!-- Storyboard for News Card -->
                <Storyboard x:Name="FadeInNewsStoryboard">
                    <DoubleAnimation Storyboard.TargetName="BriefingNewsCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="NewsCardTransform" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>

                <!-- Storyboard for Habits Card -->
                <Storyboard x:Name="FadeInHabitsStoryboard">
                    <DoubleAnimation Storyboard.TargetName="BriefingHabitsCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="HabitsCardTransform" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
        </Grid>
    </Grid>
</Page>
