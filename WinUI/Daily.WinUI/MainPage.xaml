<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Daily_WinUI"
    xmlns:models="using:Daily_WinUI.Models"
    xmlns:chart="using:Syncfusion.UI.Xaml.Charts"
    xmlns:gauge="using:Syncfusion.UI.Xaml.Gauges"
    xmlns:editors="using:Syncfusion.UI.Xaml.Editors"
    xmlns:notif="using:Syncfusion.UI.Xaml.Notifications"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0E1F3A" Offset="0" />
            <GradientStop Color="#FF163760" Offset="0.45" />
            <GradientStop Color="#FF236A88" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#FF69B6FF" />
        <SolidColorBrush x:Key="AccentMintBrush" Color="#FF7FF0D5" />
        <SolidColorBrush x:Key="AccentSunBrush" Color="#FFFFD166" />
        <SolidColorBrush x:Key="AccentRoseBrush" Color="#FFFF8FA3" />
        <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="#CC2274D8" />
        <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#AA165AA8" />
        <SolidColorBrush x:Key="ShellBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#46FFFFFF" />
        <SolidColorBrush x:Key="TileBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="TileBorderBrush" Color="#30FFFFFF" />
        <SolidColorBrush x:Key="SubTileBrush" Color="#15FFFFFF" />
        <SolidColorBrush x:Key="ForecastCardBrush" Color="#14FFFFFF" />
        <SolidColorBrush x:Key="ForecastCardBorderBrush" Color="#33FFFFFF" />
    </Page.Resources>

    <Grid Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="MobileState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="GlassShell.Margin" Value="12" />
                        <Setter Target="GlassShell.Padding" Value="14" />
                        <Setter Target="DashboardGrid.ColumnSpacing" Value="0" />
                        <Setter Target="PrimaryPanel.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="SideRailPanel.(Grid.Row)" Value="1" />
                        <Setter Target="SideRailPanel.(Grid.Column)" Value="0" />
                        <Setter Target="SideRailPanel.(Grid.ColumnSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="DesktopState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="GlassShell.Margin" Value="28" />
                        <Setter Target="GlassShell.Padding" Value="26" />
                        <Setter Target="DashboardGrid.ColumnSpacing" Value="16" />
                        <Setter Target="PrimaryPanel.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="SideRailPanel.(Grid.Row)" Value="0" />
                        <Setter Target="SideRailPanel.(Grid.Column)" Value="1" />
                        <Setter Target="SideRailPanel.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled">
            <Border x:Name="GlassShell" Margin="20" Background="{StaticResource ShellBrush}" BorderBrush="{StaticResource ShellBorderBrush}" BorderThickness="1" CornerRadius="28" Padding="22">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <editors:SfComboBox
                            Grid.Column="0"
                            x:Name="LocationSearchBox"
                            PlaceholderText="Search city, e.g. London, UK"
                            IsEditable="True"
                            IsFilteringEnabled="False"
                            IsTextSearchEnabled="False"
                            TextMemberPath="DisplayName"
                            DisplayMemberPath="DisplayName"
                            SelectionChanged="LocationSearchBox_SelectionChanged"
                            InputSubmitted="LocationSearchBox_InputSubmitted"
                            Loaded="LocationSearchBox_ComboBoxLoaded"
                            FontSize="15"
                            MaxWidth="720" />

                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
                                <Button x:Name="FavoriteToggleButton" Content="Add Favorite" Click="FavoriteToggleButton_Click" Background="{StaticResource ButtonPrimaryBrush}" Foreground="White" Padding="12,8" MinWidth="110" />
                                <Button x:Name="FavoritePinButton" Content="Pin" Click="FavoritePinButton_Click" Background="{StaticResource ButtonSecondaryBrush}" Foreground="White" Padding="12,8" MinWidth="84" />
                                <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" Background="{StaticResource ButtonSecondaryBrush}" Foreground="White" Padding="12,8" MinWidth="92" />
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="Glass" VerticalAlignment="Center" Opacity="0.75" />
                                    <ComboBox x:Name="GlassIntensityComboBox" Width="120" SelectionChanged="GlassIntensityComboBox_SelectionChanged" SelectedIndex="1">
                                        <x:String>Low</x:String>
                                        <x:String>Medium</x:String>
                                        <x:String>High</x:String>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="DashboardGrid" Grid.Row="1" ColumnSpacing="14" RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="PrimaryPanel" Grid.Row="0" Grid.Column="0" Spacing="14">
                            <Border Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="18">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <TextBlock Text="{x:Bind ViewModel.LocationName, Mode=OneWay}" FontFamily="Segoe UI Variable Display" FontSize="34" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}" FontSize="16" Opacity="0.84" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,8,0,0" VerticalAlignment="Bottom">
                                            <TextBlock Text="{x:Bind ViewModel.Temperature, Mode=OneWay}" FontFamily="Segoe UI Variable Display" FontSize="70" FontWeight="Bold" />
                                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="Feels Like" FontSize="12" Opacity="0.65" CharacterSpacing="100" />
                                                <TextBlock Text="{x:Bind ViewModel.FeelsLike, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind ViewModel.HighLow, Mode=OneWay}" FontSize="14" Opacity="0.76" />
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                    <ProgressRing Width="14" Height="14" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                                                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" FontSize="12" Opacity="0.75" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <notif:BadgeContainer Grid.Column="1" VerticalAlignment="Center">
                                        <Border Background="{StaticResource ForecastCardBrush}" BorderBrush="{StaticResource ForecastCardBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="10">
                                            <Image x:Name="ConditionIcon" Width="116" Height="116" Stretch="UniformToFill" />
                                        </Border>
                                        <notif:BadgeContainer.Badge>
                                            <notif:SfBadge
                                                Content="{x:Bind ViewModel.WeatherAlertText, Mode=OneWay}"
                                                Visibility="{x:Bind BoolToVisibility(ViewModel.HasWeatherAlert), Mode=OneWay}"
                                                Shape="Oval"
                                                Background="#FFFF6B00"
                                                AnimationType="Scale"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top" />
                                        </notif:BadgeContainer.Badge>
                                    </notif:BadgeContainer>
                                </Grid>
                            </Border>

                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8">
                                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Humidity" FontSize="11" Opacity="0.65" HorizontalAlignment="Center" />
                                        <gauge:SfRadialGauge Height="90" Width="90">
                                            <gauge:SfRadialGauge.Axes>
                                                <gauge:RadialAxis Minimum="0" Maximum="100"
                                                                  ShowLabels="False"
                                                                  ShowTicks="False"
                                                                  ShowAxisLine="False"
                                                                  StartAngle="140"
                                                                  EndAngle="40">
                                                    <gauge:RadialAxis.Ranges>
                                                        <gauge:GaugeRange StartValue="0" EndValue="100" Background="#1A7FF0D5" />
                                                    </gauge:RadialAxis.Ranges>
                                                    <gauge:RadialAxis.Pointers>
                                                        <gauge:RangePointer Value="{x:Bind ViewModel.HumidityValue, Mode=OneWay}">
                                                            <gauge:RangePointer.GradientStops>
                                                                <gauge:GaugeGradientStop Value="0" Color="#FF7FF0D5" />
                                                                <gauge:GaugeGradientStop Value="100" Color="#FF7FF0D5" />
                                                            </gauge:RangePointer.GradientStops>
                                                        </gauge:RangePointer>
                                                    </gauge:RadialAxis.Pointers>
                                                    <gauge:RadialAxis.Annotations>
                                                        <gauge:GaugeAnnotation DirectionUnit="Angle" DirectionValue="90" PositionFactor="0.5">
                                                            <gauge:GaugeAnnotation.Content>
                                                                <TextBlock Text="{x:Bind ViewModel.Humidity, Mode=OneWay}"
                                                                           FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                            </gauge:GaugeAnnotation.Content>
                                                        </gauge:GaugeAnnotation>
                                                    </gauge:RadialAxis.Annotations>
                                                </gauge:RadialAxis>
                                            </gauge:SfRadialGauge.Axes>
                                        </gauge:SfRadialGauge>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8">
                                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Wind" FontSize="11" Opacity="0.65" HorizontalAlignment="Center" />
                                        <gauge:SfRadialGauge Height="90" Width="90">
                                            <gauge:SfRadialGauge.Axes>
                                                <gauge:RadialAxis Minimum="0" Maximum="30"
                                                                  ShowLabels="False"
                                                                  ShowTicks="False"
                                                                  ShowAxisLine="False"
                                                                  StartAngle="140"
                                                                  EndAngle="40">
                                                    <gauge:RadialAxis.Ranges>
                                                        <gauge:GaugeRange StartValue="0" EndValue="30" Background="#1A69B6FF" />
                                                    </gauge:RadialAxis.Ranges>
                                                    <gauge:RadialAxis.Pointers>
                                                        <gauge:RangePointer Value="{x:Bind ViewModel.WindSpeedValue, Mode=OneWay}">
                                                            <gauge:RangePointer.GradientStops>
                                                                <gauge:GaugeGradientStop Value="0" Color="#FF69B6FF" />
                                                                <gauge:GaugeGradientStop Value="30" Color="#FF69B6FF" />
                                                            </gauge:RangePointer.GradientStops>
                                                        </gauge:RangePointer>
                                                    </gauge:RadialAxis.Pointers>
                                                    <gauge:RadialAxis.Annotations>
                                                        <gauge:GaugeAnnotation DirectionUnit="Angle" DirectionValue="90" PositionFactor="0.5">
                                                            <gauge:GaugeAnnotation.Content>
                                                                <TextBlock Text="{x:Bind ViewModel.Wind, Mode=OneWay}"
                                                                           FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                                            </gauge:GaugeAnnotation.Content>
                                                        </gauge:GaugeAnnotation>
                                                    </gauge:RadialAxis.Annotations>
                                                </gauge:RadialAxis>
                                            </gauge:SfRadialGauge.Axes>
                                        </gauge:SfRadialGauge>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                                    <StackPanel Spacing="2">
                                        <FontIcon Glyph="&#xE890;" FontFamily="Segoe Fluent Icons" FontSize="18" Opacity="0.85" Foreground="{StaticResource AccentSunBrush}" />
                                        <TextBlock Text="Visibility" FontSize="12" Opacity="0.65" />
                                        <TextBlock Text="{x:Bind ViewModel.Visibility, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                                    <StackPanel Spacing="2">
                                        <FontIcon Glyph="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="18" Opacity="0.85" Foreground="{StaticResource AccentRoseBrush}" />
                                        <TextBlock Text="Pressure" FontSize="12" Opacity="0.65" />
                                        <TextBlock Text="{x:Bind ViewModel.Pressure, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="SunToggleTile" Grid.Column="0" Background="{StaticResource SubTileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10" Tapped="WeatherToggleTile_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE706;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                                        <TextBlock Text="{x:Bind ViewModel.SunLabel, Mode=OneWay}" Opacity="0.65" />
                                        <TextBlock Text="{x:Bind ViewModel.SunValue, Mode=OneWay}" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="HumidityToggleTile" Grid.Column="1" Background="{StaticResource SubTileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10" Tapped="WeatherToggleTile_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE708;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                                        <TextBlock Text="{x:Bind ViewModel.MoistureLabel, Mode=OneWay}" Opacity="0.65" />
                                        <TextBlock Text="{x:Bind ViewModel.MoistureValue, Mode=OneWay}" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="SideRailPanel" Grid.Row="0" Grid.Column="1" Spacing="14">
                            <Border Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                                <StackPanel x:Name="FavoritesPanel" Spacing="10">
                                    <TextBlock Text="Saved Locations" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="SemiBold" />

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Home" FontSize="12" Opacity="0.7" CharacterSpacing="80" />
                                        <ListView
                                            x:Name="HomeFavoritesList"
                                            ItemsSource="{x:Bind HomeFavorites, Mode=OneWay}"
                                            SelectionMode="None"
                                            IsItemClickEnabled="True"
                                            ItemClick="FavoriteList_ItemClick"
                                            CanDragItems="True"
                                            CanReorderItems="True"
                                            AllowDrop="True"
                                            DragItemsCompleted="FavoriteList_DragItemsCompleted"
                                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                            ScrollViewer.HorizontalScrollMode="Enabled"
                                            ScrollViewer.VerticalScrollMode="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                            MaxHeight="52">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsStackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="models:LocationSuggestion">
                                                    <Border Padding="10,4" Margin="0,0,8,0" Background="{StaticResource ForecastCardBrush}" BorderBrush="{StaticResource ForecastCardBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{x:Bind PinTag}" />
                                                            <TextBlock Text="{x:Bind DisplayName}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Work" FontSize="12" Opacity="0.7" CharacterSpacing="80" />
                                        <ListView
                                            x:Name="WorkFavoritesList"
                                            ItemsSource="{x:Bind WorkFavorites, Mode=OneWay}"
                                            SelectionMode="None"
                                            IsItemClickEnabled="True"
                                            ItemClick="FavoriteList_ItemClick"
                                            CanDragItems="True"
                                            CanReorderItems="True"
                                            AllowDrop="True"
                                            DragItemsCompleted="FavoriteList_DragItemsCompleted"
                                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                            ScrollViewer.HorizontalScrollMode="Enabled"
                                            ScrollViewer.VerticalScrollMode="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                            MaxHeight="52">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsStackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="models:LocationSuggestion">
                                                    <Border Padding="10,4" Margin="0,0,8,0" Background="{StaticResource ForecastCardBrush}" BorderBrush="{StaticResource ForecastCardBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{x:Bind PinTag}" />
                                                            <TextBlock Text="{x:Bind DisplayName}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Travel" FontSize="12" Opacity="0.7" CharacterSpacing="80" />
                                        <ListView
                                            x:Name="TravelFavoritesList"
                                            ItemsSource="{x:Bind TravelFavorites, Mode=OneWay}"
                                            SelectionMode="None"
                                            IsItemClickEnabled="True"
                                            ItemClick="FavoriteList_ItemClick"
                                            CanDragItems="True"
                                            CanReorderItems="True"
                                            AllowDrop="True"
                                            DragItemsCompleted="FavoriteList_DragItemsCompleted"
                                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                            ScrollViewer.HorizontalScrollMode="Enabled"
                                            ScrollViewer.VerticalScrollMode="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                            MaxHeight="52">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsStackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="models:LocationSuggestion">
                                                    <Border Padding="10,4" Margin="0,0,8,0" Background="{StaticResource ForecastCardBrush}" BorderBrush="{StaticResource ForecastCardBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{x:Bind PinTag}" />
                                                            <TextBlock Text="{x:Bind DisplayName}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Recent" FontSize="12" Opacity="0.7" CharacterSpacing="80" />
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                                            <ItemsRepeater ItemsSource="{x:Bind RecentLocations, Mode=OneWay}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Orientation="Horizontal" Spacing="8" />
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding DisplayName}" Click="RecentChip_Click" Padding="10,4" FontSize="12" />
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </ScrollViewer>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsPanelHost" Background="{StaticResource SubTileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="8">
                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource AccentMintBrush}" />
                                            <TextBlock Text="Settings &amp; Preferences" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <Grid Padding="4,8,4,4" ColumnSpacing="10" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Weather &amp; Favorites" FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" Opacity="0.85" Foreground="{StaticResource AccentBlueBrush}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Favorite Type" FontSize="12" Opacity="0.7" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="FavoriteCategoryComboBox" SelectedIndex="2">
                                            <x:String>Home</x:String>
                                            <x:String>Work</x:String>
                                            <x:String>Travel</x:String>
                                        </ComboBox>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Temperature Units" FontSize="12" Opacity="0.7" />
                                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="UnitSystemComboBox" SelectionChanged="UnitSystemComboBox_SelectionChanged">
                                            <x:String>Metric (C)</x:String>
                                            <x:String>Imperial (F)</x:String>
                                        </ComboBox>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Wind Units" FontSize="12" Opacity="0.7" />
                                        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="WindUnitComboBox" SelectionChanged="WindUnitComboBox_SelectionChanged">
                                            <x:String>m/s</x:String>
                                            <x:String>km/h</x:String>
                                            <x:String>mph</x:String>
                                            <x:String>kn</x:String>
                                        </ComboBox>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Pressure Units" FontSize="12" Opacity="0.7" />
                                        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="PressureUnitComboBox" SelectionChanged="PressureUnitComboBox_SelectionChanged">
                                            <x:String>hpa</x:String>
                                            <x:String>mmhg</x:String>
                                            <x:String>inhg</x:String>
                                        </ComboBox>
                                    </Grid>
                                </Expander>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="14" RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                                <Grid RowSpacing="4" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Hourly Forecast" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="SemiBold" />

                                    <Grid Grid.Row="1" RowSpacing="2" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Icon + temperature row. ScaleX=8/7 maps UniformGrid centers to 8 tick positions. -->
                                        <ItemsRepeater
                                            x:Name="HourlyIconStrip"
                                            Grid.Row="0"
                                            ItemsSource="{x:Bind ViewModel.HourlyForecast, Mode=OneWay}"
                                            HorizontalAlignment="Stretch"
                                            Margin="12,0,12,0"
                                            RenderTransformOrigin="0.5,0.5">
                                            <ItemsRepeater.RenderTransform>
                                                <ScaleTransform ScaleX="1.142857" />
                                            </ItemsRepeater.RenderTransform>
                                            <ItemsRepeater.Layout>
                                                <UniformGridLayout MaximumRowsOrColumns="8" MinItemWidth="56" MinColumnSpacing="0" ItemsStretch="Fill" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:HourlyForecastSnapshot">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Spacing="1" Padding="0,4,0,0">
                                                        <Image Source="{x:Bind IconImage}" Width="30" Height="30" HorizontalAlignment="Center" />
                                                        <TextBlock Text="{x:Bind TemperatureText}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#FFF4FAFF" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>

                                        <!-- Spline chart — same container width as top strip -->
                                        <chart:SfCartesianChart
                                            x:Name="HourlyForecastChart"
                                            Grid.Row="1"
                                            Height="190"
                                            Margin="0,2,0,0"
                                            PlotAreaBorderThickness="0"
                                            >

                                        <chart:SfCartesianChart.XAxes>
                                            <chart:CategoryAxis ShowMajorGridLines="False" TickLineSize="0">
                                                <chart:CategoryAxis.LabelStyle>
                                                    <chart:LabelStyle Foreground="#CCE0EEFF" FontSize="11" />
                                                </chart:CategoryAxis.LabelStyle>
                                                <chart:CategoryAxis.AxisLineStyle>
                                                    <Style TargetType="Line">
                                                        <Setter Property="StrokeThickness" Value="0" />
                                                    </Style>
                                                </chart:CategoryAxis.AxisLineStyle>
                                            </chart:CategoryAxis>
                                        </chart:SfCartesianChart.XAxes>

                                        <chart:SfCartesianChart.YAxes>
                                            <chart:NumericalAxis />
                                        </chart:SfCartesianChart.YAxes>

                                        <chart:SplineAreaSeries
                                            ItemsSource="{x:Bind ViewModel.HourlyForecast, Mode=OneWay}"
                                            XBindingPath="HourLabel"
                                            YBindingPath="Temperature"
                                            StrokeWidth="2"
                                            Fill="#8069B6FF"
                                            Stroke="#FF69B6FF" />

                                        </chart:SfCartesianChart>
                                    </Grid>
                                </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="{StaticResource TileBrush}" BorderBrush="{StaticResource TileBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="5-Day Forecast" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="SemiBold" />
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ForecastDays, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="8" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ForecastDaySnapshot">
                                            <Border Background="{StaticResource ForecastCardBrush}" BorderBrush="{StaticResource ForecastCardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind DayLabel}" FontSize="15" FontWeight="SemiBold" Margin="0,0,10,0" />
                                                    <StackPanel Grid.Column="1" Spacing="1">
                                                        <TextBlock Text="{x:Bind Description}" Opacity="0.84" TextWrapping="WrapWholeWords" MaxLines="1" />
                                                        <TextBlock Text="{x:Bind PrecipitationText}" Opacity="0.72" FontSize="12" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <TextBlock Text="{x:Bind MaxTempText}" FontWeight="SemiBold" />
                                                        <TextBlock Text="/" Opacity="0.7" />
                                                        <TextBlock Text="{x:Bind MinTempText}" Opacity="0.75" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
