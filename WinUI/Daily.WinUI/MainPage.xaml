<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Daily_WinUI"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <LinearGradientBrush x:Key="DashboardBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="0.35" />
            <GradientStop Color="#600B1121" Offset="0.6" />
            <GradientStop Color="#600B1121" Offset="1" />
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="TopBarOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#000B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WidgetBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="WidgetBorderBrush" Color="#46FFFFFF" />
    </Page.Resources>

    <Grid Background="{StaticResource DashboardBackgroundBrush}">
        <!-- Top Artwork -->
        <Grid VerticalAlignment="Top" Height="350">
            <Image Source="ms-appx:///Assets/apptopbar.png" Stretch="UniformToFill" Opacity="0.4" />
            <Rectangle Fill="{StaticResource TopBarOverlayBrush}" />
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32" Spacing="24">
                <!-- Header Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Dashboard" FontFamily="Segoe UI Variable Display" FontSize="42" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    
                    <!-- User Account Button -->
                    <Button x:Name="AccountButton" Grid.Column="1" VerticalAlignment="Center"
                            Background="#20FFFFFF" BorderThickness="0" CornerRadius="20" Padding="12,6"
                            Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PersonPicture x:Name="UserAvatar" Width="28" Height="28" DisplayName="?" />
                            <TextBlock x:Name="UserEmailText" Text="Not signed in" FontSize="13" 
                                       Foreground="#BBFFFFFF" VerticalAlignment="Center" MaxWidth="150"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Name="SignOutItem" Text="Sign Out" Click="SignOut_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF3B1;" FontFamily="Segoe Fluent Icons"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
                
                <!-- We will use a Grid to allow different widget sizes without crashing -->
                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200" />
                        <RowDefinition Height="200" />
                        <RowDefinition Height="200" />
                        <RowDefinition Height="200" />
                    </Grid.RowDefinitions>
                    
                    <!-- Weather Widget -->
                    <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Grid.ColumnSpan="2" Grid.Row="0" Tapped="WeatherWidget_Tapped">
                        <controls:WeatherWidgetControl x:Name="WeatherWidget" />
                    </Border>
                    
                    <!-- Finances Widget -->
                    <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Grid.Column="0" Grid.Row="1" Tapped="FinancesWidget_Tapped">
                        <controls:FinancesWidgetControl x:Name="FinancesWidget" />
                    </Border>

                    <!-- Habits Widget -->
                    <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Grid.Column="1" Grid.Row="1" Tapped="HabitsWidget_Tapped">
                        <controls:HabitsWidgetControl x:Name="HabitsWidget" />
                    </Border>

                    <!-- RSS Widget (Spans 2 rows) -->
                    <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Grid.Column="0" Grid.Row="2" Grid.RowSpan="2" Tapped="RssFeedWidget_Tapped">
                        <controls:RssFeedWidgetControl x:Name="RssFeedWidget" />
                    </Border>

                    <!-- Health Widget -->
                    <Border Background="{StaticResource WidgetBrush}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="16" Grid.Column="1" Grid.Row="2" Tapped="HealthWidget_Tapped">
                        <controls:HealthWidgetControl x:Name="HealthWidget" />
                    </Border>

                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
