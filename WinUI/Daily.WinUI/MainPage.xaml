<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Daily_WinUI"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="DashboardBackgroundBrush" Color="#FF0B1121" />
        <SolidColorBrush x:Key="DashboardBackgroundBrushLight" Color="#FFF5F0E8" />
        
        <LinearGradientBrush x:Key="TopBarOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#000B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WidgetBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="WidgetBorderBrush" Color="#46FFFFFF" />

        <DataTemplate x:Key="WeatherWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:WeatherWidgetControl x:Name="WeatherWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="FinancesWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:FinancesWidgetControl x:Name="FinancesWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HabitsWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:HabitsWidgetControl x:Name="HabitsWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HealthWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:HealthWidgetControl x:Name="HealthWidget" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="CalendarWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Calendar Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="RssFeedWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <controls:RssFeedWidgetControl x:Name="RssFeedWidget" ArticleTapped="RssFeedWidget_ArticleTapped" />
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NotesWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Notes Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MediaWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="Media Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SystemInfoWidgetTemplate">
            <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Tapped="Widget_Tapped">
                <TextBlock Text="System Info Widget Coming Soon" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <controls:WidgetTemplateSelector x:Key="WidgetSelector"
            WeatherTemplate="{StaticResource WeatherWidgetTemplate}"
            FinancesTemplate="{StaticResource FinancesWidgetTemplate}"
            HabitsTemplate="{StaticResource HabitsWidgetTemplate}"
            HealthTemplate="{StaticResource HealthWidgetTemplate}"
            CalendarTemplate="{StaticResource CalendarWidgetTemplate}"
            RssFeedTemplate="{StaticResource RssFeedWidgetTemplate}"
            NotesTemplate="{StaticResource NotesWidgetTemplate}"
            MediaTemplate="{StaticResource MediaWidgetTemplate}"
            SystemInfoTemplate="{StaticResource SystemInfoWidgetTemplate}" />

        <!-- Squash and stretch jumping animation of GemIcon -->
        <!-- Squash and stretch jumping animation of GemIcon with pulsing show lights -->
        <Storyboard x:Name="LoadingStoryboard" RepeatBehavior="Forever">
            <!-- Icon Translation Y (jumping up and landing) -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconTranslate" Storyboard.TargetProperty="Y">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="-10" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="-80" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="-15" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Icon Scale X (squash and stretch) -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.85" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.02" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.85" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="1.25" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Icon Scale Y (squash and stretch) -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.8" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.98" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.2" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.75" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Shadow Scale X -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowScale" Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="1.2" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.85" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.4" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.85" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="1.25" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Shadow Opacity -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoadingShadow" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.4" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.5" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.35" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.1" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.35" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.55" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.4" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Glow Scale X -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.95" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.1" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.3" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.1" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.8" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Glow Scale Y -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowScale" Storyboard.TargetProperty="ScaleY">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.95" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.1" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.3" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="1.1" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.8" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.0" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>

            <!-- Glow Opacity -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoadingGlow" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.5" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.1" Value="0.6" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="0.45" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.25" KeySpline="0.1,0.9,0.2,1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.6" Value="0.45" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.65" KeySpline="0.8,0,0.9,0.1" />
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.5" KeySpline="0.1,0.9,0.2,1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Name="FadeOutStoryboard">
            <!-- Fade out the LoadingOverlay -->
            <DoubleAnimation Storyboard.TargetName="LoadingOverlay"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.0"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Scale up the LoadingOverlay as it expands away -->
            <DoubleAnimation Storyboard.TargetName="OverlayScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.1"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OverlayScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.1"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Fade in the ContentGrid -->
            <DoubleAnimation Storyboard.TargetName="ContentGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Scale up the ContentGrid with spring overshoot -->
            <DoubleAnimation Storyboard.TargetName="ContentScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.94" To="1.0"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.94" To="1.0"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid x:Name="ContentGrid" Background="Transparent" Opacity="0.0" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="ContentScale" ScaleX="0.94" ScaleY="0.94" />
            </Grid.RenderTransform>
            <!-- Scrollable content: widgets -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,16,20,20" Spacing="20">
                    <!-- Dynamic Widget Grid -->
                    <local:DashboardGridView x:Name="WidgetGridView"
                              SelectionMode="None"
                              HorizontalAlignment="Stretch"
                              Padding="0"
                              CanDragItems="True"
                              CanReorderItems="False"
                              AllowDrop="True"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              DragItemsStarting="WidgetGridView_DragItemsStarting"
                              DragOver="WidgetGridView_DragOver"
                              Drop="WidgetGridView_Drop"
                              SizeChanged="WidgetGridView_SizeChanged"
                              ItemTemplateSelector="{StaticResource WidgetSelector}">

                        <local:DashboardGridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid x:Name="DashboardWrapGrid" Orientation="Horizontal" MaximumRowsOrColumns="2" />
                            </ItemsPanelTemplate>
                        </local:DashboardGridView.ItemsPanel>

                        <local:DashboardGridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="6" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="ContextFlyout">
                                    <Setter.Value>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Size: Small (1x1)" Tag="1x1" Click="WidgetResize_Click"/>
                                            <MenuFlyoutItem Text="Size: Wide (2x1)" Tag="2x1" Click="WidgetResize_Click"/>
                                            <MenuFlyoutItem Text="Size: Tall (1x2)" Tag="1x2" Click="WidgetResize_Click"/>
                                            <MenuFlyoutItem Text="Size: Large (2x2)" Tag="2x2" Click="WidgetResize_Click"/>
                                        </MenuFlyout>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </local:DashboardGridView.ItemContainerStyle>
                    </local:DashboardGridView>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Full-screen Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Background="{ThemeResource LoadingOverlayBgBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Canvas.ZIndex="9999" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="OverlayScale" ScaleX="1.0" ScaleY="1.0" />
            </Grid.RenderTransform>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                <!-- Container for the icon to keep it positioned relative to the ground -->
                <Grid Height="120" Width="120" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Height="80" Width="80" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                        <Image x:Name="LoadingGemIcon" Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,1.0">
                            <Image.Source>
                                <SvgImageSource UriSource="ms-appx:///Assets/GemIcon.svg" RasterizePixelWidth="240" RasterizePixelHeight="240"/>
                            </Image.Source>
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1.0" ScaleY="1.0" />
                                    <TranslateTransform x:Name="IconTranslate" Y="0" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>

                        <!-- Glowing show lights aura over the icon -->
                        <Ellipse x:Name="LoadingGlow" Width="140" Height="140" Fill="{ThemeResource LoadingGlowBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-30" RenderTransformOrigin="0.5,0.5" Opacity="0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="GlowScale" ScaleX="1.0" ScaleY="1.0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                </Grid>
                <!-- Shadow sits on the ground below the grid container -->
                <Ellipse x:Name="LoadingShadow" Width="64" Height="8" Fill="Black" Opacity="0.4" HorizontalAlignment="Center" Margin="0,8,0,0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="ShadowScale" ScaleX="1.0" ScaleY="1.0" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <TextBlock Text="Loading your day..." Foreground="{ThemeResource AppFgColorBrush}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,24,0,0" Opacity="0.75" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
