<Page
    x:Class="Daily_WinUI.Views.HealthDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:chart="using:Syncfusion.UI.Xaml.Charts"
    xmlns:local="using:Daily_WinUI.Views"
    mc:Ignorable="d"
    Background="Transparent" DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Grid Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="850" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <!-- Main Layout adjustments -->
                        <Setter Target="MainCol1.Width" Value="0" />
                        <Setter Target="MainCol2.Width" Value="0" />
                        <Setter Target="HeroBorder.(Grid.ColumnSpan)" Value="3" />
                        <Setter Target="VitalsGrid.(Grid.Row)" Value="1" />
                        <Setter Target="VitalsGrid.(Grid.Column)" Value="0" />
                        <Setter Target="VitalsGrid.(Grid.ColumnSpan)" Value="3" />
                        <Setter Target="VitalsGrid.Margin" Value="0,24,0,0" />

                        <!-- Trends Grid adjustments -->
                        <Setter Target="TrendsCol1.Width" Value="0" />
                        <Setter Target="TrendsCol2.Width" Value="0" />
                        
                        <Setter Target="StepsCard.(Grid.Row)" Value="0" />
                        <Setter Target="StepsCard.(Grid.Column)" Value="0" />
                        <Setter Target="StepsCard.Margin" Value="0" />

                        <Setter Target="HrCard.(Grid.Row)" Value="1" />
                        <Setter Target="HrCard.(Grid.Column)" Value="0" />
                        <Setter Target="HrCard.Margin" Value="0,24,0,0" />

                        <Setter Target="SleepCard.(Grid.Row)" Value="2" />
                        <Setter Target="SleepCard.(Grid.Column)" Value="0" />
                        <Setter Target="SleepCard.Margin" Value="0,24,0,0" />

                        <Setter Target="CaloriesCard.(Grid.Row)" Value="3" />
                        <Setter Target="CaloriesCard.(Grid.Column)" Value="0" />
                        <Setter Target="CaloriesCard.Margin" Value="0,24,0,0" />

                        <Setter Target="WeightCard.(Grid.Row)" Value="4" />
                        <Setter Target="WeightCard.(Grid.Column)" Value="0" />
                        <Setter Target="WeightCard.Margin" Value="0,24,0,0" />

                        <Setter Target="HrvCard.(Grid.Row)" Value="5" />
                        <Setter Target="HrvCard.(Grid.Column)" Value="0" />
                        <Setter Target="HrvCard.Margin" Value="0,24,0,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="110" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Bar with Icon, Title and Action Button -->
        <Grid Grid.Row="0" Padding="20,0" VerticalAlignment="Center" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="20" Background="{ThemeResource AppGlassColorBrush}">
                    <FontIcon Glyph="&#xE95E;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Health" FontSize="32" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}" />
                    <TextBlock Text="Vital metrics and wellness trends" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                </StackPanel>
            </StackPanel>

            <Button x:Name="SyncButton" Grid.Column="2" Content="Force Native Sync" Click="SyncButton_Click" IsEnabled="{x:Bind IsNotSyncing, Mode=OneWay}" />
        </Grid>

        <!-- Scrollable Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                <StackPanel Spacing="24" Padding="20,16,20,20">
                    <Grid x:Name="MainGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="MainCol0" Width="2*" />
                            <ColumnDefinition x:Name="MainCol1" Width="24" />
                            <ColumnDefinition x:Name="MainCol2" Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT COLUMN: Hero (Steps, Cals, Sleep) and Sub-metrics -->
                        <Border x:Name="HeroBorder" Grid.Column="0" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                        <StackPanel Spacing="16">
                            
                            <!-- Hero Metrics Grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Steps -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="STEPS" FontSize="12" Opacity="0.6" Margin="0,0,0,4" HorizontalAlignment="Center" CharacterSpacing="100" />
                                    <TextBlock Text="{x:Bind StepsText, Mode=OneWay}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
                                </StackPanel>

                                <!-- Calories -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="CALORIES" FontSize="12" Opacity="0.6" Margin="0,0,0,4" HorizontalAlignment="Center" CharacterSpacing="100" />
                                    <TextBlock Text="{x:Bind CaloriesText, Mode=OneWay}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FF9800" />
                                </StackPanel>

                                <!-- Sleep -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="SLEEP" FontSize="12" Opacity="0.6" Margin="0,0,0,4" HorizontalAlignment="Center" CharacterSpacing="100" />
                                    <TextBlock Text="{x:Bind SleepText, Mode=OneWay}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#7C4DFF" />
                                </StackPanel>
                            </Grid>

                            <!-- Activity Sub-Metrics -->
                            <Border Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}" CornerRadius="12" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Distance -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE819;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#4CAF50" Margin="0,0,0,4" />
                                        <TextBlock Text="{x:Bind DistanceText, Mode=OneWay}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Floors -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#00BCD4" Margin="0,0,0,4" />
                                        <TextBlock Text="{x:Bind FloorsText, Mode=OneWay}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Speed -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8A4;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#FF9800" Margin="0,0,0,4" />
                                        <TextBlock Text="{x:Bind SpeedText, Mode=OneWay}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT COLUMN: Vitals Grid -->
                    <Grid x:Name="VitalsGrid" Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Heart Rate -->
                        <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xEB51;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="#FF5252" Margin="0,0,0,8" />
                                <TextBlock Text="HEART RATE" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" CharacterSpacing="50" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind HeartRateText, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Weight -->
                        <Border Grid.Row="0" Grid.Column="2" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xECA5;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="#2196F3" Margin="0,0,0,8" />
                                <TextBlock Text="WEIGHT" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" CharacterSpacing="50" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind WeightText, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- HRV -->
                        <Border Grid.Row="2" Grid.Column="0" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xEC92;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="#9C27B0" Margin="0,0,0,8" />
                                <TextBlock Text="HRV" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" CharacterSpacing="50" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind HrvText, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Blood Pressure -->
                        <Border Grid.Row="2" Grid.Column="2" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8D5;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="#FF5252" Margin="0,0,0,8" />
                                <TextBlock Text="BP" FontSize="10" Opacity="0.6" HorizontalAlignment="Center" CharacterSpacing="50" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind BloodPressureText, Mode=OneWay}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Expanded Vitals Row -->
                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- RHR -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="RHR" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind RhrText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- RESP -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="RESP" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind RespText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="3" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- SpO2 -->
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <TextBlock Text="SpO2" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind Spo2Text, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="5" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- GLUCOSE -->
                        <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                            <TextBlock Text="GLUCOSE" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind GlucoseText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Body Composition Row -->
                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- BODY FAT -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="BODY FAT" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind BodyFatText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- BMI -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="BMI" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind BmiText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="3" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- LEAN MASS -->
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <TextBlock Text="LEAN MASS" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind LeanMassText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Sleep Stages Row -->
                <Border Visibility="{x:Bind SleepStagesVisibility, Mode=OneWay}" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                            <FontIcon Glyph="&#xE708;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#7C4DFF" />
                            <TextBlock Text="Sleep Stages" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="DEEP" FontSize="12" Foreground="#3F51B5" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind DeepSleepText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{ThemeResource AppGlassBorderColorBrush}" />

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="LIGHT" FontSize="12" Foreground="#7C4DFF" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind LightSleepText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="3" Background="{ThemeResource AppGlassBorderColorBrush}" />

                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="REM" FontSize="12" Foreground="#00BCD4" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind RemSleepText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border Grid.Column="5" Background="{ThemeResource AppGlassBorderColorBrush}" />

                            <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                <TextBlock Text="AWAKE" FontSize="12" Foreground="#FF9800" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{x:Bind AwakeSleepText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Wellness Row (Mind, Temp, H2O) -->
                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- MIND -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="MIND" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind MindText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- TEMP -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="TEMP" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind TempText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="3" Background="{ThemeResource AppGlassBorderColorBrush}" />

                        <!-- H2O -->
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <TextBlock Text="H2O" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{x:Bind H2oText, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 7-Day Trends Section -->
                <TextBlock Text="7-Day Trends" FontSize="20" FontWeight="SemiBold" Margin="0,16,0,0" />

                <Grid x:Name="TrendsGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="TrendsCol0" Width="*" />
                        <ColumnDefinition x:Name="TrendsCol1" Width="24" />
                        <ColumnDefinition x:Name="TrendsCol2" Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Steps Trend -->
                    <Border x:Name="StepsCard" Grid.Column="0" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                <FontIcon Glyph="&#xE7EE;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#FF9800" />
                                <TextBlock Text="Steps" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>
                            <chart:SfCartesianChart Height="180">
                                <chart:SfCartesianChart.XAxes>
                                    <chart:CategoryAxis ShowMajorGridLines="False" />
                                </chart:SfCartesianChart.XAxes>
                                <chart:SfCartesianChart.YAxes>
                                    <chart:NumericalAxis ShowMajorGridLines="True" />
                                </chart:SfCartesianChart.YAxes>
                                <chart:FastLineSeries ItemsSource="{Binding StepsHistory}" XBindingPath="Label" YBindingPath="Value" Fill="#FF9800" />
                            </chart:SfCartesianChart>

                            <!-- Stats Grid -->
                            <Border Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}" CornerRadius="8" Padding="12,8" Margin="0,12,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="AVG" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind StepsAvgText, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="HIGH" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind StepsMaxText, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="LOW" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind StepsMinText, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="TOTAL" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind StepsTotalText, Mode=OneWay}" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Daily Breakdown -->
                            <TextBlock Text="Daily Breakdown" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AppFgMutedColorBrush}" Margin="0,4,0,4" />
                            <ItemsControl ItemsSource="{Binding StepsHistory}" HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ChartData">
                                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                                            <TextBlock Text="{x:Bind FormattedValue}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                            <Grid Height="50" Width="14" HorizontalAlignment="Center">
                                                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="7" Height="50" Width="14" />
                                                <Border Background="#FF9800" CornerRadius="7" Height="{x:Bind BarHeight, Mode=OneWay}" Width="14" VerticalAlignment="Bottom" />
                                            </Grid>
                                            <TextBlock Text="{x:Bind Label}" FontSize="10" HorizontalAlignment="Center" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Heart Rate Trend -->
                    <Border x:Name="HrCard" Grid.Column="2" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                <FontIcon Glyph="&#xEB51;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#FF5252" />
                                <TextBlock Text="Heart Rate" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>
                            <chart:SfCartesianChart Height="180">
                                <chart:SfCartesianChart.XAxes>
