<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Daily_WinUI.Views.FeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Daily_WinUI.Converters"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:WidgetAgingDurationTooltipConverter x:Key="WidgetAgingDurationTooltipConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:InverseStringToVisibilityConverter x:Key="InverseStringToVisibilityConverter" />
        <DataTemplate x:Key="TinyHeaderTemplate">
            <TextBlock Text="{Binding}" FontSize="11" Opacity="0.8" Margin="0,0,0,2"/>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32">
        <StackPanel MaxWidth="650" HorizontalAlignment="Left" Spacing="24">
            
            <TextBlock Text="Features" FontSize="26" FontWeight="SemiBold" CharacterSpacing="20" Margin="0,0,0,8"/>
            
            <!-- Divider -->
            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- SECTION 1: Local Smart Briefing -->
            <TextBlock Text="Smart Features" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
            
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <RelativePanel>
                        <StackPanel x:Name="AcceleratorTextPanel" Spacing="4" RelativePanel.AlignLeftWithPanel="True" RelativePanel.LeftOf="SettingsAiAcceleratorCombo">
                            <TextBlock Text="Local AI Accelerator" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Select the hardware device for local on-device smart features." FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            
                            <StackPanel Spacing="2" Margin="0,6,0,0">
                                <TextBlock x:Name="SettingsCpuModelText" Text="CPU: Unknown Processor" FontSize="11" Opacity="0.8" TextWrapping="Wrap" />
                                <TextBlock x:Name="SettingsNpuStatusText" Text="NPU: Not Detected" FontSize="11" Opacity="0.8" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                        
                        <ComboBox x:Name="SettingsAiAcceleratorCombo" Width="200" SelectionChanged="SettingsAiAcceleratorCombo_SelectionChanged" RelativePanel.AlignRightWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True" Margin="12,0,0,0" />
                    </RelativePanel>

                    <CheckBox x:Name="UseInternalAiCheckBox"
                              Content="Use Windows built-in AI engine (Phi Silica)"
                              Checked="UseInternalAiCheckBox_Checked"
                              Unchecked="UseInternalAiCheckBox_Unchecked"
                              Margin="0,0,0,0"
                              FontWeight="SemiBold"
                              Visibility="Collapsed" />

                    <!-- Active Status Text (Full Width) with Smart Icon -->
                    <StackPanel x:Name="AiActiveStatusPanel" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <FontIcon Glyph="&#xECA7;" FontSize="14" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="SettingsAiDeviceStatusText" Text="Active AI Backend: Auto | Local Model Missing" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Accelerator Description (Full Width) -->
                    <TextBlock x:Name="SettingsAiAcceleratorDescriptionText" Text="Select an option to view hardware details and recommendations." FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0" />

                    <InfoBar x:Name="LastRunExplanationInfoBar"
                             Severity="Informational"
                             IsOpen="False"
                             IsClosable="True"
                             Visibility="Collapsed"
                             Title="System Calibration Memory"
                             Message="Execution memory is empty."
                             Margin="0,0,0,0" />
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Model Management Header -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Local AI Models" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Select and manage the local LLM weights for offline briefings. Only one model can be active at a time." FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        
                        <!-- Qualcomm NPU Override Info -->
                        <InfoBar x:Name="NpuCopilotRuntimeInfoBar"
                                 Severity="Informational"
                                 IsOpen="False"
                                 IsClosable="False"
                                 Visibility="Collapsed"
                                 Title="Qualcomm Hexagon NPU Active"
                                 Message="Phi Silica runs built-in via the Windows Copilot Runtime. External model downloads and selections are disabled."
                                 Margin="0,8,0,0" />
                        
                        <!-- Accelerator Compatibility / Speed warning InfoBar -->
                        <InfoBar x:Name="HardwareWarningInfoBar"
                                 Severity="Warning"
                                 IsOpen="False"
                                 IsClosable="True"
                                 Visibility="Collapsed"
                                 Title="Configuration Alert"
                                 Message="Warning detail goes here."
                                 Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Models List Container -->
                    <StackPanel x:Name="ModelsContainer" Spacing="12" Margin="0,4,0,0">
                        
                        <!-- Llama 3.2 1B Card -->
                        <Border x:Name="LlamaCard" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Llama 3.2 1B Instruct (INT4)" FontWeight="SemiBold" FontSize="13" />
                                        <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="4" Padding="6,1,6,2" VerticalAlignment="Center" x:Name="LlamaActiveBadge" Visibility="Collapsed">
                                            <TextBlock Text="Active" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Lightweight and fast, optimized for standard summaries. Size: ~670 MB" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    <TextBlock x:Name="LlamaStatusText" Text="Not Downloaded" FontSize="11" FontWeight="SemiBold" Opacity="0.8" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="LlamaDownloadBtn" Content="Download" Click="LlamaDownloadBtn_Click" Style="{ThemeResource AccentButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="LlamaUseBtn" Content="Select" Click="LlamaUseBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="LlamaDeleteBtn" Content="Delete" Click="LlamaDeleteBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" Foreground="#FFFF4B4B" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Qwen 2.5 1.5B Card -->
                        <Border x:Name="QwenCard" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Qwen 2.5 1.5B Instruct (INT4)" FontWeight="SemiBold" FontSize="13" />
                                        <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="4" Padding="6,1,6,2" VerticalAlignment="Center" x:Name="QwenActiveBadge" Visibility="Collapsed">
                                            <TextBlock Text="Active" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Strong reasoning and text generation balance. Size: ~950 MB" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    <TextBlock x:Name="QwenStatusText" Text="Not Downloaded" FontSize="11" FontWeight="SemiBold" Opacity="0.8" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="QwenDownloadBtn" Content="Download" Click="QwenDownloadBtn_Click" Style="{ThemeResource AccentButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="QwenUseBtn" Content="Select" Click="QwenUseBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="QwenDeleteBtn" Content="Delete" Click="QwenDeleteBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" Foreground="#FFFF4B4B" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Gemma 3 1B Card -->
                        <Border x:Name="GemmaCard" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Gemma 3 1B Instruct (INT4)" FontWeight="SemiBold" FontSize="13" />
                                        <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="4" Padding="6,1,6,2" VerticalAlignment="Center" x:Name="GemmaActiveBadge" Visibility="Collapsed">
                                            <TextBlock Text="Active" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="State of the art lightweight language model from Google. Size: ~750 MB" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    <TextBlock x:Name="GemmaStatusText" Text="Not Downloaded" FontSize="11" FontWeight="SemiBold" Opacity="0.8" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="GemmaDownloadBtn" Content="Download" Click="GemmaDownloadBtn_Click" Style="{ThemeResource AccentButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="GemmaUseBtn" Content="Select" Click="GemmaUseBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="GemmaDeleteBtn" Content="Delete" Click="GemmaDeleteBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" Foreground="#FFFF4B4B" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Phi 3.5 Mini Card -->
                        <Border x:Name="PhiCard" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Phi 3.5 Mini Instruct (INT4)" FontWeight="SemiBold" FontSize="13" />
                                        <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="4" Padding="6,1,6,2" VerticalAlignment="Center" x:Name="PhiActiveBadge" Visibility="Collapsed">
                                            <TextBlock Text="Active" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="High quality 3.8B model. Slower on CPU, works best on GPU/NPU. Size: ~2.2 GB" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                    <TextBlock x:Name="PhiStatusText" Text="Not Downloaded" FontSize="11" FontWeight="SemiBold" Opacity="0.8" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="PhiDownloadBtn" Content="Download" Click="PhiDownloadBtn_Click" Style="{ThemeResource AccentButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="PhiUseBtn" Content="Select" Click="PhiUseBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" />
                                    <Button x:Name="PhiDeleteBtn" Content="Delete" Click="PhiDeleteBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="28" Foreground="#FFFF4B4B" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                    </StackPanel>

                    <!-- Single progress area shared by download events -->
                    <StackPanel x:Name="SettingsDownloadProgressGrid" Visibility="Collapsed" Spacing="4">
                        <ProgressBar x:Name="SettingsDownloadProgressBar" Minimum="0" Maximum="100" Value="0" Height="4" Margin="0,4" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                        <Grid>
                            <TextBlock x:Name="SettingsDownloadStatusText" Text="Downloading..." FontSize="11" Opacity="0.7" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Button x:Name="SettingsCancelDownloadBtn" Content="Cancel" Click="SettingsCancelDownloadBtn_Click" Style="{ThemeResource DefaultButtonStyle}" FontSize="11" Height="24" Padding="8,2" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SECTION 2: Smart Briefing Configuration -->
            <TextBlock Text="Smart Briefing" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
            
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Smart Briefing Summary" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Show a personalized on-device AI briefing summary based on your activity." FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="SmartBriefingSwitch" IsOn="True" Toggled="SmartBriefingSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SECTION 3: Smart Behavior Tracking -->
            <TextBlock Text="Smart Behavior" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
            
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Smart Behavior Engine" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Trace user habits, reads, and searches across weather, news, finance, vitals, and habits to build a local semantic profile." FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="SmartBehaviorSwitch" Toggled="SmartBehaviorSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Sync Behavior to Cloud" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Batch synchronize behavior events to Supabase securely for cross-device analysis." FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="SmartBehaviorSyncSwitch" Toggled="SmartBehaviorSyncSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Clear Behavior Data" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Completely erase your tracked behavior events and restart your profile." FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="SettingsClearBehaviorBtn" Content="Clear History" Click="SettingsClearBehaviorBtn_Click" Style="{ThemeResource DefaultButtonStyle}" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SECTION: News Settings -->
            <TextBlock Text="News Settings" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <!-- News Auto-refresh -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="News: Auto-refresh on startup" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Automatically refresh your RSS feed subscriptions upon launching." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="NewsAutoRefreshSwitch" Toggled="NewsAutoRefreshSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <!-- News Show article covers -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="News: Show article covers" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Render cover images for RSS stories in lists and reader view cards." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="NewsShowImagesSwitch" Toggled="NewsShowImagesSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Sub-section: News Feeds -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="News Feeds" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                        <TextBlock Text="Manage and subscribe to RSS or JSON news feeds. Drag to reorder, or click search to discover new feeds." FontSize="11" Opacity="0.6" />

                        <!-- Feed Discover & Add -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <AutoSuggestBox x:Name="FeedSearchBox" 
                                            QueryIcon="Find" 
                                            PlaceholderText="Search feeds by name or enter URL (e.g. techcrunch.com)..." 
                                            QuerySubmitted="FeedSearchBox_QuerySubmitted" 
                                            KeyDown="FeedSearchBox_KeyDown" />
                            <Button Grid.Column="1" x:Name="AddCustomFeedBtn" Content="Add Feed" Click="AddCustomFeedBtn_Click" Style="{ThemeResource DefaultButtonStyle}" />
                        </Grid>

                        <!-- Discovery Progress / Status -->
                        <ProgressBar x:Name="FeedSearchProgressBar" IsIndeterminate="True" Visibility="Collapsed" Height="2" Margin="0,4" />
                        <TextBlock x:Name="FeedSearchStatusText" FontSize="11" Opacity="0.7" Visibility="Collapsed" />

                        <!-- Discovered Feeds List -->
                        <ListView x:Name="DiscoveredFeedsListView" 
                                  SelectionMode="None" 
                                  Visibility="Collapsed" 
                                  MaxHeight="250" 
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                  BorderThickness="1" 
                                  CornerRadius="6" 
                                  Padding="4"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="20" Height="20" VerticalAlignment="Center">
                                            <Image Source="{Binding IconUrl}" Width="20" Height="20" ImageFailed="FeedIcon_ImageFailed"
                                                   Visibility="{Binding IconUrl, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}" />
                                            <FontIcon x:Name="FeedIconFallback" Glyph="&#xEB19;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" 
                                                      Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                      Visibility="{Binding IconUrl, Converter={StaticResource InverseStringToVisibilityConverter}, Mode=OneWay}" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Url}" FontSize="10" Opacity="0.6" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="2" x:Name="CategoryCombo" SelectedIndex="3" Width="120" VerticalAlignment="Center">
                                            <ComboBoxItem Tag="Local">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEAE8;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="Local" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="Markets">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEB43;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="Markets" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="World">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEB54;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="World" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="Tech">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEF8E;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="Tech" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="Coding">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEA77;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="Coding" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="Space">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEC45;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="Space" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem Tag="Other">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xEA45;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                    <TextBlock Text="Other" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                        </ComboBox>
                                        <Button Grid.Column="3" Content="Subscribe" Click="SubscribeDiscoveredFeed_Click" Style="{ThemeResource AccentButtonStyle}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Subscribed Feeds List -->
                        <TextBlock Text="Subscribed Feeds" FontSize="12" FontWeight="SemiBold" Opacity="0.8" Margin="0,8,0,2"/>
                        
                        <ListView x:Name="CurrentFeedsListView" 
                                  CanReorderItems="True" 
                                  AllowDrop="True" 
                                  DragItemsCompleted="CurrentFeedsListView_DragItemsCompleted"
                                  SelectionMode="None"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="4"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,6" ColumnSpacing="12" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Left Icon container -->
                                        <Grid Width="24" Height="24" VerticalAlignment="Center" Margin="4,0">
                                            <Image Source="{Binding IconUrl}" Width="24" Height="24" ImageFailed="FeedIcon_ImageFailed"
                                                   Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                            <FontIcon x:Name="FeedIconFallback" Glyph="&#xEB19;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" 
                                                      Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                      Visibility="{Binding HasIcon, Converter={StaticResource InverseBooleanToVisibilityConverter}, Mode=OneWay}" />
                                        </Grid>
                                        
                                        <!-- Middle: Display vs Edit view -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <!-- Display View (Visible when NOT editing) -->
                                            <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                                    <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Category}" FontSize="9" FontWeight="SemiBold" Foreground="White" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Url}" FontSize="10" Opacity="0.6" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            
                                            <!-- Edit View (Visible when EDITING) -->
                                            <Grid Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" ColumnSpacing="8" RowSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="3*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding EditName, Mode=TwoWay}" PlaceholderText="Name" Header="Feed Name" HeaderTemplate="{StaticResource TinyHeaderTemplate}" FontSize="12"/>
                                                <TextBox Grid.Column="1" Text="{Binding EditUrl, Mode=TwoWay}" PlaceholderText="URL" Header="Feed URL" HeaderTemplate="{StaticResource TinyHeaderTemplate}" FontSize="12"/>
                                                <ComboBox Grid.Column="2" SelectedValue="{Binding EditCategory, Mode=TwoWay}" SelectedValuePath="Tag" Header="Category" HeaderTemplate="{StaticResource TinyHeaderTemplate}" FontSize="12" Width="120">
                                                    <ComboBoxItem Tag="Local">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEAE8;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="Local" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                    <ComboBoxItem Tag="Markets">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEB43;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="Markets" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                    <ComboBoxItem Tag="World">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEB54;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="World" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                    <ComboBoxItem Tag="Tech">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEF8E;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="Tech" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                    <ComboBoxItem Tag="Coding">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEA77;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="Coding" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                    <ComboBoxItem Tag="Space">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEC45;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="Space" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                    <ComboBoxItem Tag="Other">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xEA45;" FontFamily="{StaticResource TablerIconsFont}" FontSize="13" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="Other" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ComboBoxItem>
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                        
                                        <!-- Right Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <!-- Display actions -->
                                            <Button Content="&#xE70F;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Click="EditFeed_Click" ToolTipService.ToolTip="Edit" Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" Height="32" Width="32" Padding="0"/>
                                            <Button Content="&#xE110;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Click="MoveUpFeed_Click" ToolTipService.ToolTip="Move Up" Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" Height="32" Width="32" Padding="0"/>
                                            <Button Content="&#xE1FD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Click="MoveDownFeed_Click" ToolTipService.ToolTip="Move Down" Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" Height="32" Width="32" Padding="0"/>
                                            <Button Content="&#xE74D;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Click="DeleteFeed_Click" ToolTipService.ToolTip="Delete" Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" Height="32" Width="32" Padding="0" Foreground="Red"/>
                                            
                                            <!-- Editing actions -->
                                            <Button Content="&#xE105;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Click="SaveFeed_Click" ToolTipService.ToolTip="Save" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" Height="32" Width="32" Padding="0" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                            <Button Content="&#xE10A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Click="CancelEditFeed_Click" ToolTipService.ToolTip="Cancel" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" Height="32" Width="32" Padding="0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Sub-section: Medium Setup -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Medium Setup" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
                        <TextBlock Text="Link your Medium account to access your Reading List and read Member-only stories." FontSize="11" Opacity="0.6" />

                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock x:Name="MediumStatusText" Text="Status: Not Configured" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="MediumReadingListUrlHelpText" Text="Reading List URL will be automatically configured upon login." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button x:Name="MediumLoginBtn" Content="Login to Medium" Click="MediumLoginBtn_Click" Style="{ThemeResource AccentButtonStyle}"/>
                                <Button x:Name="MediumDisconnectBtn" Content="Disconnect" Click="MediumDisconnectBtn_Click" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                        
                        <TextBox x:Name="MediumReadingListUrlTextBox" 
                                 Header="Reading List URL" 
                                 HeaderTemplate="{StaticResource TinyHeaderTemplate}"
                                 PlaceholderText="https://medium.com/@username/list/reading-list"
                                 FontSize="12" 
                                 LostFocus="MediumReadingListUrlTextBox_LostFocus"
                                 Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SECTION 3: Configurable Traditional Features -->
            <TextBlock Text="Traditional Features" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <!-- Weather -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Weather: Auto location detection" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Always auto-detect your location at startup instead of saving a preferred location." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="WeatherAutoLocationSwitch" Toggled="WeatherAutoLocationSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Weather: Unit system" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Preferred measurement units for temperature and forecast data." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="WeatherUnitSystemCombo" SelectionChanged="WeatherUnitSystemCombo_SelectionChanged" Width="150" VerticalAlignment="Center" Margin="12,0,0,0">
                            <ComboBoxItem Content="Metric (°C, m/s)" Tag="metric" />
                            <ComboBoxItem Content="Imperial (°F, mph)" Tag="imperial" />
                        </ComboBox>
                    </Grid>
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Health -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Health: Enable mock health store" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Simulate vitals history data (steps, heart rate, sleep) for development." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="HealthMockDataSwitch" Toggled="HealthMockDataSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Health: Sleep goal (hours)" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Define your target recovery duration for daily vitals progress tracker." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Slider x:Name="HealthSleepTargetSlider" Minimum="6.0" Maximum="10.0" StepFrequency="0.5" ValueChanged="HealthSleepTargetSlider_ValueChanged" Width="120" SnapsTo="StepValues" />
                            <TextBlock x:Name="HealthSleepTargetLabel" Text="8.0h" FontSize="12" FontWeight="SemiBold" Width="35" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Habits -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Habits: Hydration target (L)" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Daily target water intake for habits tracker logging." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Slider x:Name="HabitsWaterTargetSlider" Minimum="1.0" Maximum="4.0" StepFrequency="0.25" ValueChanged="HabitsWaterTargetSlider_ValueChanged" Width="120" SnapsTo="StepValues" />
                            <TextBlock x:Name="HabitsWaterTargetLabel" Text="2.0L" FontSize="12" FontWeight="SemiBold" Width="35" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Habits: Streak notifications" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Enable reminders and warnings to protect active habit streaks." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="HabitsRemindersSwitch" Toggled="HabitsRemindersSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                    
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Finances -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Finances: Default currency" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Primary ledger currency for asset calculation and charts." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="FinancesCurrencyCombo" SelectionChanged="FinancesCurrencyCombo_SelectionChanged" Width="150" VerticalAlignment="Center" Margin="12,0,0,0">
                            <ComboBoxItem Content="USD ($)" Tag="USD" />
                            <ComboBoxItem Content="EUR (€)" Tag="EUR" />
                            <ComboBoxItem Content="GBP (£)" Tag="GBP" />
                            <ComboBoxItem Content="CAD ($)" Tag="CAD" />
                            <ComboBoxItem Content="RON (lei)" Tag="RON" />
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Finances: Watchlist badges" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Show green/red stock daily percentage change badges in widgets." FontSize="11" Opacity="0.6" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="FinancesShowBadgesSwitch" Toggled="FinancesShowBadgesSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Widget Glass Aging Settings -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Widget glass aging" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock Text="Enable visual aging (fingerprints, dust accumulation) on dashboard widgets as data becomes stale." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="WidgetAgingSwitch" Toggled="WidgetAgingSwitch_Toggled" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Widget glass aging duration" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock Text="Configure how long it takes for widget panels to reach maximum visual aging." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Slider x:Name="WidgetAgingSlider" Minimum="0" Maximum="9" StepFrequency="1" ValueChanged="WidgetAgingSlider_ValueChanged" Width="120" SnapsTo="StepValues" ThumbToolTipValueConverter="{StaticResource WidgetAgingDurationTooltipConverter}" />
                            <TextBlock x:Name="WidgetAgingLabel" Text="30s" FontSize="12" FontWeight="SemiBold" Width="35" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Widget glass grain intensity" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock Text="Configure the intensity of the procedural fractal noise/dust overlay." FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Slider x:Name="WidgetGrainIntensitySlider" Minimum="0" Maximum="100" StepFrequency="5" ValueChanged="WidgetGrainIntensitySlider_ValueChanged" Width="120" SnapsTo="StepValues" />
                            <TextBlock x:Name="WidgetGrainIntensityLabel" Text="50%" FontSize="12" FontWeight="SemiBold" Width="35" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
