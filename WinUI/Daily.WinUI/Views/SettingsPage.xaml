<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Daily_WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    OpenPaneLength="220"
                    CompactModeThresholdWidth="0"
                    ExpandedModeThresholdWidth="0"
                    SelectionFollowsFocus="Disabled"
                    ItemInvoked="NavView_ItemInvoked">

        <NavigationView.MenuItems>

            <!-- ── General ─────────────────────────────── -->
            <NavigationViewItemHeader Content="General" />

            <NavigationViewItem Tag="Appearance" Content="Appearance">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE771;" FontFamily="Segoe Fluent Icons"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem Tag="Notifications" Content="Notifications">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xEA8F;" FontFamily="Segoe Fluent Icons"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- ── Application ─────────────────────────── -->
            <NavigationViewItemHeader Content="Application" />

            <NavigationViewItem Tag="Account" Content="Account">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE77B;" FontFamily="Segoe Fluent Icons"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem Tag="Data" Content="Data &amp; Sync">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8CB;" FontFamily="Segoe Fluent Icons"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- ── About ───────────────────────────────── -->
            <NavigationViewItemHeader Content="About" />

            <NavigationViewItem x:Name="NavAbout" Tag="DayOne" Content="DayOne">
                <NavigationViewItem.Icon>
                    <ImageIcon>
                        <ImageIcon.Source>
                            <SvgImageSource x:Name="DayOneIconSource"
                                            UriSource="ms-appx:///Assets/appicon.theme-dark.svg"
                                            RasterizePixelWidth="32" RasterizePixelHeight="32"/>
                        </ImageIcon.Source>
                    </ImageIcon>
                </NavigationViewItem.Icon>
            </NavigationViewItem>

        </NavigationView.MenuItems>

        <!-- Content frame -->
        <Frame x:Name="ContentFrame" />

    </NavigationView>
</Page>
