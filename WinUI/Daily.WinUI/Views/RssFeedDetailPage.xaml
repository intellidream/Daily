<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.Views.RssFeedDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- State 1: List View -->
        <Grid x:Name="ListViewContainer" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="32,32,32,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="&#xE900;" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="News" FontSize="28" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
                
                <ComboBox Grid.Column="2" x:Name="FeedComboBox" 
                          Width="220" Height="40" 
                          DisplayMemberPath="Name"
                          SelectionChanged="FeedComboBox_SelectionChanged"
                          VerticalAlignment="Center"/>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="32,0,32,32">
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressRing IsActive="True" Width="56" Height="56"/>
                    <TextBlock Text="Fetching latest news..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="16"/>
                </StackPanel>

                <ListView x:Name="ArticlesListView" 
                          SelectionMode="None"
                          ShowsScrollingPlaceholders="False"
                          Visibility="Collapsed"
                          IsItemClickEnabled="True"
                          ItemClick="ArticlesListView_ItemClick"
                          Padding="0,0,0,32">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ListViewItemPresenter 
                                            ContentMargin="0"
                                            PointerOverBackground="Transparent"
                                            SelectedBackground="Transparent"
                                            PressedBackground="Transparent"
                                            SelectedPointerOverBackground="Transparent"
                                            SelectedPressedBackground="Transparent"
                                            FocusBorderBrush="Transparent"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <!-- Use a clean container for the hover effect -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="20"
                                    Margin="0,0,0,24"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Article Thumbnail -->
                                    <Border Width="200" Height="130" CornerRadius="8" Background="{ThemeResource ControlFillColorDisabledBrush}">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Title}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" 
                                                   MaxLines="2" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,12" Spacing="8">
                                            <TextBlock Text="{Binding PublishDate}" 
                                                       FontSize="13" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="•" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Author}" 
                                                       FontSize="13" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                                   
                                        <TextBlock Text="{Binding Description}" 
                                                   FontSize="15" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" 
                                                   MaxLines="3" 
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="22"
                                                   Opacity="0.85"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- State 2: Reader View -->
        <Grid x:Name="ReaderViewContainer" Visibility="Collapsed" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Grid Grid.Row="0" Margin="32,32,32,16" Height="48">
                <Button x:Name="BackButton" Click="BackButton_Click" Style="{StaticResource DefaultButtonStyle}" Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                        <TextBlock Text="Back to List" FontSize="16"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Reader Loading State -->
            <StackPanel Grid.Row="1" x:Name="ReaderLoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="56" Height="56"/>
                <TextBlock Text="Extracting article..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="16"/>
            </StackPanel>

            <!-- WebView2 for Reader Content -->
            <WebView2 x:Name="ReaderWebView" Grid.Row="1" Margin="0" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Page>
