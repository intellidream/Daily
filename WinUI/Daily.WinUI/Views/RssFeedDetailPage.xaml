<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.Views.RssFeedDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- State 1: List View -->
        <Grid x:Name="ListViewContainer" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="24,24,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="&#xE904;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="News" FontSize="24" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                
                <ComboBox Grid.Column="2" x:Name="FeedComboBox" 
                          Width="200" Height="40" 
                          DisplayMemberPath="Name"
                          SelectionChanged="FeedComboBox_SelectionChanged"
                          VerticalAlignment="Center"/>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="24,0,24,24">
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing IsActive="True" Width="48" Height="48"/>
                    <TextBlock Text="Fetching latest news..." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <ListView x:Name="ArticlesListView" 
                          SelectionMode="None"
                          ShowsScrollingPlaceholders="False"
                          Visibility="Collapsed"
                          IsItemClickEnabled="True"
                          ItemClick="ArticlesListView_ItemClick"
                          Padding="0,0,0,24">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,12"
                                    Width="800"
                                    HorizontalAlignment="Left">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Article Thumbnail -->
                                    <Border Width="150" Height="100" CornerRadius="8" Background="{ThemeResource ControlFillColorDisabledBrush}">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Title}" 
                                                   FontSize="18" 
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" 
                                                   MaxLines="2" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <TextBlock Text="{Binding PublishDate}" 
                                                   FontSize="12" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   Margin="0,4,0,8"/>
                                                   
                                        <TextBlock Text="{Binding Description}" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" 
                                                   MaxLines="2" 
                                                   TextTrimming="CharacterEllipsis"
                                                   Opacity="0.8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- State 2: Reader View -->
        <Grid x:Name="ReaderViewContainer" Visibility="Collapsed" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Grid Grid.Row="0" Margin="24,24,24,12" Height="40">
                <Button x:Name="BackButton" Click="BackButton_Click" Style="{StaticResource DefaultButtonStyle}" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <!-- Placeholder for future actions like Save, Favorite -->
                </StackPanel>
            </Grid>

            <!-- Reader Loading State -->
            <StackPanel Grid.Row="1" x:Name="ReaderLoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="Extracting article..." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- WebView2 for Reader Content -->
            <WebView2 x:Name="ReaderWebView" Grid.Row="1" Margin="0" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Page>
