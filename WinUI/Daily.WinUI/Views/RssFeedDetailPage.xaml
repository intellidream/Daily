<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.Views.RssFeedDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Daily_WinUI.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- Dark navy background matching MainPage -->
        <LinearGradientBrush x:Key="RssPageBgBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="0.35" />
            <GradientStop Color="#820B1121" Offset="0.65" />
            <GradientStop Color="#600B1121" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="RssArtOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#000B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SourceItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid Background="Transparent">
                            <!-- Base Glass Pill -->
                            <Border x:Name="Pill" 
                                    Background="{ThemeResource AppGlassColorBrush}" 
                                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="16" 
                                    Padding="12,6"
                                    Margin="2"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="PillScale" ScaleX="1.0" ScaleY="1.0"/>
                                </Border.RenderTransform>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Pill.Background" Value="#30FFFFFF"/>
                                            <Setter Target="Pill.BorderBrush" Value="#60FFFFFF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="PillScale.ScaleX" Value="0.95"/>
                                            <Setter Target="PillScale.ScaleY" Value="0.95"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected"/>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="Pill.Background" Value="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                            <Setter Target="Pill.BorderBrush" Value="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                            <Setter Target="Pill.Translation" Value="0,0,4"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="White"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="SelectedUnfocused">
                                        <VisualState.Setters>
                                            <Setter Target="Pill.Background" Value="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                            <Setter Target="Pill.BorderBrush" Value="{ThemeResource SystemControlForegroundAccentBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="White"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RssItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ListViewItemPresenter
                            ContentMargin="0"
                            PointerOverBackground="Transparent"
                            SelectedBackground="Transparent"
                            PressedBackground="Transparent"
                            SelectedPointerOverBackground="Transparent"
                            SelectedPressedBackground="Transparent"
                            FocusBorderBrush="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="RssItemTemplate" x:DataType="vm:RssItemViewModel">
            <Border Background="{ThemeResource AppGlassColorBrush}"
                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                    BorderThickness="1"
                    Style="{StaticResource GlassPanelStyle}" Translation="0,0,18"
                    CornerRadius="18"
                    Padding="20"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Article Thumbnail -->
                    <Border Width="200" Height="130" CornerRadius="10" Background="{ThemeResource AppGlassSubColorBrush}">
                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource AppFgColorBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,12" Spacing="8" VerticalAlignment="Center">
                            <!-- Publication Logo circular badge -->
                            <Border Width="18" Height="18" CornerRadius="9" Background="White" Padding="1" VerticalAlignment="Center">
                                <Image Source="{Binding PublicationIconUrl}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding PublicationName}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AppFgColorBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="•" Foreground="{ThemeResource AppFgMutedColorBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PublishDate}"
                                       FontSize="13"
                                       Foreground="{ThemeResource AppFgMutedColorBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="•" Foreground="{ThemeResource AppFgMutedColorBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Author}"
                                       FontSize="13"
                                       Foreground="{ThemeResource AppFgMutedColorBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Description}"
                                   FontSize="15"
                                   Foreground="{ThemeResource AppFgColorBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis"
                                   LineHeight="22"/>
                    </StackPanel>

                    <!-- Quick Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="12" VerticalAlignment="Center" Margin="20,0,0,0">
                        <!-- Favorite Button -->
                        <Button Click="FavoriteButton_Click"
                                Width="38" Height="38" 
                                CornerRadius="19"
                                Background="{ThemeResource AppGlassSubColorBrush}"
                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                                BorderThickness="1"
                                Padding="0"
                                ToolTipService.ToolTip="Toggle Favorite">
                            <FontIcon Glyph="{Binding FavoriteGlyph}" 
                                      FontFamily="Segoe Fluent Icons" 
                                      FontSize="16" 
                                      Foreground="{Binding FavoriteBrush}"/>
                        </Button>

                        <!-- Read Later Button -->
                        <Button Click="ReadLaterButton_Click"
                                Width="38" Height="38" 
                                CornerRadius="19"
                                Background="{ThemeResource AppGlassSubColorBrush}"
                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                                BorderThickness="1"
                                Padding="0"
                                ToolTipService.ToolTip="Toggle Read Later">
                            <FontIcon Glyph="{Binding ReadLaterGlyph}" 
                                      FontFamily="Segoe Fluent Icons" 
                                      FontSize="16" 
                                      Foreground="{Binding ReadLaterBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="Transparent">
        <!-- State 1: List View -->
        <Grid x:Name="ListViewContainer" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fixed TopBar Row: icon + title + selector -->
            <Grid Grid.Row="0" Padding="20,16,20,8" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="44" Height="44" CornerRadius="22" Background="{ThemeResource AppGlassColorBrush}" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE736;" FontFamily="Segoe Fluent Icons" FontSize="22" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="News" FontSize="32" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}"/>
                    <TextBlock x:Name="RssSubtitleTextBlock" Text="Latest articles from your selected feed" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}"/>
                </StackPanel>

                <!-- Spin-Wheel Selection Control -->
                <StackPanel x:Name="FeedSelectorContainer" Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <!-- Cycle Left Button -->
                    <Button x:Name="CycleLeftButton" 
                            Click="CycleLeftButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Width="32" Height="36" Padding="0"
                            ToolTipService.ToolTip="Previous Feed">
                        <FontIcon Glyph="&#xE76B;" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </Button>

                    <!-- Center Feed Selector Button -->
                    <Button x:Name="FeedSelectorButton"
                            Background="{ThemeResource AppGlassColorBrush}" 
                            BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                            BorderThickness="1" 
                            CornerRadius="16"
                            Height="36" Padding="12,0"
                            ToolTipService.ToolTip="Select Feed">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9" Background="White" Padding="1" VerticalAlignment="Center">
                                <Image x:Name="SelectedFeedIcon" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="SelectedFeedText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        
                        <Button.Flyout>
                            <MenuFlyout x:Name="FeedMenuFlyout" Placement="Bottom"/>
                        </Button.Flyout>
                    </Button>

                    <!-- Cycle Right Button -->
                    <Button x:Name="CycleRightButton" 
                            Click="CycleRightButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Width="32" Height="36" Padding="0"
                            ToolTipService.ToolTip="Next Feed">
                        <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Scrollable content: article lists within Pivot tabs -->
            <Pivot Grid.Row="1" x:Name="RssPivot" Margin="20,0,0,0" SelectionChanged="RssPivot_SelectionChanged">
                <!-- Tab 1: Live Feed -->
                <PivotItem Header="Live Feed">
                    <Grid>
                        <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                            <ProgressRing IsActive="True" Width="56" Height="56"/>
                            <TextBlock Text="Fetching latest news..." Foreground="{ThemeResource AppFgMutedColorBrush}" FontSize="16"/>
                        </StackPanel>

                        <ListView x:Name="ArticlesListView"
                                  SelectionMode="None"
                                  ShowsScrollingPlaceholders="False"
                                  Visibility="Collapsed"
                                  IsItemClickEnabled="True"
                                  ItemClick="ArticlesListView_ItemClick"
                                  Padding="0,16,20,20"
                                  ItemContainerStyle="{StaticResource RssItemContainerStyle}"
                                  ItemTemplate="{StaticResource RssItemTemplate}"/>
                    </Grid>
                </PivotItem>

                <!-- Tab 2: Read Later -->
                <PivotItem Header="Read Later">
                    <Grid>
                        <TextBlock x:Name="NoReadLaterTextBlock" 
                                   Text="No articles saved for later." 
                                   Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                   FontSize="16" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Visibility="Collapsed"/>

                        <ListView x:Name="ReadLaterListView"
                                  SelectionMode="None"
                                  ShowsScrollingPlaceholders="False"
                                  IsItemClickEnabled="True"
                                  ItemClick="ArticlesListView_ItemClick"
                                  Padding="0,16,20,20"
                                  ItemContainerStyle="{StaticResource RssItemContainerStyle}"
                                  ItemTemplate="{StaticResource RssItemTemplate}"/>
                    </Grid>
                </PivotItem>

                <!-- Tab 3: Favorites -->
                <PivotItem Header="Favorites">
                    <Grid>
                        <TextBlock x:Name="NoFavoritesTextBlock" 
                                   Text="No favorite articles starred." 
                                   Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                   FontSize="16" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Visibility="Collapsed"/>

                        <ListView x:Name="FavoritesListView"
                                  SelectionMode="None"
                                  ShowsScrollingPlaceholders="False"
                                  IsItemClickEnabled="True"
                                  ItemClick="ArticlesListView_ItemClick"
                                  Padding="0,16,20,20"
                                  ItemContainerStyle="{StaticResource RssItemContainerStyle}"
                                  ItemTemplate="{StaticResource RssItemTemplate}"/>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Grid>

        <!-- State 2: Reader View -->
        <Grid x:Name="ReaderViewContainer" Visibility="Collapsed" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="110"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fixed TopBar Row: back button and action buttons -->
            <Grid Grid.Row="0" Padding="20,0" VerticalAlignment="Center">
                <Button x:Name="BackButton" Click="BackButton_Click" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Translation="0,0,18" CornerRadius="14" Padding="14,8" Height="40" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{ThemeResource AppFgColorBrush}"/>
                        <TextBlock Text="Back to List" FontSize="15" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </StackPanel>
                </Button>
                
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <!-- Reader Favorite Button -->
                    <Button x:Name="ReaderFavoriteButton" Click="ReaderFavoriteButton_Click" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Translation="0,0,18" CornerRadius="14" Width="40" Height="40" Padding="0" ToolTipService.ToolTip="Toggle Favorite">
                        <FontIcon x:Name="ReaderFavoriteIcon" Glyph="&#xE734;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </Button>
                    
                    <!-- Reader Read Later Button -->
                    <Button x:Name="ReaderReadLaterButton" Click="ReaderReadLaterButton_Click" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Translation="0,0,18" CornerRadius="14" Width="40" Height="40" Padding="0" ToolTipService.ToolTip="Toggle Read Later">
                        <FontIcon x:Name="ReaderReadLaterIcon" Glyph="&#xE8A4;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Color Ribbon Separator - matches darkest tones from SVG gradients -->
            <Border Grid.Row="1" Height="3" Background="{ThemeResource AppReaderRibbonBrush}"/>

            <!-- Reader Loading State -->
            <StackPanel Grid.Row="2" x:Name="ReaderLoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="56" Height="56"/>
                <TextBlock Text="Extracting article..." Foreground="{ThemeResource AppFgMutedColorBrush}" FontSize="16"/>
            </StackPanel>

            <!-- WebView2 for Reader Content -->
            <WebView2 x:Name="ReaderWebView" Grid.Row="2" Margin="0" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Page>
