<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.Views.RssFeedDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- Dark navy background matching MainPage -->
        <LinearGradientBrush x:Key="RssPageBgBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="0.35" />
            <GradientStop Color="#820B1121" Offset="0.65" />
            <GradientStop Color="#600B1121" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="RssArtOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#000B1121" Offset="0" />
            <GradientStop Color="#FF0B1121" Offset="1" />
        </LinearGradientBrush>

    </Page.Resources>

    <Grid Background="{ThemeResource AppBgBrush}">


        <!-- State 1: List View -->
        <Grid x:Name="ListViewContainer" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="110"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fixed TopBar Row: icon + title + feed selector -->
            <Grid Grid.Row="0" Padding="20,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="44" Height="44" CornerRadius="22" Background="{ThemeResource AppGlassColorBrush}" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE736;" FontFamily="Segoe Fluent Icons" FontSize="22" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="News" FontSize="32" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}"/>
                    <TextBlock Text="Latest articles from your selected feed" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}"/>
                </StackPanel>

                <Border Grid.Column="2" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="14" VerticalAlignment="Center">
                    <ComboBox x:Name="FeedComboBox"
                              Width="220" Height="40"
                              Background="Transparent"
                              BorderThickness="0"
                              DisplayMemberPath="Name"
                              SelectionChanged="FeedComboBox_SelectionChanged"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource AppFgColorBrush}"/>
                </Border>
            </Grid>

            <!-- Scrollable content: article list -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressRing IsActive="True" Width="56" Height="56"/>
                    <TextBlock Text="Fetching latest news..." Foreground="{ThemeResource AppFgMutedColorBrush}" FontSize="16"/>
                </StackPanel>

                <ListView x:Name="ArticlesListView"
                          SelectionMode="None"
                          ShowsScrollingPlaceholders="False"
                          Visibility="Collapsed"
                          IsItemClickEnabled="True"
                          ItemClick="ArticlesListView_ItemClick"
                          Padding="0,0,0,32">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ListViewItemPresenter
                                            ContentMargin="0"
                                            PointerOverBackground="Transparent"
                                            SelectedBackground="Transparent"
                                            PressedBackground="Transparent"
                                            SelectedPointerOverBackground="Transparent"
                                            SelectedPressedBackground="Transparent"
                                            FocusBorderBrush="Transparent"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource AppGlassColorBrush}"
                                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                                    BorderThickness="1"
                                    Style="{StaticResource GlassPanelStyle}" Translation="0,0,18"
                                    CornerRadius="18"
                                    Padding="20"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Article Thumbnail -->
                                    <Border Width="200" Height="130" CornerRadius="10" Background="{ThemeResource AppGlassSubColorBrush}">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{ThemeResource AppFgColorBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,12" Spacing="8">
                                            <TextBlock Text="{Binding PublishDate}"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource AppFgMutedColorBrush}"/>
                                            <TextBlock Text="•" Foreground="{ThemeResource AppFgMutedColorBrush}"/>
                                            <TextBlock Text="{Binding Author}"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource AppFgMutedColorBrush}"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="15"
                                                   Foreground="{ThemeResource AppFgColorBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="3"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="22"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- State 2: Reader View -->
        <Grid x:Name="ReaderViewContainer" Visibility="Collapsed" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="110"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fixed TopBar Row: back button -->
            <Grid Grid.Row="0" Padding="20,0" VerticalAlignment="Center">
                <Button x:Name="BackButton" Click="BackButton_Click" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Translation="0,0,18" CornerRadius="14" Padding="14,8" Height="40" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{ThemeResource AppFgColorBrush}"/>
                        <TextBlock Text="Back to List" FontSize="15" Foreground="{ThemeResource AppFgColorBrush}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Reader Loading State -->
            <StackPanel Grid.Row="1" x:Name="ReaderLoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="56" Height="56"/>
                <TextBlock Text="Extracting article..." Foreground="{ThemeResource AppFgMutedColorBrush}" FontSize="16"/>
            </StackPanel>

            <!-- WebView2 for Reader Content -->
            <WebView2 x:Name="ReaderWebView" Grid.Row="1" Margin="0" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Page>
