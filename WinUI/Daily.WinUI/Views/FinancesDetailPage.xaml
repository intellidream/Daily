<Page
    x:Class="Daily_WinUI.Views.FinancesDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Daily.Models.Finances"
    xmlns:controls="using:Daily_WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:PercentConverter x:Key="PercentConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Bar with Back Button -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Button x:Name="BackButton" Style="{StaticResource NavigationBackButtonNormalStyle}" Click="BackButton_Click" />
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE825;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="Finances" FontSize="24" FontWeight="SemiBold" />
            </StackPanel>

            <Button x:Name="RefreshBtn" Grid.Column="2" Content="Refresh" Click="RefreshBtn_Click" />
        </Grid>

        <!-- Main Content -->
        <Pivot Grid.Row="1" x:Name="MainPivot">
            
            <!-- WORLD / MACRO -->
            <PivotItem Header="World">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                    <StackPanel Spacing="24">
                        
                        <!-- Macro Indicators -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                                    <FontIcon Glyph="&#xE909;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <TextBlock Text="Global Pulse" FontSize="20" FontWeight="SemiBold" />
                                </StackPanel>
                                
                                <!-- Adaptive Grid for Macros -->
                                <ItemsControl ItemsSource="{x:Bind MacroIndicators, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:MacroIndicator">
                                            <Border CornerRadius="12" Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16" Margin="0,0,12,12" Width="280">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{x:Bind Emoji}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Name}" FontSize="16" FontWeight="SemiBold" />
                                                            <TextBlock Text="{x:Bind Pillar}" FontSize="12" Opacity="0.6" />
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold" />
                                                        <TextBlock Grid.Column="1" Text="{x:Bind PercentChange, Converter={StaticResource PercentConverter}}" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                                    </Grid>
                                                    
                                                    <TextBlock Text="{x:Bind Insight}" FontSize="12" Opacity="0.8" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Global Heatmap -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                    <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                    <TextBlock Text="Global Heatmap" FontSize="20" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="Real Interest Rate (Rate - Inflation)" FontSize="12" Opacity="0.6" Margin="0,0,0,16" />
                                
                                <controls:WorldMapControl Data="{x:Bind HeatmapData, Mode=OneWay}" Height="360" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- STOCKS -->
            <PivotItem Header="Stocks">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                    <StackPanel Spacing="24">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                                    <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                    <TextBlock Text="Watchlist" FontSize="20" FontWeight="SemiBold" />
                                </StackPanel>
                                
                                <ListView ItemsSource="{x:Bind WatchlistStocks, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:StockQuote">
                                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="200" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="100" />
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <PersonPicture Grid.Column="0" ProfilePicture="{x:Bind LogoUrl}" DisplayName="{x:Bind Symbol}" Width="32" Height="32" Margin="0,0,16,0" />
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Symbol}" FontSize="16" FontWeight="SemiBold" />
                                                        <TextBlock Text="{x:Bind CompanyName}" FontSize="12" Opacity="0.6" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                        <TextBlock Text="{x:Bind MarketType}" FontSize="12" Opacity="0.6" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                        <TextBlock Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{x:Bind PercentChange, Converter={StaticResource PercentConverter}}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- MONEY -->
            <PivotItem Header="Money">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                    <StackPanel Spacing="24">
                        
                        <!-- Net Worth Hero -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="32">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="NET WORTH" FontSize="14" Opacity="0.6" HorizontalAlignment="Center" CharacterSpacing="100" Margin="0,0,0,8" />
                                <TextBlock Text="{x:Bind NetWorthDisplay, Mode=OneWay}" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemFillColorSuccessBrush}" Margin="0,-12,0,16" />
                                
                                <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="CASH" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind CashDisplay, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#FF0288D1" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="INVESTMENTS" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                                        <TextBlock Text="{x:Bind InvestmentsDisplay, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#FF8E24AA" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Accounts -->
                            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Accounts" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <ListView ItemsSource="{x:Bind Accounts, Mode=OneWay}" SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:LocalAccount">
                                                <Grid Margin="0,0,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{x:Bind Name}" FontSize="16" FontWeight="SemiBold" />
                                                        <TextBlock Text="{x:Bind Type}" FontSize="12" Opacity="0.6" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind CurrentBalance, Converter={StaticResource CurrencyConverter}}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <!-- Portfolio -->
                            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Portfolio Holdings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    <ListView ItemsSource="{x:Bind Holdings, Mode=OneWay}" SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:StockQuote"> <!-- PortfolioItem inherits from StockQuote in models? Actually PortfolioItem is dynamic, let's just bind to properties. -->
                                                <Grid Margin="0,0,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <PersonPicture Grid.Column="0" ProfilePicture="{Binding LogoUrl}" DisplayName="{Binding Symbol}" Width="32" Height="32" Margin="0,0,12,0" />
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Symbol}" FontSize="16" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding CompanyName}" FontSize="12" Opacity="0.6" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
