<Page
    x:Class="Daily_WinUI.Views.FinancesDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Daily.Models.Finances"
    xmlns:controls="using:Daily_WinUI.Controls"
    xmlns:chart="using:Syncfusion.UI.Xaml.Charts"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:PercentConverter x:Key="PercentConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:IndicatorBackgroundConverter x:Key="IndicatorBackgroundConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:IndicatorBorderConverter x:Key="IndicatorBorderConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:IndicatorForegroundConverter x:Key="IndicatorForegroundConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:IndicatorIconConverter x:Key="IndicatorIconConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:HeatmapBackgroundConverter x:Key="HeatmapBackgroundConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:HeatmapBorderConverter x:Key="HeatmapBorderConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:HeatmapForegroundConverter x:Key="HeatmapForegroundConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:CountryFlagConverter x:Key="CountryFlagConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:VolumeFormatConverter x:Key="VolumeFormatConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" xmlns:converters="using:Daily_WinUI.Converters"/>
    </Page.Resources>

    <Grid Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="850" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="WideColumnPlaceholder.Visibility" Value="Visible" />
                        <Setter Target="MoneyScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                        <Setter Target="MoneyEditorBorder.MinHeight" Value="0" />
                        
                        <!-- Editor on left, above Chart -->
                        <Setter Target="MoneyEditorBorder.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyEditorBorder.(Grid.Row)" Value="0" />
                        <Setter Target="MoneyEditorBorder.(Grid.RowSpan)" Value="2" />
                        <Setter Target="MoneyEditorBorder.Margin" Value="0,0,16,16" />
                        
                        <!-- Totals on right, top -->
                        <Setter Target="MoneyTotalsBorder.(Grid.Column)" Value="1" />
                        <Setter Target="MoneyTotalsBorder.(Grid.Row)" Value="0" />
                        <Setter Target="MoneyTotalsBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyTotalsBorder.Margin" Value="0,0,0,16" />
                        
                        <!-- Chat on right, above Transactions -->
                        <Setter Target="MoneyChatBorder.(Grid.Column)" Value="1" />
                        <Setter Target="MoneyChatBorder.(Grid.Row)" Value="1" />
                        <Setter Target="MoneyChatBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyChatBorder.Margin" Value="0,0,0,16" />

                        <!-- Chart on left, bottom -->
                        <Setter Target="MoneyChartPanel.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyChartPanel.(Grid.Row)" Value="2" />
                        <Setter Target="MoneyChartPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyChartPanel.Margin" Value="0,0,16,0" />

                        <!-- Transactions on right, bottom -->
                        <Setter Target="MoneyTransactionsBorder.(Grid.Column)" Value="1" />
                        <Setter Target="MoneyTransactionsBorder.(Grid.Row)" Value="2" />
                        <Setter Target="MoneyTransactionsBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyTransactionsBorder.Margin" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="WideColumnPlaceholder.Visibility" Value="Collapsed" />
                        <Setter Target="MoneyScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                        <Setter Target="MoneyEditorBorder.MinHeight" Value="500" />
                        
                        <!-- Totals on top -->
                        <Setter Target="MoneyTotalsBorder.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyTotalsBorder.(Grid.Row)" Value="0" />
                        <Setter Target="MoneyTotalsBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyTotalsBorder.Margin" Value="0,0,0,16" />
                        
                        <!-- Editor in middle -->
                        <Setter Target="MoneyEditorBorder.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyEditorBorder.(Grid.Row)" Value="1" />
                        <Setter Target="MoneyEditorBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyEditorBorder.Margin" Value="0,0,0,16" />
                        
                        <!-- Chat on bottom -->
                        <Setter Target="MoneyChatBorder.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyChatBorder.(Grid.Row)" Value="2" />
                        <Setter Target="MoneyChatBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyChatBorder.Margin" Value="0,0,0,16" />

                        <!-- Chart on bottom -->
                        <Setter Target="MoneyChartPanel.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyChartPanel.(Grid.Row)" Value="3" />
                        <Setter Target="MoneyChartPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyChartPanel.Margin" Value="0,0,0,16" />

                        <!-- Transactions on bottom -->
                        <Setter Target="MoneyTransactionsBorder.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyTransactionsBorder.(Grid.Row)" Value="4" />
                        <Setter Target="MoneyTransactionsBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="MoneyTransactionsBorder.Margin" Value="0" />

                        <Setter Target="MoneyManualExpander.(Grid.Column)" Value="0" />
                        <Setter Target="MoneyManualExpander.(Grid.Row)" Value="5" />
                        <Setter Target="MoneyManualExpander.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="110" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Bar with Icon, Title and Action Button -->
        <Grid Grid.Row="0" Padding="20,0" VerticalAlignment="Center" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="20" Background="{ThemeResource AppGlassColorBrush}">
                    <FontIcon Glyph="&#xE825;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Finances" FontSize="32" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}" />
                    <TextBlock Text="Portfolio overview and market insights" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                </StackPanel>
            </StackPanel>

            <Button x:Name="RefreshBtn" Grid.Column="2" Content="Refresh" Click="RefreshBtn_Click" />
        </Grid>

        <!-- Main Content -->
        <Pivot Grid.Row="1" x:Name="MainPivot" Margin="20,0,0,0">
            <Pivot.Resources>
                <Thickness x:Key="PivotItemMargin">0</Thickness>
            </Pivot.Resources>
            
            <!-- WORLD / MACRO -->
            <PivotItem Header="World">
                <Grid>
                    <ProgressRing IsActive="{x:Bind IsWorldLoading, Mode=OneWay}" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24" Padding="0,16,20,20">
                        
                        <!-- Macro Indicators -->
                        <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE909;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                        <TextBlock Text="Global Pulse" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="6 Core Pillars" FontSize="12" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Adaptive Grid for Macros -->
                                <ItemsControl ItemsSource="{x:Bind MacroIndicators, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:MacroIndicator">
                                            <Border CornerRadius="12" 
                                                    Background="{x:Bind PercentChange, Converter={StaticResource IndicatorBackgroundConverter}}" 
                                                    BorderBrush="{x:Bind PercentChange, Converter={StaticResource IndicatorBorderConverter}}" 
                                                    BorderThickness="1" Padding="16" Margin="0,0,12,12" MinWidth="280">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Margin="0,0,12,0">
                                                            <TextBlock Text="{x:Bind Emoji}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Name}" FontSize="16" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{x:Bind Pillar}" FontSize="12" Opacity="0.6" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                                                                <FontIcon Glyph="{x:Bind PercentChange, Converter={StaticResource IndicatorIconConverter}}" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{x:Bind PercentChange, Converter={StaticResource IndicatorForegroundConverter}}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind PercentChange, Converter={StaticResource PercentConverter}}" FontSize="12" FontWeight="Bold" Foreground="{x:Bind PercentChange, Converter={StaticResource IndicatorForegroundConverter}}" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <!-- Row 2: Day Range & Insight -->
                                                    <Grid Margin="0,12,0,0" Padding="0,8,0,0" BorderBrush="#1A808080" BorderThickness="0,1,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="1.5*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                                            <TextBlock Text="Day Range" FontSize="10" Opacity="0.5" />
                                                            <TextBlock FontSize="10" FontWeight="Bold">
                                                                <Run Text="{Binding DayLow, TargetNullValue='-'}" /><Run Text=" - " /><Run Text="{Binding DayHigh, TargetNullValue='-'}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="Insight" FontSize="10" Opacity="0.5" HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding Insight, TargetNullValue='-'}" FontSize="10" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Global Heatmap -->
                        <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                        <TextBlock Text="Global Heatmap" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="Real Interest Rate (Rate - Inflation)" FontSize="12" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <controls:WorldMapControl Data="{x:Bind HeatmapData, Mode=OneWay}" Height="360" Margin="0,0,0,16" />

                                <!-- Legend -->
                                <Border Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="12" Padding="12,8" Margin="0,0,0,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Money flows →" FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border Grid.Column="1" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#F44336" Offset="0.0" />
                                                    <GradientStop Color="#FF9800" Offset="0.25" />
                                                    <GradientStop Color="#FFC107" Offset="0.5" />
                                                    <GradientStop Color="#8BC34A" Offset="0.75" />
                                                    <GradientStop Color="#2E7D32" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="Negative" FontSize="11" Foreground="#F44336" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="3" Text="High" FontSize="11" Foreground="#4CAF50" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{x:Bind HeatmapData, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:CountryEconomicData">
                                            <Border CornerRadius="12" 
                                                    Background="{x:Bind RealRate, Converter={StaticResource HeatmapBackgroundConverter}}" 
                                                    BorderBrush="{x:Bind RealRate, Converter={StaticResource HeatmapBorderConverter}}" 
                                                    BorderThickness="1" Padding="12" Margin="0,0,12,12" MinWidth="200">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{x:Bind CountryCode, Converter={StaticResource CountryFlagConverter}}" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind CountryName}" FontSize="14" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{x:Bind CurrencyCode}" FontSize="11" Opacity="0.5" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{x:Bind RealRate, Converter={StaticResource PercentConverter}}" FontSize="16" FontWeight="Bold" Foreground="{x:Bind RealRate, Converter={StaticResource HeatmapForegroundConverter}}" VerticalAlignment="Center" />
                                                    </Grid>
                                                    <Grid Margin="0,4,0,0" BorderBrush="#1A808080" BorderThickness="0,1,0,0" Padding="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                            <TextBlock Text="Interest" FontSize="10" Opacity="0.4" HorizontalAlignment="Center" />
                                                            <TextBlock Text="{x:Bind InterestRate, Converter={StaticResource PercentConverter}}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="-" FontSize="10" Opacity="0.3" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                            <TextBlock Text="Inflation" FontSize="10" Opacity="0.4" HorizontalAlignment="Center" />
                                                            <TextBlock Text="{x:Bind InflationRate, Converter={StaticResource PercentConverter}}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="3" Text="=" FontSize="10" Opacity="0.3" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                                            <TextBlock Text="Real Rate" FontSize="10" Opacity="0.4" HorizontalAlignment="Center" />
                                                            <TextBlock Text="{x:Bind RealRate, Converter={StaticResource PercentConverter}}" FontSize="11" FontWeight="Bold" Foreground="{x:Bind RealRate, Converter={StaticResource HeatmapForegroundConverter}}" HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
                </Grid>
            </PivotItem>

            <!-- STOCKS -->
            <PivotItem Header="Stocks">
                <Grid>
                    <ProgressRing IsActive="{x:Bind IsStocksLoading, Mode=OneWay}" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24" Padding="0,16,20,20">
                        <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                        <TextBlock Text="Watchlist" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Padding="8" CornerRadius="12">
                                        <ToggleButton x:Name="StocksBtn" Content="Stocks" IsChecked="True" Click="MarketType_Click" Tag="stock" CornerRadius="6" Padding="12,4"/>
                                        <ToggleButton x:Name="CryptoBtn" Content="Crypto" Click="MarketType_Click" Tag="crypto" CornerRadius="6" Padding="12,4"/>
                                        <ToggleButton x:Name="ForexBtn" Content="Forex" Click="MarketType_Click" Tag="forex" CornerRadius="6" Padding="12,4"/>
                                    </StackPanel>
                                </Grid>
                                
                                <ListView ItemsSource="{x:Bind WatchlistStocks, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:StockQuote">
                                            <Border CornerRadius="12" 
                                                    Background="{x:Bind PercentChange, Converter={StaticResource IndicatorBackgroundConverter}}" 
                                                    BorderBrush="{x:Bind PercentChange, Converter={StaticResource IndicatorBorderConverter}}" 
                                                    BorderThickness="1" Padding="16" Margin="0,0,0,12">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Margin="0,0,16,0"
                                                                Background="{ThemeResource AppGlassSubColorBrush}"
                                                                BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                                                                BorderThickness="1"
                                                                >
                                                            <Image Source="{Binding LogoUrl}" Stretch="UniformToFill"
                                                                   Width="44" Height="44" />
                                                        </Border>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Symbol}" FontSize="16" FontWeight="SemiBold" />
                                                            <TextBlock Text="{x:Bind CompanyName}" FontSize="12" Opacity="0.6" />
                                                        </StackPanel>
                                                        
                                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                                                <TextBlock Text="{x:Bind CurrentPrice, Converter={StaticResource CurrencyConverter}}" FontSize="16" FontWeight="Bold" />
                                                                <TextBlock Text="{x:Bind Currency}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,0,0,2" VerticalAlignment="Bottom" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                                                                <FontIcon Glyph="{x:Bind PercentChange, Converter={StaticResource IndicatorIconConverter}}" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{x:Bind PercentChange, Converter={StaticResource IndicatorForegroundConverter}}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind PercentChange, Converter={StaticResource PercentConverter}}" FontSize="12" FontWeight="Bold" Foreground="{x:Bind PercentChange, Converter={StaticResource IndicatorForegroundConverter}}" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <Grid Margin="0,12,0,0" Padding="0,8,0,0" BorderBrush="#1A808080" BorderThickness="0,1,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                                            <TextBlock Text="Day Range" FontSize="10" Opacity="0.5" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding DayLow, TargetNullValue='-'}" FontSize="10" FontWeight="Bold" />
                                                                <TextBlock Text=" - " FontSize="10" FontWeight="Bold" />
                                                                <TextBlock Text="{Binding DayHigh, TargetNullValue='-'}" FontSize="10" FontWeight="Bold" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="Volume" FontSize="10" Opacity="0.5" HorizontalAlignment="Right" />
                                                            <TextBlock Text="{x:Bind Volume, Converter={StaticResource VolumeFormatConverter}}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                </Grid>
            </PivotItem>
            <!-- MONEY -->
            <PivotItem Header="Money">
                <Grid>
                    <ProgressRing IsActive="{x:Bind IsMoneyLoading, Mode=OneWay}" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    
                    <ScrollViewer x:Name="MoneyScrollViewer" VerticalScrollBarVisibility="Disabled">
                        <Grid x:Name="MoneyLayoutGrid" Padding="0,16,20,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="250" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <!-- Dummy placeholder to force column 1 width in wide mode -->
                            <Border x:Name="WideColumnPlaceholder" Grid.Column="1" Width="350" Height="0" />
                            
                            <!-- Net Worth Hero -->
                            <Border x:Name="MoneyTotalsBorder" Grid.Row="0" Grid.Column="1" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="16" Padding="32" Margin="0,0,0,16">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="NET WORTH" FontSize="14" Opacity="0.6" HorizontalAlignment="Center" CharacterSpacing="100" Margin="0,0,0,8" />
                                    <TextBlock Text="{x:Bind NetWorthDisplay, Mode=OneWay}" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemFillColorSuccessBrush}" Margin="0,-12,0,16" />
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="CASH" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                                            <TextBlock Text="{x:Bind CashDisplay, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#FF0288D1" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="INVESTMENTS" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                                            <TextBlock Text="{x:Bind InvestmentsDisplay, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#FF8E24AA" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Raw Ledger Editor -->
                            <Border x:Name="MoneyEditorBorder" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,16,0">
                                <TextBox AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" 
                                         Text="{x:Bind SmartLedgerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </Border>

                            <!-- Balances Chart -->
                            <Border x:Name="MoneyChartPanel" Grid.Row="2" Grid.Column="0" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,16,16,0">
                                <Grid>
                                    <TextBlock Text="Asset Allocation" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8" />
                                    <chart:SfCircularChart Margin="0,24,0,0">
                                        <chart:PieSeries ItemsSource="{x:Bind AccountBalances, Mode=OneWay}" 
                                                         XBindingPath="AccountName" 
                                                         YBindingPath="Balance" 
                                                         ShowDataLabels="True">
                                            <chart:PieSeries.DataLabelSettings>
                                                <chart:CircularDataLabelSettings Position="Outside" />
                                            </chart:PieSeries.DataLabelSettings>
                                        </chart:PieSeries>
                                    </chart:SfCircularChart>
                                </Grid>
                            </Border>

                            <!-- AI Chat -->
                            <Border x:Name="MoneyChatBorder" Grid.Row="1" Grid.RowSpan="1" Grid.Column="1" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /> <!-- AI Assistant Title -->
                                        <RowDefinition Height="*" />    <!-- Chat messages -->
                                        <RowDefinition Height="Auto" /> <!-- Input -->
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="Smart AI Assistant" FontWeight="SemiBold" Margin="0,0,0,16" Opacity="0.8" />
                                    
                                    <ScrollViewer x:Name="SmartLedgerChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="SmartLedgerChatPanel" Spacing="8" Padding="0,0,16,0" />
                                    </ScrollViewer>
                                    
                                    <Grid Grid.Row="2" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LedgerChatInput" PlaceholderText="Ask AI or say 'spent 5 at Mega'..." 
                                                 TextWrapping="Wrap" MaxHeight="100" AcceptsReturn="True"
                                                 KeyDown="LedgerChatInput_KeyDown" />
                                        <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}" Margin="8,0,0,0" VerticalAlignment="Bottom"
                                                Click="SendLedgerChatBtn_Click">
                                            <FontIcon Glyph="&#xE122;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Transaction History -->
                            <Border x:Name="MoneyTransactionsBorder" Grid.Row="2" Grid.Column="1" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Transaction History" FontWeight="SemiBold" Margin="0,0,0,16" Opacity="0.8" />
                                    <ListView Grid.Row="1" ItemsSource="{x:Bind LedgerTransactions, Mode=OneWay}" 
                                              SelectionMode="None" Margin="0,0,0,16"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding CreatedAt}" Opacity="0.6" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ActionType}" FontWeight="SemiBold" FontSize="12" Opacity="0.8"/>
                                                        <TextBlock Text="{Binding Target}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="from" Opacity="0.6" Visibility="{Binding Target, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding Source}" Opacity="0.8"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Amount}" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>

                            <!-- User Manual -->
                            <Expander x:Name="MoneyManualExpander" Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" Margin="0,16,0,0"
                                      Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="8">
                                        <FontIcon Glyph="&#xE8FD;" />
                                        <TextBlock Text="Money User Manual" FontWeight="Bold" FontSize="16" />
                                    </StackPanel>
                                </Expander.Header>
                                <Expander.Content>
                                    <StackPanel Spacing="24" Padding="16,24,16,32" MaxWidth="800" HorizontalAlignment="Left">
                                        
                                        <!-- Overview -->
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Money - Smart Ledger" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <TextBlock TextWrapping="Wrap" LineHeight="24">
The Smart Ledger is a hybrid financial tracking tool. You can freely edit your financial data as plain text on the left, or use the AI Assistant on the right to manage your money with natural language. 
The system automatically parses your text, computes your Net Worth, Cash, and Investments, and tracks historical transactions.
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Basic Formatting -->
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="1. Basic Balances" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock TextWrapping="Wrap" LineHeight="24">
You declare accounts and their balances by writing <Run FontWeight="Bold">Account = Value</Run>. You can group them under headers surrounded by double asterisks.
                                            </TextBlock>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
**Cash**<LineBreak/>
Card = 1500<LineBreak/>
Wallet = 300<LineBreak/>
<LineBreak/>
**Investments**<LineBreak/>
Broker = 5000
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>

                                        <!-- Mathematical Expressions & Comments -->
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="2. Expressions &amp; Comments" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock TextWrapping="Wrap" LineHeight="24">
The ledger evaluates math expressions dynamically. Use <Run FontWeight="Bold">//</Run> to add comments. Everything after <Run FontWeight="Bold">//</Run> is safely ignored by the parser but kept for your records.
                                            </TextBlock>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
Card = 1500 - 50 // Groceries<LineBreak/>
Wallet = 300 + 100 // ATM withdrawal<LineBreak/>
Savings = 50 * 12 // Yearly savings
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- Assets & Goals -->
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="3. Asset Tracking &amp; Goals" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock TextWrapping="Wrap" LineHeight="24">
Track assets like stocks or crypto using the <Run FontWeight="Bold">@</Run> symbol for price multiplication. Define financial goals using the <Run FontWeight="Bold">=&gt;</Run> arrow syntax.
                                            </TextBlock>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
Apple = 10 @ 150 // 10 shares at $150 each<LineBreak/>
BTC = 0.5 @ 60000<LineBreak/>
<LineBreak/>
Emergency Fund = 5000 =&gt; 10000 // 50% complete
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- AI Commands -->
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="4. AI Assistant Commands" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock TextWrapping="Wrap" LineHeight="24">
Instead of typing the math yourself, tell the AI Assistant what happened. It will automatically update the ledger and record a transaction in the history!
                                            </TextBlock>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Text="• 'I spent 50 from Card at Mega Image'" />
                                                    <TextBlock Text="• 'Got paid 2000 into Checking'" />
                                                    <TextBlock Text="• 'Transfer 500 from Checking to Savings'" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- Recurring -->
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="5. Recurring Transactions" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock TextWrapping="Wrap" LineHeight="24">
You can ask the AI to schedule recurring transfers or payments. The system will automatically execute them in the background based on the schedule.
                                            </TextBlock>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Text="• 'Schedule 50 from Checking to Savings every month'" />
                                                    <TextBlock Text="• 'Schedule a 10 payment from Card to Netflix every week'" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </PivotItem>

        </Pivot>
    </Grid>




</Page>
