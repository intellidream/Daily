<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Daily_WinUI.Views.DebugSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32">
        <StackPanel MaxWidth="800" HorizontalAlignment="Left" Spacing="24">
            
            <TextBlock Text="AI Debug Diagnostics" FontSize="26" FontWeight="SemiBold" CharacterSpacing="20" Margin="0,0,0,8"/>
            
            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Engine info card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Spacing="6">
                        <TextBlock Text="Active AI Execution Strategy" FontWeight="SemiBold" FontSize="14" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Engine:" Opacity="0.6" FontSize="12"/>
                            <TextBlock x:Name="ActiveEngineText" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Last Execution:" Opacity="0.6" FontSize="12"/>
                            <TextBlock x:Name="LastExecutionText" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="Refresh" Click="RefreshButton_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Error Card (only visible if there is an error) -->
            <Border x:Name="ErrorCard" 
                    Background="#2D1215" 
                    BorderBrush="#FF5252" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="16"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEA39;" FontFamily="Segoe Fluent Icons" Foreground="#FF5252" FontSize="16"/>
                        <TextBlock Text="Last Execution Exception/Error" FontWeight="SemiBold" Foreground="#FF5252" FontSize="14" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="ErrorTextBox" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             FontFamily="Consolas" 
                             FontSize="12"
                             Background="Transparent"
                             BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- System Prompt Expander -->
            <Expander Header="System Prompt" HorizontalAlignment="Stretch">
                <TextBox x:Name="SystemPromptTextBox" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         FontFamily="Consolas" 
                         FontSize="12"
                         MaxHeight="300"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Expander>

            <!-- User Prompt Expander -->
            <Expander Header="User Prompt" HorizontalAlignment="Stretch">
                <TextBox x:Name="UserPromptTextBox" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         FontFamily="Consolas" 
                         FontSize="12"
                         MaxHeight="300"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Expander>

            <!-- Formatted Prompt Expander -->
            <Expander Header="Formatted Prompt (Sent to Model)" HorizontalAlignment="Stretch">
                <TextBox x:Name="FormattedPromptTextBox" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         FontFamily="Consolas" 
                         FontSize="12"
                         MaxHeight="350"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Expander>

            <!-- AI Response Expander -->
            <Expander Header="AI Response / Narrative" HorizontalAlignment="Stretch" IsExpanded="True">
                <TextBox x:Name="ResponseTextBox" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         FontFamily="Consolas" 
                         FontSize="12"
                         MaxHeight="400"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
