<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Daily_WinUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource LoginBackgroundBrush}">
        <!-- Subtle radial glow behind the card -->
        <Ellipse Width="500" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-80,0,0" Opacity="0.08">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{ThemeResource LoginGlowColor}" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0" Width="360">
            
            <!-- App Icon -->
            <Image Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Image.Source>
                    <SvgImageSource UriSource="ms-appx:///Assets/GemIcon.svg" RasterizePixelWidth="288" RasterizePixelHeight="288"/>
                </Image.Source>
            </Image>

            <!-- App Name -->
            <TextBlock Text="DayOne" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" 
                       Foreground="{ThemeResource AppFgColorBrush}" FontFamily="Segoe UI Variable Display" Margin="0,0,0,4"/>
            <TextBlock Text="Your personal dashboard" FontSize="15" HorizontalAlignment="Center" 
                       Foreground="{ThemeResource AppFgMutedColorBrush}" Margin="0,0,0,40"/>

            <!-- Login Card -->
            <Border Background="{ThemeResource AppGlassColorBrush}" CornerRadius="16" Padding="32" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <TextBlock Text="Welcome" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sign in to sync your data across devices" FontSize="14" 
                               Foreground="{ThemeResource AppFgMutedColorBrush}" TextWrapping="Wrap" TextAlignment="Center"/>

                    <!-- Google Sign-In Button -->
                    <Button x:Name="GoogleSignInButton" Click="GoogleSignInButton_Click"
                            HorizontalAlignment="Stretch" Height="48" CornerRadius="8"
                            Background="#FFFFFFFF" Foreground="#FF1F1F1F"
                            BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <!-- Google "G" logo approximation using text -->
                            <FontIcon Glyph="&#xEB4F;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="#FF4285F4"/>
                            <TextBlock Text="Sign in with Google" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Loading State -->
                    <StackPanel x:Name="LoadingPanel" Visibility="Collapsed" HorizontalAlignment="Center" Spacing="12">
                        <ProgressRing IsActive="True" Width="32" Height="32"/>
                        <TextBlock x:Name="StatusText" Text="Opening browser..." FontSize="13" 
                                   Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Error State -->
                    <TextBlock x:Name="ErrorText" Visibility="Collapsed" FontSize="13" 
                               Foreground="{ThemeResource AppErrorBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Skip option -->
            <HyperlinkButton x:Name="SkipButton" Click="SkipButton_Click" 
                             Content="Continue without signing in" 
                             HorizontalAlignment="Center" Margin="0,24,0,0"
                             Foreground="{ThemeResource AppFgMutedColorBrush}" FontSize="13"/>

        </StackPanel>
    </Grid>
</Page>
