<Page x:Class="Daily_WinUI.Views.HabitsDetailPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="using:Daily_WinUI.Views" mc:Ignorable="d" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="24,24,24,0">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="Habits Detail" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
        <ComboBox x:Name="HabitTypeSelector" Grid.Row="1" Margin="24,16,24,0" Width="200" SelectionChanged="HabitTypeSelector_SelectionChanged">
            <ComboBoxItem Content="Water" Tag="water" IsSelected="True" />
            <ComboBoxItem Content="Smokes" Tag="smokes" />
        </ComboBox>
        <ScrollViewer Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Padding="24" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <TextBlock Text="Viewing Date:" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                    <CalendarDatePicker Date="{x:Bind ViewDate, Mode=OneWay}" DateChanged="CalendarDatePicker_DateChanged" Width="200"/>
                </StackPanel>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <StackPanel x:Name="WaterSummaryPanel" Visibility="Visible" Spacing="24">
                            <Grid Height="250" Width="250" HorizontalAlignment="Center">
                                <ProgressRing Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" Value="{x:Bind CurrentProgress, Mode=OneWay}" Width="200" Height="200" IsIndeterminate="False" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" Background="#1A7FF0D5" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ProgressPercentageText, Mode=OneWay}" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="16" Opacity="0.6" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                <Button Content="+250ml" Background="#1A7FF0D5" Foreground="Teal" Click="AddWater_Click" CommandParameter="250" CornerRadius="16"/>
                                <Button Content="+500ml" Background="#1A7FF0D5" Foreground="Teal" Click="AddWater_Click" CommandParameter="500" CornerRadius="16"/>
                                <Button Content="Coffee" Background="#EFEBE9" Foreground="#5D4037" Click="AddCoffee_Click" CornerRadius="16"/>
                                <Button Content="Tea" Background="#F1F8E9" Foreground="#33691E" Click="AddTea_Click" CornerRadius="16"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="SmokesSummaryPanel" Visibility="Collapsed" Spacing="24">
                            <Grid Height="250" Width="250" HorizontalAlignment="Center">
                                <ProgressRing Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" Value="{x:Bind CurrentProgress, Mode=OneWay}" Width="200" Height="200" IsIndeterminate="False" Foreground="#F44336" Background="#1AF44336" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F44336"/>
                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="16" Opacity="0.6" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="4" HorizontalAlignment="Center" Orientation="Horizontal">
                                <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                                    <TextBlock Text="Financials" FontSize="14" FontWeight="SemiBold" Opacity="0.8" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="16" Foreground="Green" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind DaysSinceQuitDisplay, Mode=OneWay}" FontSize="12" Opacity="0.6" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                <Button Content="Cigarette" Background="#F44336" Foreground="White" Click="AddCigarette_Click" CornerRadius="16"/>
                                <Button Content="Vape" Background="#1976D2" Foreground="White" Click="AddVape_Click" CornerRadius="16"/>
                                <Button Content="Rolled" Background="#FBC02D" Foreground="White" Click="AddRolled_Click" CornerRadius="16"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Expander Header="{x:Bind ViewDateText, Mode=OneWay}" HorizontalAlignment="Stretch" ExpandDirection="Down" IsExpanded="True">
                        <ListView ItemsSource="{x:Bind TodaysLogs, Mode=OneWay}" Height="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="0">
                                            <TextBlock Text="{Binding LoggedAt}" Opacity="0.6" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Value}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Unit}" Opacity="0.8" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Metadata}" Opacity="0.5" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                </Border>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Last 7 Days" FontSize="18" FontWeight="SemiBold" Opacity="0.8"/>
                        <ItemsControl ItemsSource="{x:Bind HistoryData, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{Binding Value}">
                                        <Border Background="{ThemeResource SystemControlHighlightAccentBrush}" Width="40" Height="{Binding Value}" CornerRadius="4,4,0,0" MinHeight="4"/>
                                        <TextBlock Text="{Binding DateLabel}" FontSize="12" Opacity="0.6" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Consistency (Last 4 Months)" FontSize="18" FontWeight="SemiBold" Opacity="0.8"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{x:Bind HeatmapData, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VariableSizedWrapGrid Orientation="Vertical" MaximumRowsOrColumns="7" ItemHeight="16" ItemWidth="16" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1" CornerRadius="2" Background="{Binding Color}" ToolTipService.ToolTip="{Binding Tooltip}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Grid x:Name="SettingsGrid" Grid.Row="2" Margin="24,24,24,24" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Expander Header="Settings" ExpandDirection="Up" HorizontalAlignment="Stretch">
                <Grid ColumnSpacing="16" RowSpacing="12" Padding="8,12,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Baseline Daily:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SmokesBaseline, Mode=TwoWay}" PlaceholderText="e.g. 20" MaxWidth="150" HorizontalAlignment="Left" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Pack Size:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SmokesPackSize, Mode=TwoWay}" PlaceholderText="e.g. 20" MaxWidth="150" HorizontalAlignment="Left" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Pack Cost:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SmokesPackCost, Mode=TwoWay}" PlaceholderText="e.g. 10.50" MaxWidth="150" HorizontalAlignment="Left" />
                    <Button Grid.Row="3" Grid.ColumnSpan="2" Content="Save Settings" HorizontalAlignment="Right" Click="SaveSettings_Click" Style="{ThemeResource AccentButtonStyle}"/>
                </Grid>
            </Expander>
        </Grid>
    </Grid>
</Page>
