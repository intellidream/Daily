<Page x:Class="Daily_WinUI.Views.HabitsDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="using:Daily_WinUI.Views"
      xmlns:gauge="using:Syncfusion.UI.Xaml.Gauges"
      xmlns:controls="using:Daily_WinUI.Controls"
      mc:Ignorable="d"
      Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WaterGlassBorderBrush" Color="#CCFFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WaterGlassBorderBrush" Color="#99000000" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Artwork fade-out overlay (mirrors MainPage TopBarOverlayBrush but softer) -->
            <LinearGradientBrush x:Key="DetailArtOverlayBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#00000000" Offset="0" />
                <GradientStop Color="#CC000000" Offset="1" />
            </LinearGradientBrush>

            <!-- Dark navy background — matches MainPage DashboardBackgroundBrush -->
            <LinearGradientBrush x:Key="DetailPageBgBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF0B1121" Offset="0" />
                <GradientStop Color="#FF0B1121" Offset="0.35" />
                <GradientStop Color="#820B1121" Offset="0.65" />
                <GradientStop Color="#600B1121" Offset="1" />
            </LinearGradientBrush>



            <Style TargetType="controls:WaterLevelControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="controls:WaterLevelControl">
                            <Path x:Name="PART_Path"
                                  Fill="{TemplateBinding Background}"
                                  Stroke="{TemplateBinding BorderBrush}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="controls:LungsControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="controls:LungsControl">
                            <Canvas x:Name="PART_Canvas">
                                <Path x:Name="PART_LeftFill"       StrokeThickness="0" />
                                <Path x:Name="PART_RightFill"      StrokeThickness="0" />
                                <Path x:Name="PART_LeftOutline"    StrokeThickness="1.5" />
                                <Path x:Name="PART_RightOutline"   StrokeThickness="1.5" />
                                <Path x:Name="PART_Trachea"        StrokeThickness="1.5" Fill="Transparent" />
                                <Path x:Name="PART_LeftDivision"   StrokeThickness="1.0" Fill="Transparent" />
                                <Path x:Name="PART_RightDivision"  StrokeThickness="1.0" Fill="Transparent" />
                            </Canvas>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Mutable brush updated from code-behind to reflect last-log drink colour -->
            <SolidColorBrush x:Key="LastLogColorBrush" x:Name="LastLogColorBrush" Color="#FF5EB5FF" />

            <DataTemplate x:Key="WaterPointerHandleTemplate">
                <Border Width="72" Height="72" CornerRadius="36"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Top half: always light blue / +150 ml -->
                        <Border Grid.Row="0" Background="#FF5EB5FF" CornerRadius="36,36,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="▲" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="150 ml" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Bottom half: last-log drink colour / last-log amount -->
                        <Border Grid.Row="1" Background="{ThemeResource LastLogColorBrush}" CornerRadius="0,0,36,36">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                <TextBlock x:Name="LastLogMlLabel" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="▼" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Mutable brush updated from code-behind to reflect last smoked type colour -->
            <SolidColorBrush x:Key="SmokesLastLogColorBrush" x:Name="SmokesLastLogColorBrush" Color="#FFF44336" />

            <DataTemplate x:Key="SmokesPointerHandleTemplate">
                <Border Width="72" Height="72" CornerRadius="36"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Top half: always red-orange / +1 -->
                        <Border Grid.Row="0" Background="#FFEF5350" CornerRadius="36,36,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="▲" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="1 cig" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Bottom half: last-smoke-type colour / type label -->
                        <Border Grid.Row="1" Background="{ThemeResource SmokesLastLogColorBrush}" CornerRadius="0,0,36,36">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">
                                <TextBlock x:Name="SmokesLastLogLabel" FontSize="9" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="▼" FontSize="11" Foreground="{ThemeResource AppFgColorBrush}" FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>


    


    <!-- Root grid: artwork layer behind content -->
    <Grid Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="110" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Fixed TopBar Row: icon + title + selectors -->
        <Grid Grid.Row="0" Padding="20,0" VerticalAlignment="Center" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="20" Background="{ThemeResource AppGlassColorBrush}">
                    <FontIcon Glyph="&#xed23;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Habits Detail" FontSize="32" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}" />
                    <TextBlock Text="Desktop-friendly overview with responsive insight cards" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ComboBox x:Name="HabitTypeSelector" Width="180" SelectionChanged="HabitTypeSelector_SelectionChanged">
                    <ComboBoxItem Content="Water" Tag="water" IsSelected="True" />
                    <ComboBoxItem Content="Smokes" Tag="smokes" />
                </ComboBox>
                <CalendarDatePicker Date="{x:Bind ViewDate, Mode=OneWay}" DateChanged="CalendarDatePicker_DateChanged" Width="200" />
            </StackPanel>
        </Grid>

        <!-- Scrollable content: info banner + habits panes -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="20,16,20,20" Spacing="20">

        <Border Background="{ThemeResource AppGlassColorBrush}"
                BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Stretch">
                <FontIcon Glyph="&#xea53;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Use the quick actions below to keep logs close to the MAUI experience, while the charts and consistency cards adapt to the available width." TextWrapping="WrapWholeWords" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- HERO GAUGE SECTION -->
                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="32">
                    <Grid>

                          <gauge:SfRadialGauge x:Name="HeroRadialGauge" Visibility="Collapsed" Width="280" Height="280" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <gauge:SfRadialGauge.Axes>
                                  <gauge:RadialAxis x:Name="HeroRadialAxis" StartAngle="135" EndAngle="405" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowAxisLine="False" TickLengthUnit="Factor" MajorTickLength="0.265" MinorTickLength="0.13" MinorTicksPerInterval="4" TickOffset="0">
                                      <gauge:RadialAxis.Ranges>
                                          <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" StartWidth="0.265" EndWidth="0.265" WidthUnit="Factor" Background="{ThemeResource AppGlassSubColorBrush}" />
                                      </gauge:RadialAxis.Ranges>
                                      <gauge:RadialAxis.Pointers>
                                          <gauge:NeedlePointer Value="{x:Bind CurrentProgress, Mode=OneWay}"
                                                               NeedleFill="{ThemeResource TextFillColorPrimaryBrush}"
                                                               NeedleLength="0.6"
                                                               NeedleStartWidth="1"
                                                               NeedleEndWidth="24"
                                                               KnobFill="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                                               KnobStroke="{ThemeResource TextFillColorPrimaryBrush}"
                                                               KnobStrokeThickness="0.05"
                                                               KnobRadius="0.08"
                                                               TailFill="{ThemeResource TextFillColorPrimaryBrush}"
                                                               TailLength="0.2"
                                                               TailWidth="24" />
                                      </gauge:RadialAxis.Pointers>
                                      <gauge:RadialAxis.Annotations>
                                          <gauge:GaugeAnnotation PositionFactor="0.85" DirectionValue="90">
                                              <gauge:GaugeAnnotation.Content>
                                                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                      <TextBlock Text="{x:Bind HeroMainText, Mode=OneWay}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"  />
                                                      <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                                  </StackPanel>
                                              </gauge:GaugeAnnotation.Content>
                                          </gauge:GaugeAnnotation>
                                      </gauge:RadialAxis.Annotations>
                                  </gauge:RadialAxis>
                              </gauge:SfRadialGauge.Axes>
                          </gauge:SfRadialGauge>

                          <gauge:SfLinearGauge x:Name="WaterLinearGauge" Orientation="Vertical" Visibility="{x:Bind WaterGaugeVisibility, Mode=OneWay}" Width="300" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <gauge:SfLinearGauge.Axis>
                                  <gauge:LinearAxis Maximum="{x:Bind GoalValue, Mode=OneWay}" Interval="500">
                                      <gauge:LinearAxis.LabelTemplate>
                                          <DataTemplate>
                                              <StackPanel Orientation="Horizontal">
                                                  <TextBlock Text="{Binding Text}" />
                                                  <TextBlock Text=" ml" />
                                              </StackPanel>
                                          </DataTemplate>
                                      </gauge:LinearAxis.LabelTemplate>
                                      <gauge:LinearAxis.BarPointers>
                                          <gauge:BarPointer Value="{x:Bind GoalValue, Mode=OneWay}" Background="Transparent" PointerSize="250" Offset="-140">
                                              <gauge:BarPointer.Child>
                                                  <controls:WaterLevelControl BorderBrush="{ThemeResource WaterGlassBorderBrush}" />
                                              </gauge:BarPointer.Child>
                                          </gauge:BarPointer>
                                          <gauge:BarPointer Value="{Binding ElementName=waterShapePointer, Path=Value, Mode=OneWay}" Background="Transparent" PointerSize="250" Offset="-140">
                                              <gauge:BarPointer.Child>
                                                  <controls:WaterLevelControl x:Name="WaterFillControl" FullHeight="420" />
                                              </gauge:BarPointer.Child>
                                          </gauge:BarPointer>
                                      </gauge:LinearAxis.BarPointers>
                                      <gauge:LinearAxis.MarkerPointers>
                                          <gauge:LinearShapePointer x:Name="waterShapePointer"
                                                                    IsInteractive="True"
                                                                    ShapeTemplate="{StaticResource WaterPointerHandleTemplate}"
                                                                    ValueChanged="WaterShapePointer_ValueChanged"
                                                                    ValueChangeCompleted="WaterShapePointer_ValueChangeCompleted" />
                                          <gauge:LinearContentPointer Value="{Binding ElementName=waterShapePointer, Path=Value, Mode=OneWay}" OffsetPoint="-140,0" VerticalAnchor="End">
                                              <gauge:LinearContentPointer.Content>
                                                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                      <TextBlock Text="{x:Bind WaterMlText, Mode=OneWay}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}" />
                                                  </StackPanel>
                                              </gauge:LinearContentPointer.Content>
                                          </gauge:LinearContentPointer>
                                      </gauge:LinearAxis.MarkerPointers>
                                  </gauge:LinearAxis>
                              </gauge:SfLinearGauge.Axis>
                          </gauge:SfLinearGauge>

                          <controls:LungsControl x:Name="SmokesLungsControl"
                                                 Visibility="{x:Bind SmokesLungsVisibility, Mode=OneWay}"
                                                 Width="280" Height="420"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />

                          <!-- Smokes ruler — mirrors the water gauge layout -->
                          <gauge:SfLinearGauge x:Name="SmokesLinearGauge" Orientation="Vertical"
                                               Visibility="{x:Bind SmokesLungsVisibility, Mode=OneWay}"
                                               Width="300" Height="420"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                              <gauge:SfLinearGauge.Axis>
                                  <gauge:LinearAxis Maximum="{x:Bind SmokesBaseline, Mode=OneWay}" Minimum="0"
                                                    Interval="{x:Bind SmokesAxisInterval, Mode=OneWay}"
                                                    TickPosition="Cross">
                                      <gauge:LinearAxis.LabelTemplate>
                                          <DataTemplate>
                                              <TextBlock Text="{Binding Text}" />
                                          </DataTemplate>
                                      </gauge:LinearAxis.LabelTemplate>
                                      <gauge:LinearAxis.MarkerPointers>
                                          <gauge:LinearShapePointer x:Name="smokesShapePointer"
                                                                    IsInteractive="True"
                                                                    ShapeTemplate="{StaticResource SmokesPointerHandleTemplate}"
                                                                    ValueChanged="SmokesShapePointer_ValueChanged"
                                                                    ValueChangeCompleted="SmokesShapePointer_ValueChangeCompleted" />
                                          <gauge:LinearContentPointer Value="{Binding ElementName=smokesShapePointer, Path=Value, Mode=OneWay}"
                                                                      OffsetPoint="-140,0" VerticalAnchor="End">
                                              <gauge:LinearContentPointer.Content>
                                                  <TextBlock x:Name="SmokesCountLabel"
                                                             Text="{x:Bind SmokesCountText, Mode=OneWay}"
                                                             FontSize="22" FontWeight="Bold"
                                                             HorizontalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}" />
                                              </gauge:LinearContentPointer.Content>
                                          </gauge:LinearContentPointer>
                                      </gauge:LinearAxis.MarkerPointers>
                                  </gauge:LinearAxis>
                              </gauge:SfLinearGauge.Axis>
                          </gauge:SfLinearGauge>


                    </Grid>
                </Border>
                
                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                    <Grid>
                        <StackPanel x:Name="WaterSummaryPanel" Visibility="Visible" Spacing="18">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="WaterAdaptiveStates">
                                        <VisualState x:Name="WaterWide">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="960" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="WaterWideLayout.Visibility" Value="Visible" />
                                                <Setter Target="WaterNarrowLayout.Visibility" Value="Collapsed" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid x:Name="WaterWideLayout" Visibility="Collapsed" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="0.85*" />
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="24" Background="{ThemeResource AppGlassSubColorBrush}" Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                                <TextBlock Text="Hydration" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Gauge Removed -->
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ProgressPercentageText, Mode=OneWay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="15" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="24" Background="{ThemeResource AppGlassSubColorBrush}" Padding="18">
                                        <StackPanel Spacing="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Quick Add" FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock Text="Close to the MAUI-style shortcuts" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                            </StackPanel>
                                            <Grid ColumnSpacing="10" RowSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button Grid.Row="0" Grid.Column="0" Click="AddWater_Click" CornerRadius="18" Padding="10" Background="#FF2196F3" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Water" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="0" Grid.Column="1" Click="AddJuice_Click" CornerRadius="18" Padding="10" Background="#FFE91E63" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xef28;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Juice" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="1" Grid.Column="0" Click="AddCoffee_Click" CornerRadius="18" Padding="10" Background="#FFF2994A" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Coffee" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="1" Grid.Column="1" Click="AddTea_Click" CornerRadius="18" Padding="10" Background="#FF27AE60" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xf552;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Tea" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Border CornerRadius="18" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" Padding="12">
                                                <Grid RowSpacing="8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF2D9CDB" />
                                                        <TextBlock Grid.Column="1" Text="Water" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FFF2994A" />
                                                        <TextBlock Grid.Column="1" Text="Coffee" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xf552;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF27AE60" />
                                                        <TextBlock Grid.Column="1" Text="Tea" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Grid.Row="3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Goal" FontSize="11" Opacity="0.55" />
                                                        <TextBlock Grid.Column="1" Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <StackPanel x:Name="WaterNarrowLayout" Spacing="14">
                                    <Border CornerRadius="24" Background="{ThemeResource AppGlassSubColorBrush}" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                                <TextBlock Text="Hydration" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Gauge Removed -->
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ProgressPercentageText, Mode=OneWay}" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Grid ColumnSpacing="10" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Click="AddWater_Click" CornerRadius="18" Padding="10" Background="#FF2196F3" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xea97;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Water" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="0" Grid.Column="1" Click="AddJuice_Click" CornerRadius="18" Padding="10" Background="#FFE91E63" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xef28;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Juice" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="0" Click="AddCoffee_Click" CornerRadius="18" Padding="10" Background="#FFF2994A" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xef0e;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Coffee" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="1" Click="AddTea_Click" CornerRadius="18" Padding="10" Background="#FF27AE60" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xf552;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Tea" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="SmokesSummaryPanel" Visibility="Collapsed" Spacing="18">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="SmokeAdaptiveStates">
                                        <VisualState x:Name="SmokeWide">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="960" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="SmokeWideLayout.Visibility" Value="Visible" />
                                                <Setter Target="SmokeNarrowLayout.Visibility" Value="Collapsed" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid x:Name="SmokeWideLayout" Visibility="Collapsed" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="0.85*" />
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="24" Background="{ThemeResource AppGlassSubColorBrush}" Padding="18">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xebea;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="#FFF44336" />
                                                <TextBlock Text="Smoking" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Gauge Removed -->
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFF44336" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="15" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="24" Background="{ThemeResource AppGlassSubColorBrush}" Padding="18">
                                        <StackPanel Spacing="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Savings" FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock Text="Financial progress and quick actions" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                            </StackPanel>

                                            <Border CornerRadius="18" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" Padding="12">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="#FF43A047" />
                                                    <TextBlock Text="{x:Bind DaysSinceQuitDisplay, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                                </StackPanel>
                                            </Border>

                                            <Grid ColumnSpacing="10" RowSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button Grid.Row="0" Grid.Column="0" Click="AddCigarette_Click" CornerRadius="18" Padding="10" Background="#FFF44336" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Cigarette" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="0" Grid.Column="1" Click="AddHeated_Click" CornerRadius="18" Padding="10" Background="#FF1976D2" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xec2c;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Heated" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                 <Button Grid.Row="1" Grid.Column="0" Click="AddRolled_Click" CornerRadius="18" Padding="10" Background="#FFEF6C00" BorderThickness="0">
                                                     <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                         <FontIcon Glyph="&#xec2b;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                         <TextBlock Text="Rolled" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                     </StackPanel>
                                                 </Button>
                                                <Button Grid.Row="1" Grid.Column="1" Click="AddCigarillo_Click" CornerRadius="18" Padding="10" Background="#FF8E24AA" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xeed2;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Cigarillo" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <StackPanel x:Name="SmokeNarrowLayout" Spacing="14">
                                    <Border CornerRadius="24" Background="{ThemeResource AppGlassSubColorBrush}" Padding="16">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xebea;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="#FFF44336" />
                                                <TextBlock Text="Smoking" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Gauge Removed -->
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFF44336" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border CornerRadius="18" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="#FF43A047" />
                                            <TextBlock Text="{x:Bind DaysSinceQuitDisplay, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnSpacing="10" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Click="AddCigarette_Click" CornerRadius="18" Padding="10" Background="#FFF44336" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xecc4;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Cigarette" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="0" Grid.Column="1" Click="AddHeated_Click" CornerRadius="18" Padding="10" Background="#FF1976D2" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xec2c;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Heated" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="0" Click="AddRolled_Click" CornerRadius="18" Padding="10" Background="#FFEF6C00" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xec2b;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Rolled" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="1" Click="AddCigarillo_Click" CornerRadius="18" Padding="10" Background="#FF8E24AA" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xeed2;" FontFamily="{StaticResource TablerIconsFont}" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                                <TextBlock Text="Cigarillo" FontSize="10" Foreground="{ThemeResource AppFgColorBrush}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="InsightsAdaptiveStates">
                            <VisualState x:Name="InsightsWide">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="960" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="InsightsWideLayout.Visibility" Value="Visible" />
                                    <Setter Target="InsightsNarrowLayout.Visibility" Value="Collapsed" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <Grid x:Name="InsightsWideLayout" Visibility="Collapsed" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xeb6b;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                        <TextBlock Text="Last 7 Days" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind HistoryData, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{Binding Value}">
                                                <Border Background="{ThemeResource SystemControlHighlightAccentBrush}" Width="32" Height="{Binding BarHeight}" CornerRadius="6,6,0,0" MinHeight="8" />
                                                <TextBlock Text="{Binding DateLabel}" FontSize="11" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xea59;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                    <TextBlock Text="Consistency (Last 4 Months)" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" />
                                </StackPanel>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind HeatmapData, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VariableSizedWrapGrid Orientation="Vertical" MaximumRowsOrColumns="7" ItemHeight="16" ItemWidth="16" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="1" CornerRadius="2" Background="{Binding Color}" ToolTipService.ToolTip="{Binding Tooltip}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel x:Name="InsightsNarrowLayout" Spacing="16">
                        <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xeb6b;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                    <TextBlock Text="Last 7 Days" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{x:Bind HistoryData, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{Binding Value}">
                                                <Border Background="{ThemeResource SystemControlHighlightAccentBrush}" Width="28" Height="{Binding BarHeight}" CornerRadius="6,6,0,0" MinHeight="8" />
                                                <TextBlock Text="{Binding DateLabel}" FontSize="11" Foreground="{ThemeResource AppFgMutedColorBrush}" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xea59;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                    <TextBlock Text="Consistency (Last 4 Months)" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" />
                                </StackPanel>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind HeatmapData, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VariableSizedWrapGrid Orientation="Vertical" MaximumRowsOrColumns="7" ItemHeight="16" ItemWidth="16" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="1" CornerRadius="2" Background="{Binding Color}" ToolTipService.ToolTip="{Binding Tooltip}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                    <Expander HorizontalAlignment="Stretch" ExpandDirection="Down" IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xeced;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                <TextBlock Text="{x:Bind ViewDateText, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center" />
                                <Border Background="{ThemeResource AppGlassSubColorBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock Text="{x:Bind LogEntries.Count, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" />
                                </Border>
                            </StackPanel>
                        </Expander.Header>
                        <ListView ItemsSource="{x:Bind LogEntries, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  MaxHeight="340"
                                  Padding="0,4,0,4">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,3" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:LogEntryViewModel">
                                    <Border Background="{ThemeResource AppGlassSubColorBrush}"
                                            BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="10,8"
                                            Margin="0,3">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Colored icon pill -->
                                            <Border Grid.Column="0"
                                                    Width="38" Height="38" CornerRadius="10"
                                                    Background="{Binding PillBrush}">
                                                <FontIcon Glyph="{Binding Icon}"
                                                          FontFamily="{StaticResource TablerIconsFont}"
                                                          FontSize="18"
                                                          Foreground="{Binding AccentBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Label + amount -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource AppFgColorBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Amount}"
                                                           FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                            </StackPanel>

                                            <!-- Time badge -->
                                            <Border Grid.Column="2"
                                                    Background="{ThemeResource AppGlassColorBrush}"
                                                    CornerRadius="8" Padding="8,3"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TimeText}"
                                                           FontSize="12" Foreground="{ThemeResource AppFgMutedColorBrush}"
                                                           FontFamily="Consolas" />
                                            </Border>

                                            <!-- Delete button -->
                                            <Button Grid.Column="3"
                                                    Click="DeleteLog_Click"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="6"
                                                    Width="34" Height="34"
                                                    CornerRadius="8"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.ToolTip="Remove this entry">
                                                <FontIcon Glyph="&#xeb55;"
                                                          FontFamily="{StaticResource TablerIconsFont}"
                                                          FontSize="15"
                                                          Foreground="#FFE57373" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                </Border>

                <Border x:Name="SettingsGrid" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Style="{StaticResource GlassPanelStyle}" Translation="0,0,18" CornerRadius="24" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xeb20;" FontFamily="{StaticResource TablerIconsFont}" FontSize="16" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                            <TextBlock Text="Configuration" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" />
                        </StackPanel>
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Baseline Daily:" VerticalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}" />
                            <NumberBox Grid.Row="0" Grid.Column="1" Value="{Binding SmokesBaseline, Mode=TwoWay}" PlaceholderText="e.g. 20" MaxWidth="170" HorizontalAlignment="Left" SpinButtonPlacementMode="Compact" Minimum="0" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Pack Size:" VerticalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}" />
                            <NumberBox Grid.Row="1" Grid.Column="1" Value="{Binding SmokesPackSize, Mode=TwoWay}" PlaceholderText="e.g. 20" MaxWidth="170" HorizontalAlignment="Left" SpinButtonPlacementMode="Compact" Minimum="1" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Pack Cost:" VerticalAlignment="Center" Foreground="{ThemeResource AppFgColorBrush}" />
                            <NumberBox Grid.Row="2" Grid.Column="1" Value="{Binding SmokesPackCost, Mode=TwoWay}" PlaceholderText="e.g. 10.50" MaxWidth="170" HorizontalAlignment="Left" SpinButtonPlacementMode="Compact" Minimum="0" />
                            <Button Grid.Row="3" Grid.ColumnSpan="2" Content="Save Settings" HorizontalAlignment="Right" Click="SaveSettings_Click" Style="{ThemeResource AccentButtonStyle}" CornerRadius="16" Padding="18,10">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xeb62;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" />
                                            <TextBlock Text="Save Settings" />
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    </Grid>
</Page>









