<Page x:Class="Daily_WinUI.Views.HabitsDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="using:Daily_WinUI.Views"
      xmlns:gauge="using:Syncfusion.UI.Xaml.Gauges"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <FontIcon Glyph="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Habits Detail" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Desktop-friendly overview with responsive insight cards" FontSize="12" Opacity="0.6" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ComboBox x:Name="HabitTypeSelector" Width="180" SelectionChanged="HabitTypeSelector_SelectionChanged">
                    <ComboBoxItem Content="Water" Tag="water" IsSelected="True" />
                    <ComboBoxItem Content="Smokes" Tag="smokes" />
                </ComboBox>
                <CalendarDatePicker Date="{x:Bind ViewDate, Mode=OneWay}" DateChanged="CalendarDatePicker_DateChanged" Width="200" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Stretch">
                <FontIcon Glyph="&#xE787;" FontFamily="Segoe Fluent Icons" FontSize="16" Opacity="0.7" VerticalAlignment="Center" />
                <TextBlock Text="Use the quick actions below to keep logs close to the MAUI experience, while the charts and consistency cards adapt to the available width." TextWrapping="WrapWholeWords" Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                    <Grid>
                        <StackPanel x:Name="WaterSummaryPanel" Visibility="Visible" Spacing="18">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="WaterAdaptiveStates">
                                        <VisualState x:Name="WaterWide">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="960" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="WaterWideLayout.Visibility" Value="Visible" />
                                                <Setter Target="WaterNarrowLayout.Visibility" Value="Collapsed" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid x:Name="WaterWideLayout" Visibility="Collapsed" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="0.85*" />
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                                <TextBlock Text="Hydration" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <gauge:SfRadialGauge Width="210" Height="210">
                                                    <gauge:SfRadialGauge.Axes>
                                                        <gauge:RadialAxis StartAngle="180" EndAngle="360" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowTicks="False" ShowAxisLine="False">
                                                            <gauge:RadialAxis.Ranges>
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" Background="#1A7FF0D5" />
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind CurrentProgress, Mode=OneWay}" Background="{ThemeResource SystemControlHighlightAccentBrush}" />
                                                            </gauge:RadialAxis.Ranges>
                                                        </gauge:RadialAxis>
                                                    </gauge:SfRadialGauge.Axes>
                                                </gauge:SfRadialGauge>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ProgressPercentageText, Mode=OneWay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="15" Opacity="0.65" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="18">
                                        <StackPanel Spacing="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Quick Add" FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock Text="Close to the MAUI-style shortcuts" FontSize="12" Opacity="0.6" />
                                            </StackPanel>
                                            <Grid ColumnSpacing="10" RowSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button Grid.Row="0" Grid.Column="0" Click="AddWaterSmall_Click" CornerRadius="18" Padding="10" Background="{ThemeResource SystemAccentColorDark2}" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="150ml" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="0" Grid.Column="1" Click="AddWaterLarge_Click" CornerRadius="18" Padding="10" Background="#FF1E88E5" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="300ml" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="1" Grid.Column="0" Click="AddCoffee_Click" CornerRadius="18" Padding="10" Background="#FFF2994A" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Coffee" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="1" Grid.Column="1" Click="AddTea_Click" CornerRadius="18" Padding="10" Background="#FF27AE60" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE7C3;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Tea" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Border CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12">
                                                <Grid RowSpacing="8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FF2D9CDB" />
                                                        <TextBlock Grid.Column="1" Text="Water" FontSize="12" Opacity="0.75" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Grid.Row="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FFF2994A" />
                                                        <TextBlock Grid.Column="1" Text="Coffee" FontSize="12" Opacity="0.75" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xE7C3;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FF27AE60" />
                                                        <TextBlock Grid.Column="1" Text="Tea" FontSize="12" Opacity="0.75" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Grid.Row="3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Goal" FontSize="11" Opacity="0.55" />
                                                        <TextBlock Grid.Column="1" Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <StackPanel x:Name="WaterNarrowLayout" Spacing="14">
                                    <Border CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                                                <TextBlock Text="Hydration" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <gauge:SfRadialGauge Width="180" Height="180">
                                                    <gauge:SfRadialGauge.Axes>
                                                        <gauge:RadialAxis StartAngle="180" EndAngle="360" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowTicks="False" ShowAxisLine="False">
                                                            <gauge:RadialAxis.Ranges>
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" Background="#1A7FF0D5" />
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind CurrentProgress, Mode=OneWay}" Background="{ThemeResource SystemControlHighlightAccentBrush}" />
                                                            </gauge:RadialAxis.Ranges>
                                                        </gauge:RadialAxis>
                                                    </gauge:SfRadialGauge.Axes>
                                                </gauge:SfRadialGauge>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ProgressPercentageText, Mode=OneWay}" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="14" Opacity="0.65" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Grid ColumnSpacing="10" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Click="AddWaterSmall_Click" CornerRadius="18" Padding="10" Background="{ThemeResource SystemAccentColorDark2}" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="150ml" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="0" Grid.Column="1" Click="AddWaterLarge_Click" CornerRadius="18" Padding="10" Background="#FF1E88E5" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7A3;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="300ml" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="0" Click="AddCoffee_Click" CornerRadius="18" Padding="10" Background="#FFF2994A" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE81E;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="Coffee" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="1" Click="AddTea_Click" CornerRadius="18" Padding="10" Background="#FF27AE60" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7C3;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="Tea" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="SmokesSummaryPanel" Visibility="Collapsed" Spacing="18">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="SmokeAdaptiveStates">
                                        <VisualState x:Name="SmokeWide">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="960" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="SmokeWideLayout.Visibility" Value="Visible" />
                                                <Setter Target="SmokeNarrowLayout.Visibility" Value="Collapsed" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid x:Name="SmokeWideLayout" Visibility="Collapsed" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="0.85*" />
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="18">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xE95E;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#FFF44336" />
                                                <TextBlock Text="Smoking" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <gauge:SfRadialGauge Width="210" Height="210">
                                                    <gauge:SfRadialGauge.Axes>
                                                        <gauge:RadialAxis StartAngle="180" EndAngle="360" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowTicks="False" ShowAxisLine="False">
                                                            <gauge:RadialAxis.Ranges>
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" Background="#1AF44336" />
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind CurrentProgress, Mode=OneWay}" Background="#FFF44336" />
                                                            </gauge:RadialAxis.Ranges>
                                                        </gauge:RadialAxis>
                                                    </gauge:SfRadialGauge.Axes>
                                                </gauge:SfRadialGauge>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFF44336" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="15" Opacity="0.65" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="18">
                                        <StackPanel Spacing="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Savings" FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock Text="Financial progress and quick actions" FontSize="12" Opacity="0.6" />
                                            </StackPanel>

                                            <Border CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="#FF43A047" />
                                                    <TextBlock Text="{x:Bind DaysSinceQuitDisplay, Mode=OneWay}" FontSize="12" Opacity="0.65" />
                                                </StackPanel>
                                            </Border>

                                            <Grid ColumnSpacing="10" RowSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button Grid.Row="0" Grid.Column="0" Click="AddCigarette_Click" CornerRadius="18" Padding="10" Background="#FFF44336" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE731;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Cigarette" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="0" Grid.Column="1" Click="AddVape_Click" CornerRadius="18" Padding="10" Background="#FF1976D2" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE7C2;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Vape" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="1" Grid.Column="0" Click="AddRolled_Click" CornerRadius="18" Padding="10" Background="#FFEF6C00" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE8AD;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Rolled" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Row="1" Grid.Column="1" Click="AddCigarillo_Click" CornerRadius="18" Padding="10" Background="#FF8E24AA" BorderThickness="0">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE720;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="Cigarillo" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <StackPanel x:Name="SmokeNarrowLayout" Spacing="14">
                                    <Border CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="16">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                                <FontIcon Glyph="&#xE95E;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#FFF44336" />
                                                <TextBlock Text="Smoking" FontSize="16" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <gauge:SfRadialGauge Width="180" Height="180">
                                                    <gauge:SfRadialGauge.Axes>
                                                        <gauge:RadialAxis StartAngle="180" EndAngle="360" Minimum="0" Maximum="{x:Bind GoalValue, Mode=OneWay}" ShowLabels="False" ShowTicks="False" ShowAxisLine="False">
                                                            <gauge:RadialAxis.Ranges>
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind GoalValue, Mode=OneWay}" Background="#1AF44336" />
                                                                <gauge:GaugeRange StartValue="0" EndValue="{x:Bind CurrentProgress, Mode=OneWay}" Background="#FFF44336" />
                                                            </gauge:RadialAxis.Ranges>
                                                        </gauge:RadialAxis>
                                                    </gauge:SfRadialGauge.Axes>
                                                </gauge:SfRadialGauge>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind CurrentProgress, Mode=OneWay}" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFF44336" />
                                                    <TextBlock Text="{x:Bind GoalDisplay, Mode=OneWay}" FontSize="14" Opacity="0.65" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{x:Bind MoneySavedDisplay, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="#FF43A047" />
                                            <TextBlock Text="{x:Bind DaysSinceQuitDisplay, Mode=OneWay}" FontSize="12" Opacity="0.65" />
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnSpacing="10" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" Click="AddCigarette_Click" CornerRadius="18" Padding="10" Background="#FFF44336" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE731;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="Cigarette" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="0" Grid.Column="1" Click="AddVape_Click" CornerRadius="18" Padding="10" Background="#FF1976D2" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE7C2;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="Vape" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="0" Click="AddRolled_Click" CornerRadius="18" Padding="10" Background="#FFEF6C00" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE8AD;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="Rolled" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="1" Click="AddCigarillo_Click" CornerRadius="18" Padding="10" Background="#FF8E24AA" BorderThickness="0">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE720;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="Cigarillo" FontSize="10" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="InsightsAdaptiveStates">
                            <VisualState x:Name="InsightsWide">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="960" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="InsightsWideLayout.Visibility" Value="Visible" />
                                    <Setter Target="InsightsNarrowLayout.Visibility" Value="Collapsed" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <Grid x:Name="InsightsWideLayout" Visibility="Collapsed" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.25*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="16" Opacity="0.75" />
                                        <TextBlock Text="Last 7 Days" FontSize="18" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind HistoryData, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{Binding Value}">
                                                <Border Background="{ThemeResource SystemControlHighlightAccentBrush}" Width="32" Height="{Binding BarHeight}" CornerRadius="6,6,0,0" MinHeight="8" />
                                                <TextBlock Text="{Binding DateLabel}" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8E1;" FontFamily="Segoe Fluent Icons" FontSize="16" Opacity="0.75" />
                                    <TextBlock Text="Consistency (Last 4 Months)" FontSize="18" FontWeight="SemiBold" />
                                </StackPanel>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind HeatmapData, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VariableSizedWrapGrid Orientation="Vertical" MaximumRowsOrColumns="7" ItemHeight="16" ItemWidth="16" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="1" CornerRadius="2" Background="{Binding Color}" ToolTipService.ToolTip="{Binding Tooltip}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel x:Name="InsightsNarrowLayout" Spacing="16">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="16" Opacity="0.75" />
                                    <TextBlock Text="Last 7 Days" FontSize="18" FontWeight="SemiBold" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{x:Bind HistoryData, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Bottom" ToolTipService.ToolTip="{Binding Value}">
                                                <Border Background="{ThemeResource SystemControlHighlightAccentBrush}" Width="28" Height="{Binding BarHeight}" CornerRadius="6,6,0,0" MinHeight="8" />
                                                <TextBlock Text="{Binding DateLabel}" FontSize="11" Opacity="0.6" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8E1;" FontFamily="Segoe Fluent Icons" FontSize="16" Opacity="0.75" />
                                    <TextBlock Text="Consistency (Last 4 Months)" FontSize="18" FontWeight="SemiBold" />
                                </StackPanel>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{x:Bind HeatmapData, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VariableSizedWrapGrid Orientation="Vertical" MaximumRowsOrColumns="7" ItemHeight="16" ItemWidth="16" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="1" CornerRadius="2" Background="{Binding Color}" ToolTipService.ToolTip="{Binding Tooltip}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                    <Expander Header="{x:Bind ViewDateText, Mode=OneWay}" HorizontalAlignment="Stretch" ExpandDirection="Down" IsExpanded="True">
                        <ListView ItemsSource="{x:Bind TodaysLogs, Mode=OneWay}" Height="220" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="0">
                                            <TextBlock Text="{Binding LoggedAt}" Opacity="0.6" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Value}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Unit}" Opacity="0.8" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Metadata}" Opacity="0.5" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Click="DeleteLog_Click" Background="Transparent" BorderThickness="0" Padding="8" HorizontalAlignment="Right">
                                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                </Border>

                <Border x:Name="SettingsGrid" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="24" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE115;" FontFamily="Segoe Fluent Icons" FontSize="16" Opacity="0.75" />
                            <TextBlock Text="Configuration" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Baseline Daily:" VerticalAlignment="Center" />
                            <NumberBox Grid.Row="0" Grid.Column="1" Value="{Binding SmokesBaseline, Mode=TwoWay}" PlaceholderText="e.g. 20" MaxWidth="170" HorizontalAlignment="Left" SpinButtonPlacementMode="Compact" Minimum="0" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Pack Size:" VerticalAlignment="Center" />
                            <NumberBox Grid.Row="1" Grid.Column="1" Value="{Binding SmokesPackSize, Mode=TwoWay}" PlaceholderText="e.g. 20" MaxWidth="170" HorizontalAlignment="Left" SpinButtonPlacementMode="Compact" Minimum="1" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Pack Cost:" VerticalAlignment="Center" />
                            <NumberBox Grid.Row="2" Grid.Column="1" Value="{Binding SmokesPackCost, Mode=TwoWay}" PlaceholderText="e.g. 10.50" MaxWidth="170" HorizontalAlignment="Left" SpinButtonPlacementMode="Compact" Minimum="0" />
                            <Button Grid.Row="3" Grid.ColumnSpan="2" Content="Save Settings" HorizontalAlignment="Right" Click="SaveSettings_Click" Style="{ThemeResource AccentButtonStyle}" CornerRadius="16" Padding="18,10">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                            <TextBlock Text="Save Settings" />
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
