<Page
    x:Class="Daily_WinUI.Views.CalendarDetailPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Daily_WinUI.Views"
    xmlns:scheduler="using:Syncfusion.UI.Xaml.Scheduler"
    xmlns:converters="using:Daily_WinUI.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    SizeChanged="Page_SizeChanged">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:IsTodayToVisibilityConverter x:Key="IsTodayToVisibilityConverter" />
        <converters:IsTodayToBrushConverter x:Key="IsTodayToBrushConverter" />
        <converters:TodayBackgroundGlowConverter x:Key="TodayBackgroundGlowConverter" />
        <converters:TodayCircleBadgeBrushConverter x:Key="TodayCircleBadgeBrushConverter" />
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Top Header Area (Shared spanned across columns) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Padding="20,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ToggleButton x:Name="ToggleSidebarBtn" IsChecked="True" Checked="ToggleSidebar_Checked" Unchecked="ToggleSidebar_Unchecked" Width="40" Height="40" CornerRadius="20" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Padding="0" ToolTipService.ToolTip="Toggle Sidebar">
                    <FontIcon Glyph="&#xE787;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" />
                </ToggleButton>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Calendar &amp; Tasks" FontSize="26" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}" />
                    <TextBlock Text="Manage connected calendars and track daily appointments" FontSize="11" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Left Sidebar: Accounts Panel Container -->
        <Grid Grid.Row="1" Grid.Column="0"
              x:Name="SidebarContainer"
              Width="360"
              HorizontalAlignment="Left"
              Background="Transparent">
            <Border x:Name="SidebarPanel"
                    Width="340"
                    HorizontalAlignment="Left"
                    Margin="20,0,0,20"
                    Background="{ThemeResource AppGlassColorBrush}" 
                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                    BorderThickness="1" 
                    CornerRadius="12"
                    Padding="16,20">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SidebarTranslate" X="0" />
                </Border.RenderTransform>
            <Grid HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Connected title -->
                <TextBlock Grid.Row="0" Text="Connected Accounts" FontSize="14" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,14" />

                <!-- Accounts List -->
                <ListView x:Name="AccountsListView" Grid.Row="1"
                          ItemsSource="{x:Bind Accounts, Mode=OneWay}"
                          CanDragItems="True"
                          CanReorderItems="True"
                          AllowDrop="True"
                          ReorderMode="Enabled"
                          SelectionMode="None"
                          DragItemsCompleted="Accounts_DragItemsCompleted"
                          DragItemsStarting="Accounts_DragItemsStarting"
                          Background="Transparent"
                          Padding="0"
                          Margin="0,0,0,16"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:DisplayAccount">
                                <Border Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10"
                                        PointerEntered="AccountCard_PointerEntered" PointerExited="AccountCard_PointerExited">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Provider Icon -->
                                        <Border Grid.Column="0" Grid.Row="0" Width="32" Height="32" CornerRadius="16" Background="{x:Bind ColorBrush, Mode=OneWay}" Margin="0,0,10,0">
                                            <FontIcon Glyph="{x:Bind IconGlyph}" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Name/Email Display (View Mode) -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="{x:Bind ViewModeVisibility, Mode=OneWay}">
                                            <!-- If custom name is NOT set -->
                                            <StackPanel Visibility="{x:Bind NoCustomNameVisibility, Mode=OneWay}">
                                                <TextBlock Text="{x:Bind Email, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppFgColorBrush}" />
                                                <TextBlock Text="{x:Bind IdentifiedName, Mode=OneWay}" FontSize="10" Opacity="0.5" Foreground="{ThemeResource AppFgColorBrush}" />
                                            </StackPanel>

                                            <!-- If custom name IS set -->
                                            <StackPanel Visibility="{x:Bind CustomNameVisibility, Mode=OneWay}">
                                                <TextBlock Text="{x:Bind CustomName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppFgColorBrush}" />
                                                <TextBlock Text="{x:Bind Email, Mode=OneWay}" FontSize="10" Opacity="0.7" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppFgColorBrush}" />
                                                <TextBlock Text="{x:Bind IdentifiedName, Mode=OneWay}" FontSize="9" Opacity="0.4" Foreground="{ThemeResource AppFgColorBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Edit Custom Name (Edit Mode) -->
                                        <Grid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,0,0" Visibility="{x:Bind EditModeVisibility, Mode=OneWay}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{x:Bind CustomName, Mode=OneWay}" PlaceholderText="Custom Name" FontSize="11" Height="28" Padding="6,2" VerticalAlignment="Center" Margin="0,0,4,0" KeyDown="CustomNameTextBox_KeyDown" />
                                            <Button Grid.Column="1" Width="26" Height="26" Padding="0" Background="Transparent" BorderThickness="0" CornerRadius="13" Click="SaveCustomName_Click" ToolTipService.ToolTip="Save" VerticalAlignment="Center" Margin="0,0,2,0">
                                                <FontIcon Glyph="&#xE8FB;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="#00A389" />
                                            </Button>
                                            <Button Grid.Column="2" Width="26" Height="26" Padding="0" Background="Transparent" BorderThickness="0" CornerRadius="13" Click="CancelEdit_Click" ToolTipService.ToolTip="Cancel" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                                            </Button>
                                        </Grid>

                                        <!-- Right side controls (View Mode) -->
                                        <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Visibility="{x:Bind ViewModeVisibility, Mode=OneWay}">
                                            <Button Background="Transparent" BorderThickness="0" Padding="4" Click="EditAccount_Click" ToolTipService.ToolTip="Edit Custom Name">
                                                <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}" />
                                            </Button>
                                            <ToggleSwitch IsOn="{x:Bind IsActive, Mode=OneWay}" Toggled="AccountActive_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            <Button Background="Transparent" BorderThickness="0" Padding="4" Click="DeleteAccount_Click" ToolTipService.ToolTip="Disconnect Account">
                                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppErrorBrush}" />
                                            </Button>
                                        </StackPanel>

                                        <!-- Row 1: Colors & Drag Handle (Spanning all columns) -->
                                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Preset Color Dots Selection -->
                                            <ItemsControl Grid.Column="0" ItemsSource="{x:Bind Presets, Mode=OneWay}" VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="6" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:ColorPresetItem">
                                                        <!-- Outer selection ring container -->
                                                        <Border Width="24" Height="24" CornerRadius="12" Padding="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                BorderBrush="{ThemeResource AppFgColorBrush}"
                                                                BorderThickness="{x:Bind SelectionThickness, Mode=OneWay}">
                                                            <Button Width="18" Height="18" Padding="0" CornerRadius="9" BorderThickness="0" Click="ColorPreset_Click" Tag="{x:Bind Account}" DataContext="{x:Bind Color}">
                                                                <Button.Background>
                                                                    <SolidColorBrush Color="{Binding}" />
                                                                </Button.Background>
                                                            </Button>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Drag Handle / Reorder Indicator -->
                                            <FontIcon Grid.Column="1" Glyph="&#xE700;" FontFamily="Segoe Fluent Icons" FontSize="12" 
                                                      Foreground="{ThemeResource AppFgMutedColorBrush}" 
                                                      Opacity="{x:Bind DragHandleOpacity, Mode=OneWay}" 
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" ToolTipService.ToolTip="Drag to reorder" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                <!-- Bottom Panel: Add new connections (Expander) -->
                <Expander Grid.Row="2"
                          Header="Add New Account"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Background="Transparent"
                          BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          IsExpanded="False"
                          Padding="0">
                    <Expander.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <StaticResource x:Key="ExpanderHeaderBackground" ResourceKey="AppGlassSubColorBrush" />
                                    <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="AppGlassBorderColorBrush" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="Default">
                                    <StaticResource x:Key="ExpanderHeaderBackground" ResourceKey="AppGlassSubColorBrush" />
                                    <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="AppGlassBorderColorBrush" />
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>
                        </ResourceDictionary>
                    </Expander.Resources>
                    <Grid Padding="12" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Click="ConnectGoogle_Click" HorizontalAlignment="Stretch" Height="80" CornerRadius="8" Background="#1EEA4335" BorderBrush="#45EA4335" BorderThickness="1" Padding="0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                <FontIcon Glyph="&#xEC1F;" FontFamily="{StaticResource TablerIconsFont}" FontSize="20" Foreground="#EA4335" HorizontalAlignment="Center" />
                                <TextBlock Text="Google" FontSize="12" FontWeight="SemiBold" Foreground="#EA4335" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Click="ConnectMicrosoft_Click" HorizontalAlignment="Stretch" Height="80" CornerRadius="8" Background="#1E0078D4" BorderBrush="#450078D4" BorderThickness="1" Padding="0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                <FontIcon Glyph="&#xECD8;" FontFamily="{StaticResource TablerIconsFont}" FontSize="20" Foreground="#0078D4" HorizontalAlignment="Center" />
                                <TextBlock Text="Microsoft" FontSize="12" FontWeight="SemiBold" Foreground="#0078D4" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" Click="ConnectYahoo_Click" HorizontalAlignment="Stretch" Height="80" CornerRadius="8" Background="#1E512BD4" BorderBrush="#45512BD4" BorderThickness="1" Padding="0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                <FontIcon Glyph="&#xED73;" FontFamily="{StaticResource TablerIconsFont}" FontSize="20" Foreground="#512BD4" HorizontalAlignment="Center" />
                                <TextBlock Text="Yahoo" FontSize="12" FontWeight="SemiBold" Foreground="#512BD4" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Expander>
            </Grid>
        </Border>
    </Grid>

        <Grid Grid.Row="1" Grid.Column="1" Padding="20,0,20,20" x:Name="SchedulerContainer">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SchedulerTranslate" X="0" />
            </Grid.RenderTransform>
            <!-- Glassy Border Container -->
            <Border Background="{ThemeResource AppGlassColorBrush}"
                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Style="{StaticResource GlassPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Custom Scheduler Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,14" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left side: Navigation Arrows & Today + Date Selector -->
                        <StackPanel x:Name="HeaderLeftStackPanel" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <!-- Navigation Controls -->
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Click="Prev_Click" Width="32" Height="32" Padding="0" CornerRadius="6" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" ToolTipService.ToolTip="Previous">
                                    <FontIcon Glyph="&#xE76B;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}" />
                                </Button>
                                
                                <Button x:Name="TodayBtn" Click="Today_Click" Height="32" CornerRadius="6" Padding="16,0" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" ToolTipService.ToolTip="Today">
                                    <Grid>
                                        <TextBlock x:Name="TodayText" Text="Today" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center" />
                                        <FontIcon x:Name="TodayIcon" Glyph="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>
                                </Button>

                                <Button Click="Next_Click" Width="32" Height="32" Padding="0" CornerRadius="6" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" ToolTipService.ToolTip="Next">
                                    <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}" />
                                </Button>
                            </StackPanel>

                            <!-- Date Range Selector Button with Flyout Calendar -->
                            <Button x:Name="SchedulerDateButton" Background="Transparent" BorderThickness="0" Padding="8,0,8,0" VerticalAlignment="Center" CornerRadius="6" Height="32">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock x:Name="SchedulerDateText" FontSize="18" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center" />
                                        <FontIcon Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}" VerticalAlignment="Center" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Button.Content>
                                <Button.Flyout>
                                    <Flyout x:Name="CalendarFlyout">
                                        <CalendarView x:Name="HeaderCalendarView" SelectedDatesChanged="HeaderCalendarView_SelectedDatesChanged" SelectionMode="Single" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <!-- Right side: View Switcher Pane & Refresh Button -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="2" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Padding="2" CornerRadius="6" Height="32" VerticalAlignment="Center">
                                <Button x:Name="DayViewBtn" Click="ViewSwitcher_Click" Tag="Day" Content="Day" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                                <Button x:Name="WeekViewBtn" Click="ViewSwitcher_Click" Tag="Week" Content="Week" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                                <Button x:Name="WorkWeekViewBtn" Click="ViewSwitcher_Click" Tag="WorkWeek" Content="Work" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                                <Button x:Name="MonthViewBtn" Click="ViewSwitcher_Click" Tag="Month" Content="Month" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                            </StackPanel>

                            <Button x:Name="RefreshBtn" Click="Refresh_Click" Width="32" Height="32" Padding="0" CornerRadius="6" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" ToolTipService.ToolTip="Refresh Calendar">
                                <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppFgColorBrush}" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- SfScheduler Control -->
                    <Border Grid.Row="1" BorderBrush="{ThemeResource AppGlassSubColorBrush}" BorderThickness="1,0,0,0">
                        <scheduler:SfScheduler
                                               x:Name="Scheduler" 
                                               HeaderHeight="0"
                                               ViewType="Month" 
                                               Background="Transparent"
                                               BorderThickness="0"
                                               ItemsSource="{x:Bind Appointments, Mode=OneWay}"
                                               AppointmentTapped="Scheduler_AppointmentTapped"
                                               ViewChanged="Scheduler_ViewChanged">
                        <scheduler:SfScheduler.Resources>
                            <!-- Style for View Header Control (displays days of week at top of cells) -->
                            <Style TargetType="scheduler:ViewHeaderControl">
                                <Setter Property="Background" Value="{ThemeResource AppGlassSubColorBrush}" />
                                <Setter Property="BorderBrush" Value="{ThemeResource AppGlassSubColorBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Foreground" Value="{ThemeResource AppFgMutedColorBrush}" />
                            </Style>

                            <!-- Override Syncfusion Scheduler Theme Brushes for Glassy Look -->
                            <SolidColorBrush x:Key="SyncfusionSchedulerBackground" Color="Transparent" />
                            <StaticResource x:Key="SyncfusionViewHeaderControlBackground" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionViewHeaderBaseBackground" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionTimeRulerCellBackground" ResourceKey="AppGlassSubColorBrush" />
                            <SolidColorBrush x:Key="SyncfusionTimeSlotCellBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="SyncfusionAllDayAppointmentViewControlBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="SyncfusionResourceHeaderControlBackground" Color="Transparent" />

                            <!-- Borders -->
                            <StaticResource x:Key="SyncfusionSchedulerBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionViewHeaderControlBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionTimeRulerCellBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionTimeSlotCellBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionAllDayAppointmentViewControlBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                            <StaticResource x:Key="SyncfusionResourceHeaderControlBorderBrush" ResourceKey="AppGlassSubColorBrush" />

                            <!-- Foregrounds -->
                            <StaticResource x:Key="SyncfusionTimeRulerCellForeground" ResourceKey="AppFgMutedColorBrush" />
                            <StaticResource x:Key="SyncfusionDayViewHeaderDayForeground" ResourceKey="AppFgMutedColorBrush" />
                            <StaticResource x:Key="SyncfusionDayViewHeaderDateForeground" ResourceKey="AppFgColorBrush" />
                            <StaticResource x:Key="SyncfusionResourceHeaderControlForeground" ResourceKey="AppFgColorBrush" />
                            <StaticResource x:Key="SyncfusionMonthViewHeaderForeground" ResourceKey="AppFgMutedColorBrush" />
                        </scheduler:SfScheduler.Resources>
                        
                        <scheduler:SfScheduler.AppointmentMapping>
                            <scheduler:AppointmentMapping
                                Subject="Subject"
                                StartTime="StartTime"
                                EndTime="EndTime"
                                AppointmentBackground="AppointmentBackground"
                                IsAllDay="IsAllDay"
                                Notes="Notes"
                                Location="Location" />
                        </scheduler:SfScheduler.AppointmentMapping>

                        <scheduler:SfScheduler.MonthViewSettings>
                            <scheduler:MonthViewSettings>
                                <!-- Custom Month Cell Template for glassy grid look -->
                                <scheduler:MonthViewSettings.MonthCellTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" 
                                                BorderBrush="{ThemeResource AppGlassSubColorBrush}" 
                                                BorderThickness="0,0,1,1">
                                            <Grid>
                                                <!-- Today Highlight Glow (Background of today's cell) -->
                                                <Border Background="{Binding DateTime, Converter={StaticResource TodayBackgroundGlowConverter}}" 
                                                        Visibility="{Binding DateTime, Converter={StaticResource IsTodayToVisibilityConverter}}" />
                                                
                                                <!-- Today Cell Outline Border -->
                                                <Border BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                        BorderThickness="1.5"
                                                        Margin="0,0,1,1"
                                                        Opacity="0.3"
                                                        Visibility="{Binding DateTime, Converter={StaticResource IsTodayToVisibilityConverter}}" />

                                                <Grid Margin="8,6,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="20" Height="20">
                                                    <!-- Today Circle badge -->
                                                    <Ellipse Fill="{Binding DateTime, Converter={StaticResource TodayCircleBadgeBrushConverter}}" 
                                                             Visibility="{Binding DateTime, Converter={StaticResource IsTodayToVisibilityConverter}}" />
                                                    
                                                    <TextBlock Text="{Binding DateTime.Day}" 
                                                               Foreground="{Binding DateTime, Converter={StaticResource IsTodayToBrushConverter}}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </scheduler:MonthViewSettings.MonthCellTemplate>
                            </scheduler:MonthViewSettings>
                        </scheduler:SfScheduler.MonthViewSettings>
                    </scheduler:SfScheduler>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Progress Overlay -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#1D000000" Visibility="{x:Bind IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay, FallbackValue=Collapsed}">
            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
        </Grid>
    </Grid>
</Page>
