<Page
    x:Class="Daily_WinUI.Views.CalendarDetailPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Daily_WinUI.Views"
    xmlns:scheduler="using:Syncfusion.UI.Xaml.Scheduler"
    xmlns:converters="using:Daily_WinUI.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Top Header Area (Shared spanned across columns) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Padding="20,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ToggleButton x:Name="ToggleSidebarBtn" IsChecked="True" Checked="ToggleSidebar_Checked" Unchecked="ToggleSidebar_Unchecked" Width="40" Height="40" CornerRadius="20" Background="{ThemeResource AppGlassColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Padding="0" ToolTipService.ToolTip="Toggle Sidebar">
                    <FontIcon Glyph="&#xE787;" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{ThemeResource AppFgColorBrush}" />
                </ToggleButton>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Calendar &amp; Tasks" FontSize="26" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Foreground="{ThemeResource AppFgColorBrush}" />
                    <TextBlock Text="Manage connected calendars and track daily appointments" FontSize="11" Foreground="{ThemeResource AppFgMutedColorBrush}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Left Sidebar: Accounts Panel -->
        <Border Grid.Row="1" Grid.Column="0" 
                x:Name="SidebarPanel"
                Background="{ThemeResource AppGlassColorBrush}" 
                BorderBrush="{ThemeResource AppGlassBorderColorBrush}" 
                BorderThickness="0,1,1,0" 
                Padding="16,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Connected title -->
                <TextBlock Grid.Row="0" Text="Connected Accounts" FontSize="14" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,14" />

                <!-- Accounts List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,16">
                    <ItemsControl ItemsSource="{x:Bind Accounts, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:DisplayAccount">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Provider Icon -->
                                        <Border Grid.Column="0" Grid.Row="0" Width="32" Height="32" CornerRadius="16" Background="{x:Bind ColorBrush}" Margin="0,0,10,0">
                                            <FontIcon Glyph="{x:Bind IconGlyph}" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Email Address -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{x:Bind Email}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppFgColorBrush}" />
                                            <TextBlock Text="{x:Bind AccountType}" FontSize="10" Opacity="0.5" Foreground="{ThemeResource AppFgColorBrush}" />
                                        </StackPanel>

                                        <!-- Right side controls: Toggle / Disconnect -->
                                        <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <ToggleSwitch IsOn="{x:Bind IsActive, Mode=TwoWay}" Toggled="AccountActive_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            <Button Background="Transparent" BorderThickness="0" Padding="4" Click="DeleteAccount_Click" ToolTipService.ToolTip="Disconnect Account">
                                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource AppErrorBrush}" />
                                            </Button>
                                        </StackPanel>

                                        <!-- Preset Color Dots Selection -->
                                        <ItemsControl Grid.Row="1" Grid.ColumnSpan="3" x:Name="ColorItemsControl" Tag="{Binding}" ItemsSource="{Binding ElementName=RootPage, Path=ColorPresets}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <!-- Color dot button. Use custom styling or simple circular border. -->
                                                    <Button Width="18" Height="18" Padding="0" CornerRadius="9" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Click="ColorPreset_Click" Tag="{Binding Tag, ElementName=ColorItemsControl}">
                                                        <Button.Background>
                                                            <SolidColorBrush Color="{Binding}" />
                                                        </Button.Background>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Bottom Panel: Add new connections (Expander) -->
                <Expander Grid.Row="2"
                          Header="Link New Calendar"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          IsExpanded="False"
                          Padding="0">
                    <StackPanel Spacing="8" Padding="12">
                        <Button Click="ConnectGoogle_Click" HorizontalAlignment="Stretch" Padding="12,8" CornerRadius="8" Background="#100078D4" BorderBrush="#200078D4">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xEC1F;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF0078D4" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Connect Google Calendar" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF0078D4" />
                            </Grid>
                        </Button>
                        
                        <Button Click="ConnectMicrosoft_Click" HorizontalAlignment="Stretch" Padding="12,8" CornerRadius="8" Background="#10107C41" BorderBrush="#20107C41">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xECD8;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF107C41" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Connect Microsoft Outlook" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF107C41" />
                            </Grid>
                        </Button>
                        
                        <Button Click="ConnectYahoo_Click" HorizontalAlignment="Stretch" Padding="12,8" CornerRadius="8" Background="#10512BD4" BorderBrush="#20512BD4">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xED73;" FontFamily="{StaticResource TablerIconsFont}" FontSize="14" Foreground="#FF512BD4" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Connect Yahoo Calendar" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF512BD4" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Expander>
            </Grid>
        </Border>

        <!-- Right Pane: Syncfusion Scheduler -->
        <Grid Grid.Row="1" Grid.Column="1" Padding="20,0,20,20">
            <!-- Glassy Border Container -->
            <Border Background="{ThemeResource AppGlassColorBrush}"
                    BorderBrush="{ThemeResource AppGlassBorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Style="{StaticResource GlassPanelStyle}">
                <!-- SfScheduler Control -->
                <scheduler:SfScheduler x:Name="Scheduler" 
                                       HeaderHeight="50"
                                       ViewType="Month" 
                                       Background="Transparent"
                                       BorderThickness="0"
                                       ItemsSource="{x:Bind Appointments, Mode=OneWay}"
                                       AppointmentTapped="Scheduler_AppointmentTapped">
                    <scheduler:SfScheduler.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="32" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Background" Value="{ThemeResource AppGlassSubColorBrush}" />
                            <Setter Property="BorderBrush" Value="{ThemeResource AppGlassBorderColorBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="CornerRadius" Value="6" />
                            <Setter Property="Padding" Value="12,4" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="Foreground" Value="{ThemeResource AppFgColorBrush}" />
                        </Style>

                        <!-- Style for Scheduler Header Control -->
                        <Style TargetType="scheduler:SchedulerHeaderControl">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="{ThemeResource AppGlassSubColorBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Foreground" Value="{ThemeResource AppFgColorBrush}" />
                        </Style>

                        <!-- Style for View Header Control (displays days of week at top of cells) -->
                        <Style TargetType="scheduler:ViewHeaderControl">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="{ThemeResource AppGlassSubColorBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Foreground" Value="{ThemeResource AppFgMutedColorBrush}" />
                        </Style>

                        <!-- Override Syncfusion Scheduler Theme Brushes for Glassy Look -->
                        <SolidColorBrush x:Key="SyncfusionSchedulerBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="SyncfusionViewHeaderControlBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="SyncfusionViewHeaderBaseBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="SyncfusionTimeRulerCellBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="SyncfusionTimeSlotCellBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="SyncfusionAllDayAppointmentViewControlBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="SyncfusionResourceHeaderControlBackground" Color="Transparent" />

                        <!-- Borders -->
                        <StaticResource x:Key="SyncfusionSchedulerBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                        <StaticResource x:Key="SyncfusionViewHeaderControlBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                        <StaticResource x:Key="SyncfusionTimeRulerCellBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                        <StaticResource x:Key="SyncfusionTimeSlotCellBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                        <StaticResource x:Key="SyncfusionAllDayAppointmentViewControlBorderBrush" ResourceKey="AppGlassSubColorBrush" />
                        <StaticResource x:Key="SyncfusionResourceHeaderControlBorderBrush" ResourceKey="AppGlassSubColorBrush" />

                        <!-- Foregrounds -->
                        <StaticResource x:Key="SyncfusionTimeRulerCellForeground" ResourceKey="AppFgMutedColorBrush" />
                        <StaticResource x:Key="SyncfusionDayViewHeaderDayForeground" ResourceKey="AppFgMutedColorBrush" />
                        <StaticResource x:Key="SyncfusionDayViewHeaderDateForeground" ResourceKey="AppFgColorBrush" />
                        <StaticResource x:Key="SyncfusionResourceHeaderControlForeground" ResourceKey="AppFgColorBrush" />
                        <StaticResource x:Key="SyncfusionMonthViewHeaderForeground" ResourceKey="AppFgMutedColorBrush" />
                    </scheduler:SfScheduler.Resources>
                    
                    <scheduler:SfScheduler.AppointmentMapping>
                        <scheduler:AppointmentMapping
                            Subject="Subject"
                            StartTime="StartTime"
                            EndTime="EndTime"
                            AppointmentBackground="AppointmentBackground"
                            IsAllDay="IsAllDay"
                            Notes="Notes"
                            Location="Location" />
                    </scheduler:SfScheduler.AppointmentMapping>

                    <scheduler:SfScheduler.MonthViewSettings>
                        <scheduler:MonthViewSettings>
                            <!-- Custom Month Cell Template for glassy grid look -->
                            <scheduler:MonthViewSettings.MonthCellTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" 
                                            BorderBrush="{ThemeResource AppGlassSubColorBrush}" 
                                            BorderThickness="0,0,1,1">
                                        <TextBlock Text="{Binding DateTime.Day}" 
                                                   Foreground="{ThemeResource AppFgColorBrush}"
                                                   FontSize="11"
                                                   Margin="8,6,0,0" 
                                                   HorizontalAlignment="Left" 
                                                   VerticalAlignment="Top" 
                                                   Opacity="0.8"/>
                                    </Border>
                                </DataTemplate>
                            </scheduler:MonthViewSettings.MonthCellTemplate>
                        </scheduler:MonthViewSettings>
                    </scheduler:SfScheduler.MonthViewSettings>
                </scheduler:SfScheduler>
            </Border>

            <!-- Scheduler Controls Overlay (Aligned with SfScheduler Header) -->
            <Grid Height="50" HorizontalAlignment="Right" VerticalAlignment="Top" Canvas.ZIndex="1" Margin="0,16,116,0">
                <!-- View switch buttons -->
                <StackPanel Orientation="Horizontal" Spacing="2" Background="{ThemeResource AppGlassSubColorBrush}" BorderBrush="{ThemeResource AppGlassBorderColorBrush}" BorderThickness="1" Padding="2" CornerRadius="6" Height="32" VerticalAlignment="Center">
                    <Button Click="ViewSwitcher_Click" Tag="Day" Content="Day" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                    <Button Click="ViewSwitcher_Click" Tag="Week" Content="Week" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                    <Button Click="ViewSwitcher_Click" Tag="WorkWeek" Content="Work" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                    <Button Click="ViewSwitcher_Click" Tag="Month" Content="Month" CornerRadius="5" Padding="12,0" FontSize="11" Background="Transparent" BorderThickness="0" Height="26" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Progress Overlay -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#1D000000" Visibility="{x:Bind IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay, FallbackValue=Collapsed}">
            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
        </Grid>
    </Grid>
</Page>
