  <!--
    Defining the "Msix" ProjectCapability here allows the Single-project MSIX Packaging
    Tools extension to be activated for this project even if the Windows App SDK Nuget
    package has not yet been restored.
  -->
  <ItemGroup Condition="'$(DisableMsixProjectCapabilityAddedByProject)'!='true'">
    <ProjectCapability Include="Msix" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.WinUI" Version="2.4.1" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.7" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.7705" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260317003" />
    <PackageReference Include="Microsoft.WindowsAppSDK.ML" Version="1.8.2141" ExcludeAssets="all" />
    <PackageReference Include="sqlite-net-pcl" Version="1.9.172" />
    <PackageReference Include="SQLitePCLRaw.bundle_green" Version="2.1.11" />
    <PackageReference Include="Syncfusion.Chart.WinUI" Version="33.2.4" />
    <PackageReference Include="Syncfusion.Editors.WinUI" Version="33.2.4" />
    <PackageReference Include="Syncfusion.Gauge.WinUI" Version="33.2.4" />
    <PackageReference Include="Syncfusion.Notifications.WinUI" Version="33.2.4" />
    <PackageReference Include="Syncfusion.Scheduler.WinUI" Version="33.2.4" />
    <PackageReference Include="SmartReader" Version="0.10.2" />
    <PackageReference Include="Supabase" Version="1.1.1" />
    <PackageReference Include="postgrest-csharp" Version="3.5.1" />
    <PackageReference Include="YahooFinanceApi" Version="2.3.3" />
    <PackageReference Include="LLamaSharp" Version="0.27.0" />
    <PackageReference Include="LLamaSharp.Backend.Cpu" Version="0.27.0" GeneratePathProperty="true" />
    <PackageReference Include="LLamaSharp.Backend.Cuda12" Version="0.27.0" GeneratePathProperty="true" />
    <PackageReference Include="LLamaSharp.Backend.Vulkan" Version="0.27.0" GeneratePathProperty="true" />
    <PackageReference Include="System.Management" Version="9.0.0" />
  </ItemGroup>


  <!--
    Defining the "HasPackageAndPublishMenuAddedByProject" property here allows the Solution
    Explorer "Package and Publish" context menu entry to be enabled for this project even if
    the Windows App SDK Nuget package has not yet been restored.
  -->
  <PropertyGroup Condition="'$(DisableHasPackageAndPublishMenuAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
    <HasPackageAndPublishMenu>true</HasPackageAndPublishMenu>
  </PropertyGroup>

  <!-- Publish Properties -->
  <PropertyGroup>
    <PublishReadyToRun Condition="'$(Configuration)' == 'Debug'">False</PublishReadyToRun>
    <PublishReadyToRun Condition="'$(Configuration)' != 'Debug'">True</PublishReadyToRun>
    <PublishTrimmed Condition="'$(Configuration)' == 'Debug'">False</PublishTrimmed>
    <PublishTrimmed Condition="'$(Configuration)' != 'Debug'">True</PublishTrimmed>
  </PropertyGroup>

  <!-- Add native backend DLLs to AppX Packaging payload -->
  <Target Name="AddLLamaBackendsToPayload" BeforeTargets="_ComputeAppxPackagePayload">
    <ItemGroup>
      <NativeDllPayloadX64 Include="$(OutputPath)runtimes\win-x64\native\**\*.*" />
      <NativeDllPayloadArm64 Include="$(OutputPath)runtimes\win-arm64\native\**\*.*" />
      
      <PackagingOutputs Include="@(NativeDllPayloadX64)">
        <TargetPath>runtimes\win-x64\native\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
        <ProjectName>$(MSBuildProjectName)</ProjectName>
        <OutputGroup>LLamaNativeBackends</OutputGroup>
      </PackagingOutputs>
      <PackagingOutputs Include="@(NativeDllPayloadArm64)">
        <TargetPath>runtimes\win-arm64\native\%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
        <ProjectName>$(MSBuildProjectName)</ProjectName>
        <OutputGroup>LLamaNativeBackends</OutputGroup>
      </PackagingOutputs>
    </ItemGroup>
  </Target>

  <!-- Remove older DirectML, ONNX, and root llama/ggml DLLs from default packaging payload -->
  <Target Name="FilterPackagingOutputs" BeforeTargets="_ComputeAppxPackagePayload">
    <ItemGroup>
      <PackagingOutputs Remove="$(MSBuildProjectDirectory)\obj\**\MsixContent\DirectML.dll" />
      <PackagingOutputs Remove="$(MSBuildProjectDirectory)\obj\**\MsixContent\onnxruntime.dll" />
      <PackagingOutputs Remove="$(MSBuildProjectDirectory)\obj\**\MsixContent\onnxruntime_providers_shared.dll" />
      <PackagingOutputs Remove="$(MSBuildProjectDirectory)\obj\**\MsixContent\DirectML.pdb" />
      <PackagingOutputs Remove="$(MSBuildProjectDirectory)\obj\**\MsixContent\llama.dll" />
      <PackagingOutputs Remove="$(MSBuildProjectDirectory)\obj\**\MsixContent\ggml.dll" />
    </ItemGroup>
  </Target>

</Project>

